   "source": [
    "# Estimating based on GFP density in the estimated neighborhood\n",
    "- Only for pan-inhibitory.\n",
    "- TODO: dev a protocol for pan-neuronal (when needed)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "ffaf5347",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
