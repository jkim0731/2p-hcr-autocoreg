gion\\n    \\n    Parameters:\\n    -----------\\n    landmarks_df : pd.DataFrame\\n        Landmarks with 'czstack_x', 'czstack_y', 'czstack_z', 'ids' columns\\n    grid_size_pix : tuple\\n        (x, y, z) size of grid cells in pixels\\n    edge_margin_pix : tuple\\n        (x, y, z) margin from volume edges to define \\\"edge\\\" region in pixels\\n    interior_keep_proportion : float\\n        Proportion of interior points to keep (e.g., 0.1 for 10%)\\n    edge_keep_proportion : float\\n        Proportion of edge points to keep (e.g., 0.2 for 20%)\\n    \\n    Returns:\\n    --------\\n    dict with keys:\\n        'sampled': DataFrame of sampled landmarks\\n        'edge': DataFrame of edge landmarks\\n        'interior': DataFrame of interior landmarks (for reference)\\n        'removed': DataFrame of removed landmarks\\n        'stats': dict with counts and percentages\\n    \\\"\\\"\\\"\\n    \\n    # Get volume bounds from data\\n    bounds = get_volume_bounds_from_data(landmarks_df, margin_pix=0)\\n    print(f\\\"Volume bounds from data:\\\")\\n    print(f\\\"  X: {bounds['x'][0]:.0f} - {bounds['x'][1]:.0f} pixels\\\")\\n    print(f\\\"  Y: {bounds['y'][0]:.0f} - {bounds['y'][1]:.0f} pixels\\\")\\n    print(f\\\"  Z: {bounds['z'][0]:.0f} - {bounds['z'][1]:.0f} pixels\\\\n\\\")\\n    \\n    # Identify edge landmarks\\n    x_min, x_max = bounds['x']\\n    y_min, y_max = bounds['y']\\n    z_min, z_max = bounds['z']\\n    \\n    near_edge_x = (landmarks_df['czstack_x'] < x_min + edge_margin_pix[0]) | \\\\\\n                  (landmarks_df['czstack_x'] > x_max - edge_margin_pix[0])\\n    near_edge_y = (landmarks_df['czstack_y'] < y_min + edge_margin_pix[1]) | \\\\\\n                  (landmarks_df['czstack_y'] > y_max - edge_margin_pix[1])\\n    near_edge_z = (landmarks_df['czstack_z'] < z_min + edge_margin_pix[2]) | \\\\\\n                  (landmarks_df['czstack_z'] > z_max - edge_margin_pix[2])\\n    \\n    near_edge = near_edge_x | near_edge_y | near_edge_z\\n    edge_lm = landmarks_df[near_edge]\\n    interior_lm = landmarks_df[~near_edge]\\n    \\n    print(f\\\"Edge landmarks: {len(edge_lm)} ({100*len(edge_lm)/len(landmarks_df):.1f}%)\\\")\\n    print(f\\\"Interior landmarks: {len(interior_lm)} ({100*len(interior_lm)/len(landmarks_df):.1f}%)\\\\n\\\")\\n    \\n    # Create grid cells\\n    x_edges = np.arange(x_min, x_max + grid_size_pix[0], grid_size_pix[0])\\n    y_edges = np.arange(y_min, y_max + grid_size_pix[1], grid_size_pix[1])\\n    z_edges = np.arange(z_min, z_max + grid_size_pix[2], grid_size_pix[2])\\n    \\n    print(f\\\"Grid cells:\\\")\\n    print(f\\\"  X: {len(x_edges)-1} cells × {grid_size_pix[0]} pixels\\\")\\n    print(f\\\"  Y: {len(y_edges)-1} cells × {grid_size_pix[1]} pixels\\\")\\n    print(f\\\"  Z: {len(z_edges)-1} cells × {grid_size_pix[2]} pixels\\\")\\n    print(f\\\"  Total: {(len(x_edges)-1)*(len(y_edges)-1)*(len(z_edges)-1)} cells\\\\n\\\")\\n    \\n    # Sample interior landmarks\\n    sampled_interior = []\\n    if len(interior_lm) > 0:\\n        interior_lm_copy = interior_lm.copy()\\n        interior_lm_copy['grid_x'] = np.digitize(interior_lm_copy['czstack_x'], x_edges) - 1\\n        interior_lm_copy['grid_y'] = np.digitize(interior_lm_copy['czstack_y'], y_edges) - 1\\n        interior_lm_copy['grid_z'] = np.digitize(interior_lm_copy['czstack_z'], z_edges) - 1\\n        \\n        for (gx, gy, gz), group in interior_lm_copy.groupby(['grid_x', 'grid_y', 'grid_z']):\\n            n_to_keep = max(1, int(np.ceil(len(group) * interior_keep_proportion)))\\n            sampled_interior.append(group.sample(n=min(n_to_keep, len(group)), random_state=42))\\n        \\n        sampled_interior_df = pd.concat(sampled_interior, ignore_index=True)\\n        sampled_interior_df = sampled_interior_df.drop(columns=['grid_x', 'grid_y', 'grid_z'])\\n    else:\\n        sampled_interior_df = pd.DataFrame()\\n    \\n    # Sample edge landmarks\\n    sampled_edge = []\\n    if len(edge_lm) > 0:\\n  