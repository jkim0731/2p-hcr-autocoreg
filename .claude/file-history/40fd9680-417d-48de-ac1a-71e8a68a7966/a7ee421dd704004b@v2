"""v2-S04 Stage D iter 4 — fast K=4 constellation enumeration.

For each subject, enumerate K=4 quadruples over the top-N most-confident
top-slab CZ cells (by sum of candidate score from step 1), gate by
pairwise-spread + hull-area, take the rank-1 HCR per CZ, and score each
quadruple by the residual of an aniso-similarity (R, t, scales) fit to
the 4 (CZ, HCR) pairs.

This is a "consistency" filter: low residual = the four (CZ, HCR) pairs
all agree on the same global affine transform.  High residual = at
least one pair is inconsistent (the rank-1 HCR is wrong for at least
one CZ in the constellation).

We use `fit_anisotropic_similarity` (which is the GT scoring function)
to keep the metric comparable to v2 bench scoring.

Outputs
-------
- `step2_{sid}{TAG}_constellation.csv` — top-N quadruples by RMSE.
- `step2_all_subjects_summary{TAG}.csv` — best per subject.
"""
from __future__ import annotations

import os
import sys
import time
from itertools import combinations
from pathlib import Path

