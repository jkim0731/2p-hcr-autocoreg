    "def pair_errors(D, mid):\n",
    "    \"\"\"Per-predicted-pair GT residual.  GT fit is in (x,y,z); pairs stored in µm columns x/y/z.\"\"\"\n",
    "    pairs = D['pairs'][mid]\n",
    "    if len(pairs) == 0:\n",
    "        return np.array([])\n",
    "    cz_xyz = pairs[['cz_x_um', 'cz_y_um', 'cz_z_um']].values\n",
    "    hcr_pair_xyz = pairs[['hcr_x_um', 'hcr_y_um', 'hcr_z_um']].values\n",
    "    cz_lm = D['gt']['cz_lm']; hcr_lm = D['gt']['hcr_lm']\n",
    "    src_mean = cz_lm.mean(axis=0); dst_mean = hcr_lm.mean(axis=0)\n",
    "    R, sc = D['gt']['gt_R'], D['gt']['gt_scales']\n",
    "    # fit_anisotropic_similarity predict: (src - src_mean) @ R * scales + dst_mean\n",
    "    hcr_gt_xyz = (cz_xyz - src_mean) @ R * sc + dst_mean\n",
    "    return np.linalg.norm(hcr_pair_xyz - hcr_gt_xyz, axis=1)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4.5), sharey=True)\n",
    "for ax, sid, D, label in [(axes[0], WINNER, DW, 'winner 767018'),\n",
    "                           (axes[1], LOSER, DL, 'loser 782149')]:\n",
    "    bins = np.linspace(0, 100, 41)\n",
    "    summ = []\n",
    "    for mid, color in [('M3_ICP', 'C0'), ('C5', 'C1'), ('P3', 'C2')]:\n",
    "        err = pair_errors(D, mid)\n",
    "        if len(err) == 0:\n",
    "            continue\n",
    "        ax.hist(err, bins=bins, alpha=0.55, label=f'{mid} (n={len(err)}, med={np.median(err):.1f})', color=color)\n",
    "        summ.append((mid, len(err), float(np.median(err)),\n",
    "                     float((err <= 20).mean()), float((err <= 30).mean())))\n",
    "    ax.axvline(20, color='k', ls='--', lw=0.7, label='r@20 cutoff')\n",
    "    ax.axvline(30, color='gray', ls='--', lw=0.7, label='r@30 cutoff')\n",
    "    ax.set_xlabel('per-pair residual to GT [µm]')\n",
    "    ax.set_title(f'{label}')\n",
    "    ax.legend(fontsize=8)\n",
    "    print(f'\\n{label}:')\n",
    "    for row in summ:\n",
    "        print(f\"  {row[0]:8s} n={row[1]:4d}  med={row[2]:6.1f} µm  r@20={row[3]:.3f}  r@30={row[4]:.3f}\")\n",
    "axes[0].set_ylabel('count')\n",
