    "def scale_recovery_table(D, sid):\n",
    "    \"\"\"Compare each method's effective (sxy, sz) to GT.\n",
    "\n",
    "    GT scales array is in (x, y, z) order — sxy = avg(scales[0], scales[1]); sz = scales[2].\n",
    "    Method residual scales (P3/C5) are in (z, y, x) order because the candidate\n",
    "    operates on cz_lp (centroids in zyx) — sz_resid = scales[0]; sxy_resid = avg(scales[1], scales[2]).\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    sc_gt = D['gt']['gt_scales']\n",
    "    sxy_gt = float((sc_gt[0] + sc_gt[1]) / 2)\n",
    "    sz_gt = float(sc_gt[2])\n",
    "    rows.append({'method': 'GT (landmarks)', 'sxy': sxy_gt, 'sz': sz_gt,\n",
    "                 'sxy err %': 0.0, 'sz err %': 0.0})\n",
    "    sz_pin = float(D['icp']['sz_pin'])\n",
    "    sxy_lp = float(D['icp']['sxy_lp'])\n",
    "    rows.append({'method': 'LP + sz pin (warmstart)', 'sxy': sxy_lp, 'sz': sz_pin,\n",
    "                 'sxy err %': (sxy_lp - sxy_gt) / sxy_gt * 100,\n",
    "                 'sz err %': (sz_pin - sz_gt) / sz_gt * 100})\n",
    "    rows.append({'method': 'M3-ICP-locked (effective)', 'sxy': sxy_lp, 'sz': sz_pin,\n",
    "                 'sxy err %': (sxy_lp - sxy_gt) / sxy_gt * 100,\n",
    "                 'sz err %': (sz_pin - sz_gt) / sz_gt * 100})\n",
    "    for mid in ['C5', 'P3']:\n",
    "        if mid not in D['txfm']:\n",
    "            continue\n",
    "        sc = D['txfm'][mid]['scales']  # in (z, y, x) order\n",
    "        sz_resid = float(sc[0]); sxy_resid = float((sc[1] + sc[2]) / 2)\n",
    "        sz_eff = sz_pin * sz_resid\n",
    "        sxy_eff = sxy_lp * sxy_resid\n",
    "        rows.append({'method': mid, 'sxy': sxy_eff, 'sz': sz_eff,\n",
    "                     'sxy err %': (sxy_eff - sxy_gt) / sxy_gt * 100,\n",
    "                     'sz err %': (sz_eff - sz_gt) / sz_gt * 100})\n",
    "    df = pd.DataFrame(rows)\n",
    "    print(f'\\n=== {sid} — recovered scales ===')\n",
    "    return df.round(3)\n",
