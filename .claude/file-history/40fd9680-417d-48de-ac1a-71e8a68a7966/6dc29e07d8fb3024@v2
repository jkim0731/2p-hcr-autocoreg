    "import json\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "S = Path('/root/capsule/code/full_automatic_execution_02/sessions/v2_S03_revival_pass')\n",
    "VD = S / 'viz_data'\n",
    "\n",
    "def load_subject(sid):\n",
    "    cen = np.load(VD / f'{sid}_centroids.npz')\n",
    "    gt = np.load(VD / f'{sid}_gt.npz')\n",
    "    icp_diag = json.loads((VD / f'{sid}_M3_ICP_diag.json').read_text())\n",
    "    pairs = {}\n",
    "    txfm = {}\n",
    "    for mid in ['M3_ICP', 'C5', 'P3']:\n",
    "        p = VD / f'{sid}_{mid}_pairs.csv'\n",
    "        pairs[mid] = pd.read_csv(p) if p.exists() else pd.DataFrame()\n",
    "        tp = VD / f'{sid}_{mid}_transform.npz'\n",
    "        if tp.exists():\n",
    "            t = np.load(tp, allow_pickle=True)\n",
    "            txfm[mid] = dict(R=t['R'], scales=t['scales'], translation=t['translation'])\n",
    "    return dict(cen=cen, gt=gt, icp=icp_diag, pairs=pairs, txfm=txfm)\n",
    "\n",
    "def warped_cz(cz_lp, mid, txfm, icp_diag):\n",
    "    \"\"\"Apply method-specific residual transform to LP-warped CZ.\"\"\"\n",
    "    if mid == 'M3_ICP':\n",
    "        R = np.asarray(icp_diag['residual_R'])\n",
    "        t = np.asarray(icp_diag['residual_t_um'])\n",
    "        return cz_lp @ R.T + t\n",
    "    # P3/C5 transforms operate on cz_init=cz_lp\n",
    "    R = txfm[mid]['R']; sc = txfm[mid]['scales']; tt = txfm[mid]['translation']\n",
    "    return cz_lp @ np.diag(sc) @ R.T + tt\n",
    "\n",
    "WINNER = '767018'\n",
    "LOSER  = '782149'\n",
    "DW = load_subject(WINNER)\n",
    "DL = load_subject(LOSER)\n",
