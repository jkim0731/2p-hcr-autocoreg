def _discover_cz_seg(sid: str):
    for d in DATA_DIR.glob(f"multiplane-ophys_{sid}_*cortical-zstack-segmentation*"):
        tif = d / "channel_0_ref_0" / "segmentation_masks.tif"
        if tif.exists():
            return tif
    return None


def cz_roi_areas(sid: str, s, cz_surf) -> pd.DataFrame:
    """Per-CZ-cell bbox xy area (µm²) and pia depth (µm)."""
    path = _discover_cz_seg(sid)
    if path is None or not path.exists():
        raise FileNotFoundError(f"CZ seg mask for {sid}")
    mask = tifffile.imread(path)  # (z, y, x), uint32
    rp = regionprops(mask)
    # Voxel sizes
    dz_um = s.cz_z_um
    dy_um = s.cz_xy_um
    dx_um = s.cz_xy_um
    rows = []
    for r in rp:
        zlo, ylo, xlo, zhi, yhi, xhi = r.bbox
        dz = (zhi - zlo) * dz_um
        dy = (yhi - ylo) * dy_um
        dx = (xhi - xlo) * dx_um
        # centroid px -> um, then xy-depth
        zc, yc, xc = r.centroid
        # convert to [x, y, z] µm in CZ frame
        xyz_um = cz_px_to_um(np.array([[zc, yc, xc]]), s)[0]
        x_um, y_um, z_um_c = xyz_um[2], xyz_um[1], xyz_um[0]
        depth = float(depth_from_surface(np.array([[x_um, y_um, z_um_c]]), cz_surf)[0])
        rows.append({
            "cz_id": r.label,
            "xy_area_um2": dx * dy,
            "bbox_dx_um": dx, "bbox_dy_um": dy, "bbox_dz_um": dz,
            "volume_vox": r.area,
            "volume_um3": r.area * dz_um * dy_um * dx_um,
            "x_um": x_um, "y_um": y_um, "z_um": z_um_c,
            "depth_um": depth,
        })
    return pd.DataFrame(rows)


def _hcr_metrics_path(sid: str) -> Path:
    hits = glob.glob(f"/root/capsule/data/HCR_{sid}_*/cell_body_segmentation/metrics.pickle")
    if not hits:
        raise FileNotFoundError(f"HCR cell-body metrics.pickle for {sid}")
    return Path(hits[0])


def hcr_gfp_areas(sid: str, s, hcr_surf, strict_ids: set[int]) -> pd.DataFrame:
    """Per-HCR-cell bbox xy area for strict-GFP+ cell-body segmentation.

    Source of truth: `cell_body_segmentation/metrics.pickle` (per-cell
    `global_bbox` + `volume`). Keyed by `hcr_id` — same ids as GFP+ tables.
    """
    with open(_hcr_metrics_path(sid), "rb") as f:
        metrics = pickle.load(f)
    ids_all = np.fromiter(metrics.keys(), dtype=np.int64)
    ids_strict = np.array(sorted(int(i) for i in strict_ids if int(i) in metrics),
                          dtype=np.int64)
    if ids_strict.size == 0:
        return pd.DataFrame()
    bboxes = np.stack([np.asarray(metrics[int(i)]["global_bbox"], dtype=float)
                       for i in ids_strict])  # (N, 6) z y x z y x
    volumes = np.array([float(metrics[int(i)]["volume"]) for i in ids_strict])
    dz_um, dy_um, dx_um = s.hcr_z_um, s.hcr_xy_um, s.hcr_xy_um
    dx_vox = bboxes[:, 5] - bboxes[:, 2]
    dy_vox = bboxes[:, 4] - bboxes[:, 1]
    dz_vox = bboxes[:, 3] - bboxes[:, 0]
    xy_area_um2 = (dx_vox * dx_um) * (dy_vox * dy_um)
    # centroid from seg bbox center
    zc = 0.5 * (bboxes[:, 0] + bboxes[:, 3])
    yc = 0.5 * (bboxes[:, 1] + bboxes[:, 4])
    xc = 0.5 * (bboxes[:, 2] + bboxes[:, 5])
    zyx_px = np.column_stack([zc, yc, xc])
    xyz_um = hcr_px_to_um(zyx_px, s)[:, [2, 1, 0]]
    depths = depth_from_surface(xyz_um, hcr_surf)
    return pd.DataFrame({
        "hcr_id": ids_strict,
        "xy_area_um2": xy_area_um2,
        "bbox_dx_um": dx_vox * dx_um,
        "bbox_dy_um": dy_vox * dy_um,
        "bbox_dz_um": dz_vox * dz_um,
        "volume_vox": volumes,
        "volume_um3": volumes * dz_um * dy_um * dx_um,
        "x_um": xyz_um[:, 0], "y_um": xyz_um[:, 1], "z_um": xyz_um[:, 2],
        "depth_um": depths,
    })


def filter_cz(df: pd.DataFrame, cz_span: float) -> pd.DataFrame:
    return df[(df["depth_um"] >= D_SKIN) & (df["depth_um"] <= cz_span)].copy()


def filter_hcr(df: pd.DataFrame, hcr_span: float) -> pd.DataFrame:
    xy = df[["x_um", "y_um"]].to_numpy()
    x0, x1 = xy[:, 0].min(), xy[:, 0].max()
    y0, y1 = xy[:, 1].min(), xy[:, 1].max()
    cx, cy = (x0 + x1) / 2, (y0 + y1) / 2
    qx, qy = (x1 - x0) / 4, (y1 - y0) / 4
    m = (
        (xy[:, 0] >= cx - qx) & (xy[:, 0] <= cx + qx)
        & (xy[:, 1] >= cy - qy) & (xy[:, 1] <= cy + qy)
        & (df["depth_um"] >= D_SKIN).values
        & (df["depth_um"] <= hcr_span).values
    )
    return df[m].copy()


def plot_subject(sid, cz_df, hcr_df, sxy_est, sxy_gt):
    fig, axes = plt.subplots(1, 2, figsize=(12, 4.5))

    ax = axes[0]
    lo = min(cz_df.xy_area_um2.min(), hcr_df.xy_area_um2.min())
    hi = max(cz_df.xy_area_um2.max(), hcr_df.xy_area_um2.max())
    bins = np.logspace(np.log10(max(lo, 1)), np.log10(hi), 50)
    ax.hist(cz_df.xy_area_um2, bins=bins, alpha=0.55, color='#268bd2',
            label=f'CZ (n={len(cz_df)}, med={cz_df.xy_area_um2.median():.0f})', density=True)
    ax.hist(hcr_df.xy_area_um2, bins=bins, alpha=0.55, color='#cb4b16',
            label=f'HCR GFP+ (n={len(hcr_df)}, med={hcr_df.xy_area_um2.median():.0f})', density=True)
    ax.set_xscale('log')
    ax.set_xlabel('bbox xy area (µm²)')
    ax.set_ylabel('density')
    ax.set_title(f'{sid}  sxy_est={sxy_est:.3f}  GT={sxy_gt:.3f}  '
                 f'err={100*(sxy_est-sxy_gt)/sxy_gt:+.1f}%')
    ax.legend(fontsize=9)
    ax.grid(True, alpha=0.3)

    ax = axes[1]
    # Depth bins
    depth_bins = np.arange(D_SKIN, max(cz_df.depth_um.max(), hcr_df.depth_um.max()) + 50, 50)
    cz_d = cz_df.depth_um.to_numpy()
    hcr_d = hcr_df.depth_um.to_numpy()
    cz_med = [np.median(cz_df.xy_area_um2[(cz_d >= d) & (cz_d < d+50)]) for d in depth_bins]
    hcr_med = [np.median(hcr_df.xy_area_um2[(hcr_d >= d) & (hcr_d < d+50)]) for d in depth_bins]
    ax.plot(depth_bins, cz_med, 'o-', color='#268bd2', label='CZ median', lw=1.5)
    ax.plot(depth_bins, hcr_med, 's-', color='#cb4b16', label='HCR median', lw=1.5)
    # Also plot sxy² expected gap
    cz_arr = np.array(cz_med, dtype=float)
    expected_hcr = cz_arr * sxy_gt ** 2
    ax.plot(depth_bins, expected_hcr, 'k--', lw=1, label=f'CZ×sxy²_GT', alpha=0.6)
    ax.set_yscale('log')
    ax.set_xlabel('pia depth (µm)')
    ax.set_ylabel('median xy bbox area (µm²)')
    ax.set_title(f'{sid} — area vs depth')
    ax.legend(fontsize=9)
    ax.grid(True, alpha=0.3)

    plt.tight_layout()
    out = FIG_DIR / f'roi_area_{sid}.png'
    plt.savefig(out, dpi=120)
    plt.close(fig)
    return str(out)


def analyze(sid: str) -> dict:
    if sid not in SPOT_SUBJECTS:
        raise ValueError(f"{sid}: intensity subject — no global_bbox in hcr_gfp_df")
    s = load_subject(sid)
    info = analyze_subject(s)
    cz_surf, hcr_surf = info["cz_surface"], info["hcr_surface"]
    # BIC-GMM strict cutoff (session 07c convention)
    gi = gfp_thr.analyze_subject(sid)
    strict_cutoff = float(gi.cutoff_linear)
    strict_df = gfp_thr.strict_gfp_df(sid, strict_cutoff)
    strict_ids = set(int(x) for x in strict_df["hcr_id"].values)

    cz_df_all = cz_roi_areas(sid, s, cz_surf)
    hcr_df_all = hcr_gfp_areas(sid, s, hcr_surf, strict_ids)

    cz_span = float(np.nanpercentile(cz_df_all.depth_um, 99))
    hcr_span = float(np.nanpercentile(hcr_df_all.depth_um, 99))

    cz_df = filter_cz(cz_df_all, cz_span)
    hcr_df = filter_hcr(hcr_df_all, hcr_span)

    med_cz = float(cz_df.xy_area_um2.median())
    med_hcr = float(hcr_df.xy_area_um2.median())
    mean_cz = float(cz_df.xy_area_um2.mean())
    mean_hcr = float(hcr_df.xy_area_um2.mean())

    sxy_med = float(np.sqrt(med_hcr / med_cz))
    sxy_mean = float(np.sqrt(mean_hcr / mean_cz))

    # GT
    fit = fit_anisotropic_similarity(*landmark_pairs_um(s, active_only=True))
    sxy_gt = float(np.sqrt(fit.scales[0] * fit.scales[1]))

    fig = plot_subject(sid, cz_df, hcr_df, sxy_med, sxy_gt)

    return {
        "sid": sid,
        "n_cz_total": int(len(cz_df_all)), "n_cz_used": int(len(cz_df)),
        "n_hcr_strict_total": int(len(hcr_df_all)), "n_hcr_used": int(len(hcr_df)),
        "bic_cutoff_density": strict_cutoff,
        "bic_n_components": int(gi.n_components),
        "cz_span": cz_span, "hcr_span": hcr_span,
        "cz_area_med": med_cz, "hcr_area_med": med_hcr,
        "cz_area_mean": mean_cz, "hcr_area_mean": mean_hcr,
        "sxy_from_median": sxy_med,
        "sxy_from_mean": sxy_mean,
        "sxy_gt": sxy_gt,
        "err_med_pct": 100 * (sxy_med - sxy_gt) / sxy_gt,
        "err_mean_pct": 100 * (sxy_mean - sxy_gt) / sxy_gt,
        "figure": fig,
    }


