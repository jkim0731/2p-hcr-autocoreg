    "# Feature distribution plots for a subset\n",
    "import numpy as np\n",
    "fig, axes = plt.subplots(3, 4, figsize=(12, 7))\n",
    "plot_features = ['knn_elev_0','knn_azdiff_0','depth_um','depth_rank_ring',\n",
