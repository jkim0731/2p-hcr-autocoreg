"""I2 — 3D MI rigid + anisotropic affine via SimpleITK.

Loads CZ z-stack and HCR 488 volume at a coarse pyramid level, downsamples to
an isotropic 8 µm grid for the fit, and runs the F5 affine MI registration
with a 180° + anisotropic-scale initial.  Returns the recovered transform as
the intrinsic result (no per-pair assignment — I2 is a coarse aligner).
"""
from __future__ import annotations

import sys
from pathlib import Path
import numpy as np
import pandas as pd

_THIS = Path(__file__).resolve().parent
_ROOT = _THIS.parent.parent
if str(_ROOT) not in sys.path:
    sys.path.insert(0, str(_ROOT))
if str(_ROOT.parent / "dev_code") not in sys.path:
    sys.path.insert(0, str(_ROOT.parent / "dev_code"))

from bench.harness import register_candidate, CoregResult, TransformDescriptor
from lib.sitk_wrapper import mi_affine


@register_candidate("I2")
def run_i2(s, *, target_um=8.0) -> CoregResult:
    try:
        from ._i1_axial_ncc import _load_cz_fullstack, _load_hcr_fullstack
        cz_stack, cz_xy_um, cz_z_um = _load_cz_fullstack(s)
        hcr_vol, hcr_xy_um, hcr_z_um = _load_hcr_fullstack(s)
    except Exception as e:
        return CoregResult(pd.DataFrame(), 0.0, diagnostics={"error": f"load: {e}"})

    # Crude downsample to ~target_um isotropic
    from scipy.ndimage import zoom
    cz_zoom = (cz_z_um / target_um, cz_xy_um / target_um, cz_xy_um / target_um)
    hcr_zoom = (hcr_z_um / target_um, hcr_xy_um / target_um, hcr_xy_um / target_um)
    cz_ds = zoom(cz_stack, cz_zoom, order=1).astype(np.float32)
    hcr_ds = zoom(hcr_vol, hcr_zoom, order=1).astype(np.float32)

    try:
        r = mi_affine(
            cz_ds, hcr_ds,
            cz_xy_um=target_um, cz_z_um=target_um,
            hcr_xy_um=target_um, hcr_z_um=target_um,
            init_rotation_deg_z=180.0,
            # SITK xyz order — sxy, sxy, sz (sz on the z/third axis)
            init_scale=(1.8, 1.8, 2.8),
            n_iterations=200,
            pyramid_levels=(4, 2, 1),
        )
    except Exception as e:
        return CoregResult(pd.DataFrame(), 0.0, diagnostics={"error": f"mi: {e}"})

    # Convert SITK forward (HCR→CZ) to a CZ→HCR TransformDescriptor.
    # SITK forward: p_cz = A @ (p_hcr - c) + c + t
    # Inverse:       p_hcr = A^-1 @ (p_cz - c - t) + c
    #              = A^-1 @ p_cz + (c - A^-1 @ (c + t))
    # Map to Procrustes form `pred = ((src - src_mean) @ R_) * scales + dst_mean`:
    #   src_mean = c + t    (CZ anchor)
    #   R_       = (A^-1)^T normalized to pure rotation
    #   scales   = singular values of A^-1 (in z,y,x order from SVD of A^-1)
    #   dst_mean = c
    A = np.asarray(r.affine_matrix)
    A_inv = np.linalg.inv(A)
    U, S_vals, Vt = np.linalg.svd(A_inv)
    R_inv = U @ Vt  # proper rotation (det +1 guaranteed if A has det>0)
    # Reconstitute A_inv = R_inv @ diag(S_vals) @ (some V^T U^T) — for anisotropic
    # scale storage we accept some coupling. The downstream consumer applies
    # the composed transform via apply_mi_transform below.
    transform = TransformDescriptor(
        R=R_inv,
        scales=S_vals,
        translation=r.center,             # dst_mean after (src - src_mean) @ R * S
        src_mean=r.center + r.translation,  # CZ anchor
        rotation_deg_z=180.0,
        kind="mi-affine",
    )
    # Sanity: apply_inverse should match apply via TransformDescriptor.
    return CoregResult(
        pairs_df=pd.DataFrame(),
        confidence=max(0.0, min(1.0, 1.0 - abs(r.metric) / 5.0)),
        transform=transform,
        diagnostics=dict(
            metric=r.metric, iterations=r.iterations, converged=r.converged,
            scales=S_vals.tolist(),
            sitk_matrix_zyx=A.tolist(),
            sitk_translation_zyx=r.translation.tolist(),
            sitk_center_zyx=r.center.tolist(),
        ),
    )
