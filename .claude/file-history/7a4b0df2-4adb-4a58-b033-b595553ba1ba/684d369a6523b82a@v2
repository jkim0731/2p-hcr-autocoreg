# --------------------------------------------------------------
# Mutual information (binned)
# --------------------------------------------------------------
def mutual_information(
    a: np.ndarray, b: np.ndarray, mask: np.ndarray, n_bins: int = 32,
) -> float:
    if mask.sum() < 100:
        return -1.0
    av = a[mask].astype(np.float64).ravel()
    bv = b[mask].astype(np.float64).ravel()

    def to_bins(x):
        lo, hi = np.percentile(x, [1, 99])
        if hi <= lo:
            return np.zeros_like(x, dtype=np.int32)
        return np.clip(((x - lo) / (hi - lo) * (n_bins - 1)).astype(np.int32),
                       0, n_bins - 1)

    ai = to_bins(av); bi = to_bins(bv)
    joint = np.zeros((n_bins, n_bins), dtype=np.float64)
    np.add.at(joint, (ai, bi), 1.0)
    joint /= joint.sum()
    pa = joint.sum(axis=1, keepdims=True)
    pb = joint.sum(axis=0, keepdims=True)
    denom = pa @ pb
    nz = (joint > 0) & (denom > 0)
    return float((joint[nz] * np.log(joint[nz] / denom[nz])).sum())


# --------------------------------------------------------------
# Affine refinement with MI as the metric
# --------------------------------------------------------------
def stage2_affine_mi(
    template: np.ndarray, image: np.ndarray,
    M0: np.ndarray, offset0: np.ndarray, n_bins: int = 32,
    min_overlap_frac: float = 0.5,
    scale_bounds: tuple = (0.90, 1.10),
    theta_bounds_deg: float = 10.0,
) -> dict:
    """4-DOF similarity refinement on MI (intensity images)."""
    template_f = template.astype(np.float32)
    image_f = image.astype(np.float32)
    H_im, W_im = image_f.shape
    template_area_target = float((template_f > 1e-6).sum() * min_overlap_frac)
    log_s_lo = np.log(scale_bounds[0])
    log_s_hi = np.log(scale_bounds[1])
    th_lim = np.deg2rad(theta_bounds_deg)

    def warp(p):
        d_th, d_log_s, d_oy, d_ox = p
        s = np.exp(d_log_s)
        Rd = np.array([[np.cos(d_th), -np.sin(d_th)],
                       [np.sin(d_th),  np.cos(d_th)]])
        M = s * (Rd @ M0)
        off = offset0 + np.array([d_oy, d_ox])
        warped = affine_transform(
            template_f, M, offset=off,
            output_shape=(H_im, W_im), order=1, mode="constant", cval=-1.0,
        )
        valid = warped >= 0
        warped = np.where(valid, warped, 0.0)
        return warped, valid, M, off

    def neg_mi(p):
        d_th, d_log_s, _, _ = p
        if not (log_s_lo <= d_log_s <= log_s_hi) or abs(d_th) > th_lim:
            return 1.0
        warped, valid, _, _ = warp(p)
        if (warped > 1e-6).sum() < template_area_target:
            return 1.0
        return -mutual_information(warped, image_f, valid, n_bins=n_bins)

    p0 = np.zeros(4)
    base_mi = -neg_mi(p0)
    res = minimize(neg_mi, p0, method="Powell",
                   options={"xtol": 1e-3, "ftol": 1e-4, "maxiter": 800})
    final_mi = -res.fun
    if final_mi < base_mi:
        p_best, final_mi = p0, base_mi
    else:
        p_best = res.x
    warped, _, M, off = warp(p_best)
    return {"M": M, "offset": off, "mi": float(final_mi), "warped": warped,
            "params": p_best.tolist()}


# --------------------------------------------------------------
# Visualisation
# --------------------------------------------------------------
def stretch01(img, p_lo=1, p_hi=99):
    a = np.asarray(img, dtype=np.float32)
    finite = np.isfinite(a)
    if not finite.any():
        return np.zeros_like(a)
    lo, hi = np.percentile(a[finite], [p_lo, p_hi])
    return np.clip((a - lo) / max(hi - lo, 1e-6), 0, 1)


def render(
    sid, hcr_intensity, cz_intensity_warm, rigid_warp, affine_warp, nonrigid_warp,
    out_path, theta, sxy, hcr_xy_um, scores,
):
    H, W = hcr_intensity.shape
    fig, axes = plt.subplots(2, 4, figsize=(20, 10))
    extent = [0, W * hcr_xy_um, H * hcr_xy_um, 0]

    axes[0, 0].imshow(stretch01(hcr_intensity), cmap="gray", extent=extent, origin="upper")
    axes[0, 0].set_title("HCR ch488 intensity"); axes[0, 0].set_xlabel("x (µm)")
    h, w = cz_intensity_warm.shape
    extent_cz = [0, w * hcr_xy_um, h * hcr_xy_um, 0]
    axes[0, 1].imshow(stretch01(cz_intensity_warm), cmap="gray",
                      extent=extent_cz, origin="upper")
    axes[0, 1].set_title("CZ-in-ROI intensity warm-start")

    keys = ["rigid", "affine_mi", "nonrigid"]
    bin_ncc = [scores[k]["bin_ncc"] for k in keys]
    axes[0, 2].bar(keys, bin_ncc, color=["#7f7", "#cae", "#f97"])
    axes[0, 2].set_title("binary-NCC (re-scored)")
    axes[0, 2].set_ylim(min(0, min(bin_ncc)) - 0.02, max(0.6, max(bin_ncc) * 1.1))
    for i, v in enumerate(bin_ncc):
        axes[0, 2].text(i, v + 0.01, f"{v:.3f}", ha="center")

    mi_vals = [scores[k]["mi"] for k in keys]
    axes[0, 3].bar(keys, mi_vals, color=["#7f7", "#cae", "#f97"])
    axes[0, 3].set_title("intensity MI")
    for i, v in enumerate(mi_vals):
        axes[0, 3].text(i, v + 0.01, f"{v:.3f}", ha="center")

    def overlay(ax, warped, title):
        rgb = np.zeros((H, W, 3), dtype=np.float32)
        rgb[..., 0] = stretch01(hcr_intensity)
        rgb[..., 1] = stretch01(warped)
        ax.imshow(rgb, extent=extent, origin="upper")
        ax.set_title(title); ax.set_xlabel("x (µm)")

    overlay(axes[1, 0], rigid_warp, f"RIGID  θ={theta:+.2f}°  binNCC={scores['rigid']['bin_ncc']:.3f}")
    overlay(axes[1, 1], affine_warp, f"AFFINE-MI  binNCC={scores['affine_mi']['bin_ncc']:.3f}")
    overlay(axes[1, 2], nonrigid_warp, f"NONRIGID  binNCC={scores['nonrigid']['bin_ncc']:.3f}")
    best = max(keys, key=lambda k: scores[k]["bin_ncc"])
    bw = {"rigid": rigid_warp, "affine_mi": affine_warp, "nonrigid": nonrigid_warp}[best]
    overlay(axes[1, 3], bw, f"BEST binNCC: {best}  ({scores[best]['bin_ncc']:.3f})")
    fig.suptitle(f"{sid} — V3 MI registration")
    fig.tight_layout()
    fig.savefig(out_path, dpi=110, bbox_inches="tight")
    plt.close(fig)


# --------------------------------------------------------------
# Driver
# --------------------------------------------------------------
def process_subject(sid: str) -> dict:
    print(f"\n=== {sid} ===", flush=True)
    s = load_subject(sid)
    sxy, sxy_src = get_sxy_with_fallback(sid, s)
    print(f"  sxy={sxy:.4f}  source={sxy_src}", flush=True)

    hcr_surf = get_hcr_top_surface_iter07(s, level=HCR_LEVEL)
    cz_surf = get_cz_surface_iter08(s)

    # Intensity inputs
    hcr_mip_raw, hcr_xy_um = hcr488_top_mip(s, hcr_surf, *HCR_SLAB)
    hcr_intensity = fillnan_for_corr(hcr_mip_raw)
    cz_intensity = fillnan_for_corr(cz_intensity_in_roi_top_mip(s, cz_surf, *CZ_SLAB))
    cz_intensity_warm = warm_start_cz_intensity(
        cz_intensity, cz_xy_um=float(s.cz_xy_um), hcr_xy_um=hcr_xy_um, sxy=sxy,
    )

    # Binary inputs (for warm rigid stage AND for re-scoring)
    hcr_bin = detect_objects_binary(hcr_mip_raw, hcr_xy_um)
    cz_bin = cz_binary_top_mip(s, cz_surf, *CZ_SLAB)
    cz_bin_warm = (
        zoom(
            nd_rotate(cz_bin.astype(np.float32), 180.0, reshape=True, order=0,
                      mode="constant", cval=0.0),
            (float(s.cz_xy_um) * sxy) / hcr_xy_um, order=0,
        ) > 0.5
    ).astype(np.uint8)
    print(f"  HCR ch488 MIP shape={hcr_intensity.shape}  "
          f"binary fill={(hcr_bin>0).mean()*100:.1f}%   "
          f"CZ warm shape={cz_bin_warm.shape}",
          flush=True)

    # Stage 1 — rigid (binary FFT-NCC, lifted from register_binary)
    rigid = stage1_rigid(cz_bin_warm, hcr_bin)
    print(f"  RIGID:    θ={rigid['theta']:+.2f}°  (oy,ox)=({rigid['oy']},{rigid['ox']}) "
          f"binNCC={rigid['ncc']:.3f}", flush=True)

    H_im, W_im = hcr_bin.shape
    H_t, W_t = cz_bin_warm.shape
    th_in = rigid["template_shape"]
    th = np.deg2rad(rigid["theta"])
    c, s_ = np.cos(th), np.sin(th)
    M0 = np.array([[c,  s_], [-s_, c]], dtype=np.float64)
    cy_out = rigid["oy"] + th_in[0] / 2.0
    cx_out = rigid["ox"] + th_in[1] / 2.0
    cy_in = H_t / 2.0; cx_in = W_t / 2.0
    off0 = np.array([cy_in, cx_in]) - M0 @ np.array([cy_out, cx_out])

    # Stage 2 — affine optimised on MI of intensity images
    affine_mi = stage2_affine_mi(cz_intensity_warm, hcr_intensity, M0, off0)
    print(f"  AFFINE-MI: MI={affine_mi['mi']:.3f}", flush=True)

    # Stage 3 — nonrigid on intensity (BSpline)
    nonrigid = stage3_nonrigid(
        cz_intensity_warm, hcr_intensity, affine_mi["M"], affine_mi["offset"],
    )

    # Apply same transforms to BINARY for re-scoring
    def warp_bin(M, off):
        return affine_transform(
            cz_bin_warm.astype(np.float32), M, offset=off,
            output_shape=hcr_bin.shape, order=0, mode="constant", cval=0.0,
        ) > 0.5

    rigid_warp_int = affine_transform(
        cz_intensity_warm, M0, offset=off0,
        output_shape=hcr_intensity.shape, order=1, mode="constant", cval=0.0,
    )
    rigid_warp_bin = warp_bin(M0, off0).astype(np.float32)

    affine_warp_int = affine_mi["warped"]
    affine_warp_bin = warp_bin(affine_mi["M"], affine_mi["offset"]).astype(np.float32)

    nonrigid_warp_int = nonrigid["warped"]
    # We can't easily get a bspline-warped binary without re-running SITK on bin.
    # Approximate: threshold the intensity warp where original binary fully covers.
    nonrigid_warp_bin = (nonrigid_warp_int > nonrigid_warp_int.mean()).astype(np.float32)

    full_mask = np.ones(hcr_bin.shape, dtype=bool)
    scores = {
        "rigid": {
            "mi": mutual_information(rigid_warp_int, hcr_intensity, full_mask),
            "bin_ncc": ncc_overlap(rigid_warp_bin, hcr_bin.astype(np.float32), full_mask),
        },
        "affine_mi": {
            "mi": mutual_information(affine_warp_int, hcr_intensity, full_mask),
            "bin_ncc": ncc_overlap(affine_warp_bin, hcr_bin.astype(np.float32), full_mask),
        },
        "nonrigid": {
            "mi": mutual_information(nonrigid_warp_int, hcr_intensity, full_mask),
            "bin_ncc": ncc_overlap(nonrigid_warp_bin, hcr_bin.astype(np.float32), full_mask),
        },
    }
    print(
        f"  RE-SCORED  rigid binNCC={scores['rigid']['bin_ncc']:.3f}   "
        f"affine_mi binNCC={scores['affine_mi']['bin_ncc']:.3f}   "
        f"nonrigid binNCC={scores['nonrigid']['bin_ncc']:.3f}",
        flush=True,
    )

    out_png = FIG / f"register_mi_{sid}_V3.png"
    render(sid, hcr_intensity, cz_intensity_warm, rigid_warp_int, affine_warp_int,
           nonrigid_warp_int, out_png, rigid["theta"], sxy, hcr_xy_um, scores)

    out = {
        "sid": sid, "sxy": sxy, "hcr_xy_um": hcr_xy_um,
        "rigid": {"theta_deg": rigid["theta"], "oy": rigid["oy"], "ox": rigid["ox"],
                  "bin_ncc": scores["rigid"]["bin_ncc"], "mi": scores["rigid"]["mi"]},
        "affine_mi": {"bin_ncc": scores["affine_mi"]["bin_ncc"],
                      "mi": scores["affine_mi"]["mi"],
                      "M": affine_mi["M"].tolist(),
                      "offset": affine_mi["offset"].tolist()},
        "nonrigid": {"bin_ncc": scores["nonrigid"]["bin_ncc"],
                     "mi": scores["nonrigid"]["mi"],
                     "ok": bool(nonrigid.get("ok"))},
        "wrote": str(out_png.relative_to(HERE)),
    }
    return out


def main():
    all_results = {}
    for sid in SUBJECTS:
        try:
            all_results[sid] = process_subject(sid)
        except Exception as e:
            print(f"  ERROR {sid}: {type(e).__name__}: {e}", flush=True)
            all_results[sid] = {"sid": sid, "error": str(e)}
    summary = HERE / "register_mi_summary.json"
    summary.write_text(json.dumps(all_results, indent=2, default=float))
    print(f"\nwrote {summary.name}")


if __name__ == "__main__":
    main()
