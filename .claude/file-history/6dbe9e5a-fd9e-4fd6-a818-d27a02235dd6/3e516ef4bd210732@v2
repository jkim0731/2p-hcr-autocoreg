"""Test per-channel and subset combinations on 755252.

Hypothesis: AF may be channel-selective. 405 (DAPI-adjacent) often carries
strong tissue AF. Excluding 405 from the combined volume might leave pia
as the dominant bright band and push the surface deeper.

Also tries single channels to see if any one sees the pia cleanly.
"""
from __future__ import annotations
import sys, importlib.util, os
from pathlib import Path
import numpy as np
