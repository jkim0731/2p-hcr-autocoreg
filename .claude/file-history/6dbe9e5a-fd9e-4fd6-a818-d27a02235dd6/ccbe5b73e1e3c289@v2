"""Test z-axis Gaussian smoothing before top detection.

Hypothesis: autofluorescence bands above pia are thin (20-50µm); pia
signal is thick (100+µm). Smoothing along z with sigma ~ 15-30µm
should reduce peak of thin AF bands while preserving thick pia.

We patch `_per_column_top_in_band` via a temporary wrapper that
gaussian-smooths vol_sub before passing to the original function.
"""
from __future__ import annotations
import sys, importlib.util, os
from pathlib import Path
import numpy as np
from scipy.ndimage import gaussian_filter1d
os.environ["PYTHONUNBUFFERED"] = "1"

