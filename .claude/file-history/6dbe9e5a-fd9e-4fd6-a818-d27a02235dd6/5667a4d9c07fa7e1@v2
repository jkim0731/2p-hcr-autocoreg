def detect_3d_peaks(vol, z_um, xy_um, *,
                    smooth_um=5.0, nbh_um=8.0,
                    intensity_q=0.98,
                    min_neighbors=3, density_radius_um=30.0):
    """Return (N, 3) pseudo-centroids in (x, y, z) µm."""
    sz = max(1, int(round(smooth_um / z_um)))
    sxy = max(1, int(round(smooth_um / xy_um)))
    smoothed = gaussian_filter(vol.astype(np.float32), (sz, sxy, sxy))
    nz = max(1, int(round(nbh_um / z_um)))
    nxy = max(1, int(round(nbh_um / xy_um)))
    nb_size = (2 * nz + 1, 2 * nxy + 1, 2 * nxy + 1)
    local_max = maximum_filter(smoothed, size=nb_size)
    is_peak = (smoothed == local_max) & (smoothed > 0)
    thr = float(np.quantile(smoothed[smoothed > 0], intensity_q))
    is_peak &= smoothed >= thr
    zi, yi, xi = np.where(is_peak)
    if len(zi) == 0:
        return np.empty((0, 3))
    pts = np.column_stack([
        xi * xy_um, yi * xy_um, zi * z_um,
    ])
    tree = cKDTree(pts)
    counts = tree.query_ball_point(pts, r=float(density_radius_um),
                                   return_length=True)
    keep = np.asarray(counts) >= (int(min_neighbors) + 1)
    return pts[keep]


def sz(surf, x, y):
    return (surf["a"]*x + surf["b"]*y + surf["c"] +
            surf.get("p",0)*x*x + surf.get("q",0)*x*y + surf.get("r",0)*y*y)


def eval_surf(surf, pts):
    z_surf = sz(surf, pts[:,0], pts[:,1])
    depth = pts[:,2] - z_surf
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        halfmax = 0.5 * bulk
        for c, d in zip(centers, density):
            if c >= 0 and d >= halfmax:
                onset = float(c); break
    return above, onset


def clamp_to_pseudo_centroids(surface, peaks_xyz, *, tile_um=120.0,
                              within_tile_q=0.10, safety_offset_um=3.0,
                              min_per_tile=5):
    """Same math as N22's _clamp_to_roi_envelope — fed by image peaks."""
    if len(peaks_xyz) < 50:
        return surface, 0.0, 0
    px, py, pz = peaks_xyz[:, 0], peaks_xyz[:, 1], peaks_xyz[:, 2]
    xb = (px // tile_um).astype(int)
    yb = (py // tile_um).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": px, "y": py, "z": pz})
    q_within = float(within_tile_q)
    agg = df.groupby("k").agg(
        x=("x", "median"), y=("y", "median"),
        z=("z", lambda v: float(np.quantile(v, q_within))),
        n=("z", "size"))
    agg = agg[agg["n"] >= int(min_per_tile)]
    if agg.empty:
        return surface, 0.0, 0
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    plane_z = (surface["a"] * tx + surface["b"] * ty + surface["c"]
               + surface.get("p", 0) * tx * tx
               + surface.get("q", 0) * tx * ty
               + surface.get("r", 0) * ty * ty)
    deficit = plane_z - tz
    pos = deficit[deficit > 0]
    lift = float(pos.max()) if len(pos) else 0.0
    out = dict(surface)
    out["c"] = float(out["c"] - lift - safety_offset_um)
    return out, lift, int(len(agg))


for sid in ["755252", "767018", "767022", "782149", "788406", "790322"]:
    s = load_subject(sid)
    vol, xy_um, z_um, channels = load_hcr_combined(s, level=4)
    hcr_centroids = s.hcr_centroids[["z_px","y_px","x_px"]].values
    pts = hcr_px_to_um(hcr_centroids, s)[:, [2,1,0]]
    print(f"--- {sid} ---  vol shape {vol.shape} z_um={z_um:.2f} xy_um={xy_um:.2f}")

    peaks = detect_3d_peaks(vol, z_um, xy_um,
                            smooth_um=5.0, nbh_um=8.0,
                            intensity_q=0.98,
                            min_neighbors=3, density_radius_um=30.0)
    n_peaks = len(peaks)
    n_cells = len(pts)
    print(f"  peaks={n_peaks}  real_cells={n_cells}")
    if n_peaks < 100:
        print("  skip (too few peaks)")
        continue

    res = _mod.estimate_surface_and_l2_image_based(
        vol, z_um, xy_um,
        target_quantile=0.70,
        column_margin=0.25,
        band_um=150.0,
        clamp_min_per_tile=100000,  # disable internal clamp
    )
    if res.surface is None:
        print("  no surface")
        continue

    # Pre-peak-clamp evaluation
    above0, onset0 = eval_surf(res.surface, pts)
    print(f"  pre-clamp:        c={res.surface['c']:6.1f} above={above0:.4f} onset={onset0:.1f}")

    for wtq in [0.02, 0.10, 0.20]:
        surf2, lift, n_tiles = clamp_to_pseudo_centroids(
            res.surface, peaks, tile_um=120.0, within_tile_q=wtq,
            safety_offset_um=3.0, min_per_tile=5)
        a, o = eval_surf(surf2, pts)
        print(f"  peak-clamp wtq={wtq:.2f}: c={surf2['c']:6.1f} lift={lift:6.1f} "
              f"n_tiles={n_tiles:3d} above={a:.4f} onset={o:.1f}")
