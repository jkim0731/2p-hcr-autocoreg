def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


def mad_clamp(surface, xs, ys, zs, *, tile_um=120.0, within_tile_q=0.10,
              mad_k=3.0, safety_offset_um=3.0, min_per_tile=5, residual_space=True):
    """Two modes:
    - residual_space=True: compute per-tile DEFICIT (plane_z - tile_z), then
      MAD-reject extreme deficits, take max of remaining.
    - residual_space=False: MAD-filter tile_z values directly to reject
      autofluorescence-contaminated tiles (anomalously shallow), then take
      max deficit over surviving tiles.
    """
    xb = (xs // tile_um).astype(int)
    yb = (ys // tile_um).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": xs, "y": ys, "z": zs})
    agg = df.groupby("k").agg(
        x=("x", "median"), y=("y", "median"),
        z=("z", lambda v: float(np.quantile(v, within_tile_q))),
        n=("z", "size"))
    agg = agg[agg["n"] >= int(min_per_tile)]
    if agg.empty:
        return surface, 0.0, 0, 0
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    plane_z = sz(surface, tx, ty)
    deficit = plane_z - tz
    n_total = len(agg)

    if residual_space:
        pos = deficit[deficit > 0]
        if len(pos) == 0:
            return surface, 0.0, n_total, 0
        m = float(np.median(pos))
        mad = float(1.4826 * np.median(np.abs(pos - m)))
        if mad < 1e-6:
            lift = float(pos.max())
            n_kept = len(pos)
        else:
            keep = pos <= m + mad_k * mad
            n_kept = int(keep.sum())
            lift = float(pos[keep].max()) if n_kept > 0 else 0.0
    else:
        # Filter tz directly: reject tiles whose z is anomalously LOW
        m = float(np.median(tz))
        mad = float(1.4826 * np.median(np.abs(tz - m)))
        if mad < 1e-6:
            keep = np.ones_like(tz, bool)
        else:
            keep = tz >= m - mad_k * mad
        tz_kept = tz[keep]
        plane_kept = plane_z[keep]
        deficit_kept = plane_kept - tz_kept
        pos = deficit_kept[deficit_kept > 0]
        n_kept = int(keep.sum())
        lift = float(pos.max()) if len(pos) > 0 else 0.0

    out = dict(surface)
    out["c"] = float(out["c"] - lift - safety_offset_um)
    return out, lift, n_total, n_kept


