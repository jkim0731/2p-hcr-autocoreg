"""Test deep-quantile anchor: fit anchor plane only on tops where z >= pctile.

Hypothesis: for AF-contaminated subjects (755252), the median of tops is
pulled shallow by AF. Fitting the anchor plane only on the DEEPER HALF
(z >= p50) bypasses AF and gets anchor near real pia. For clean subjects,
this pushes anchor deeper but band_um=150 is wide enough to still cover pia.
"""
from __future__ import annotations
import sys, importlib.util, os
from pathlib import Path
import numpy as np
