"""4-class ROI-quality histograms on GT-matched vs all HCR cells.

For each of the 6 benchmark subjects, plot 1x4 panel of P(good), P(bad_ok),
P(merged), P(bad) histograms (all HCR gray + GT-matched blue, twinx).
Also bar-chart the argmax class label distribution for matched vs all.

Output: figures/roi_quality_4class/{sid}_proba.png  (4 panels)
        figures/roi_quality_4class/{sid}_argmax.png (bar chart)
        results_roi_quality_4class.json
"""
from __future__ import annotations
import json
import sys
from pathlib import Path

import matplotlib.pyplot as plt
import numpy as np
import pandas as pd

DEV = Path("/root/capsule/code/dev_code")
SESSION = Path("/root/capsule/code/sessions/13_pairwise_unmix_gfp")
FIGDIR = SESSION / "figures" / "roi_quality_4class"
FIGDIR.mkdir(parents=True, exist_ok=True)
if str(DEV) not in sys.path:
    sys.path.insert(0, str(DEV))

from benchmark_data_loader import load_subject  # noqa: E402

ARCHIVE = Path("/root/capsule/data/claude-data_ophys-mfish-autocoreg_260503")
SCORE_DIR = ARCHIVE / "cached_data" / "cached_roi_quality"
SUBJECTS = ["755252", "767018", "767022", "782149", "788406", "790322"]
CLASSES = ["p_good", "p_bad_ok", "p_merged", "p_bad"]
CLASS_LABELS = {"p_good": "good", "p_bad_ok": "bad_ok",
                "p_merged": "merged", "p_bad": "bad"}
CLASS_COLOURS = {"good": "#2aa198", "bad_ok": "#b58900",
                 "merged": "#cb4b16", "bad": "#dc322f"}


def analyze(sid: str) -> dict:
    s = load_subject(sid)
    matched_ids = set(int(x) for x in s.coreg_table["hcr_id"].values)
    fourcl = pd.read_parquet(SCORE_DIR / f"{sid}_stage2_4class_proba_v5d.parquet")
    fourcl["is_matched"] = fourcl["hcr_id"].astype(int).isin(matched_ids)

    cls_arr = fourcl[CLASSES].to_numpy(float)
    arg = np.argmax(cls_arr, axis=1)
    argmax_label = np.array([CLASSES[i] for i in arg])
    fourcl["argmax"] = argmax_label

    # 1x4 proba panels
    fig, axes = plt.subplots(1, 4, figsize=(20, 4.4))
    bins = np.linspace(0, 1, 50)
    matched_df = fourcl[fourcl["is_matched"]]
    for ax, col in zip(axes, CLASSES):
        all_v = fourcl[col].dropna().to_numpy()
        m_v = matched_df[col].dropna().to_numpy()
        ax.hist(all_v, bins=bins, color="#94a3b8", alpha=0.7,
                label=f"all HCR (n={len(all_v)})")
        ax2 = ax.twinx()
        ax2.hist(m_v, bins=bins, color="#3b7dd8", alpha=0.55,
                 label=f"matched (n={len(m_v)})")
        ax.set_xlabel(f"P({CLASS_LABELS[col]})")
        ax.set_ylabel("count (all HCR)")
        ax2.set_ylabel("count (matched)", color="#3b7dd8")
        ax2.tick_params(axis='y', colors="#3b7dd8")
        ax.set_title(
            f"{CLASS_LABELS[col]}  all-med={np.median(all_v):.3f}  "
            f"matched-med={np.median(m_v):.3f}"
        )
        h1, l1 = ax.get_legend_handles_labels()
        h2, l2 = ax2.get_legend_handles_labels()
        ax.legend(h1 + h2, l1 + l2, loc="upper center", fontsize=8)
        ax.grid(True, alpha=0.3)
    fig.suptitle(f"{sid}: 4-class ROI-quality probabilities — matched vs all HCR",
                 y=1.02)
    fig.tight_layout()
    fig.savefig(FIGDIR / f"{sid}_proba.png", dpi=130, bbox_inches="tight")
    plt.close(fig)

    # Argmax bar chart (fraction in each class)
    classes_short = [CLASS_LABELS[c] for c in CLASSES]
    all_frac = [
        float((argmax_label == c).mean()) for c in CLASSES
    ]
    m_argmax = matched_df["argmax"].to_numpy()
    matched_frac = [
        float((m_argmax == c).mean()) for c in CLASSES
    ]
    fig, ax = plt.subplots(1, 1, figsize=(8, 4.4))
    x = np.arange(len(classes_short))
    w = 0.38
    bars1 = ax.bar(x - w/2, all_frac, w, color="#94a3b8",
                   label=f"all HCR (n={len(fourcl)})")
    bars2 = ax.bar(x + w/2, matched_frac, w, color="#3b7dd8",
                   label=f"matched (n={len(matched_df)})")
    for bar, frac in zip(bars1, all_frac):
        ax.text(bar.get_x() + bar.get_width()/2, frac + 0.01,
                f"{100*frac:.1f}%", ha="center", fontsize=8)
    for bar, frac in zip(bars2, matched_frac):
        ax.text(bar.get_x() + bar.get_width()/2, frac + 0.01,
                f"{100*frac:.1f}%", ha="center", fontsize=8,
                color="#3b7dd8")
    ax.set_xticks(x); ax.set_xticklabels(classes_short)
    ax.set_ylabel("fraction (argmax class)")
    ax.set_title(f"{sid}: predicted class distribution — matched vs all HCR")
    ax.legend(fontsize=8)
    ax.grid(True, alpha=0.3, axis="y")
    fig.tight_layout()
    fig.savefig(FIGDIR / f"{sid}_argmax.png", dpi=130, bbox_inches="tight")
    plt.close(fig)

    return {
        "subject": sid,
        "n_total": int(len(fourcl)),
        "n_matched": int(matched_df.shape[0]),
        "argmax_frac_all": dict(zip(classes_short, all_frac)),
        "argmax_frac_matched": dict(zip(classes_short, matched_frac)),
        "mean_proba_all": {
            CLASS_LABELS[c]: float(fourcl[c].mean()) for c in CLASSES
        },
        "mean_proba_matched": {
            CLASS_LABELS[c]: float(matched_df[c].mean()) for c in CLASSES
        },
    }


def main():
    out = {}
    print("subject  n_match | argmax fractions (matched | all):")
    print(f"{'sid':>7s}  {'n':>5s} | {'good_m':>7s} {'bok_m':>7s} {'mrg_m':>7s} {'bad_m':>7s}  ||  "
          f"{'good_a':>7s} {'bok_a':>7s} {'mrg_a':>7s} {'bad_a':>7s}")
    for sid in SUBJECTS:
        try:
            r = analyze(sid)
        except Exception as e:
            print(f"  {sid} ERROR: {type(e).__name__}: {e}")
            out[sid] = {"subject": sid, "error": str(e)}
            continue
        out[sid] = r
        am = r["argmax_frac_matched"]; aa = r["argmax_frac_all"]
        print(
            f"{sid:>7s}  {r['n_matched']:5d} | "
            f"{100*am['good']:6.1f}% {100*am['bad_ok']:6.1f}% "
            f"{100*am['merged']:6.1f}% {100*am['bad']:6.1f}%  ||  "
            f"{100*aa['good']:6.1f}% {100*aa['bad_ok']:6.1f}% "
            f"{100*aa['merged']:6.1f}% {100*aa['bad']:6.1f}%"
        )
    with open(SESSION / "results_roi_quality_4class.json", "w") as f:
        json.dump(out, f, indent=2)


if __name__ == "__main__":
    main()
