    "argmax_rows = []\n",
    "for sid, df in frames.items():\n",
    "    miss = df.loc[~df[\"in_unmixed\"]]\n",
    "    n_miss = len(miss)\n",
    "    row = {\"subject\": sid, \"n_missed\": n_miss,\n",
    "           \"score_p25\": round(float(miss[\"score\"].quantile(0.25)), 3) if n_miss else float(\"nan\"),\n",
    "           \"score_med\": round(float(miss[\"score\"].median()), 3) if n_miss else float(\"nan\"),\n",
    "           \"score_p75\": round(float(miss[\"score\"].quantile(0.75)), 3) if n_miss else float(\"nan\"),\n",
    "           \"score>=0.5_%\": round(100 * float((miss[\"score\"] >= 0.5).mean()), 1) if n_miss else float(\"nan\"),\n",
    "           \"argmax_pos_%\": round(100 * float(miss[\"argmax\"].isin([\"good\", \"bad_ok\"]).mean()), 1) if n_miss else float(\"nan\"),\n",
