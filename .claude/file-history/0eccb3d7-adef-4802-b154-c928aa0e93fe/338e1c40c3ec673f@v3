   "source": [
    "from __future__ import annotations\n",
    "import sys\n",
    "from glob import glob\n",
    "from pathlib import Path\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "DEV = Path(\"/root/capsule/code/dev_code\")\n",
    "SESSION = Path(\"/root/capsule/code/sessions/13_pairwise_unmix_gfp\")\n",
    "SCORE_DIR = DEV / \"cached_roi_quality\"  # retrained v5d outputs\n",
    "if str(DEV) not in sys.path:\n",
    "    sys.path.insert(0, str(DEV))\n",
    "from benchmark_data_loader import load_subject\n",
    "\n",
    "UNMIX_GLOB = (\"/root/capsule/data/HCR_{sid}_pairwise-unmixing_*/\"\n",
    "              \"pairwise_unmixing/all_cells_unmixed/unmixed_all_cells.csv\")\n",
    "\n",
    "SUBJECTS = [\"755252\", \"767022\", \"782149\", \"788406\", \"790322\"]\n",
    "CLASSES = [\"p_good\", \"p_bad_ok\", \"p_merged\", \"p_bad\"]\n",
    "CLASS_LABEL = {\"p_good\": \"good\", \"p_bad_ok\": \"bad_ok\",\n",
    "               \"p_merged\": \"merged\", \"p_bad\": \"bad\"}\n",
    "\n",
    "def collect(sid: str) -> pd.DataFrame:\n",
    "    s = load_subject(sid)\n",
    "    matched = (s.coreg_table[[\"hcr_id\"]]\n",
    "               .astype({\"hcr_id\": int})\n",
    "               .drop_duplicates())\n",
    "    cent = (s.hcr_centroids[[\"hcr_id\", \"z_px\", \"y_px\", \"x_px\"]]\n",
    "            .astype({\"hcr_id\": int}))\n",
    "    binary = pd.read_parquet(SCORE_DIR / f\"{sid}_stage2_binary_score_v5d.parquet\")\n",
    "    fourcl = pd.read_parquet(SCORE_DIR / f\"{sid}_stage2_4class_proba_v5d.parquet\")\n",
    "    matches = glob(UNMIX_GLOB.format(sid=sid))\n",
    "    if not matches:\n",
    "        raise FileNotFoundError(f\"no unmixed CSV for {sid}\")\n",
    "    unmixed = set(int(x) for x in pd.read_csv(matches[0])[\"cell_id\"].astype(int).values)\n",
    "\n",
    "    df = (matched\n",
    "          .merge(cent, on=\"hcr_id\", how=\"left\")\n",
    "          .merge(binary[[\"hcr_id\", \"score\"]], on=\"hcr_id\", how=\"left\")\n",
    "          .merge(fourcl[[\"hcr_id\"] + CLASSES], on=\"hcr_id\", how=\"left\"))\n",
    "    df[\"sid\"] = sid\n",
    "    df[\"in_unmixed\"] = df[\"hcr_id\"].isin(unmixed)\n",
    "    arr = df[CLASSES].to_numpy(float)\n",
    "    df[\"argmax\"] = [CLASS_LABEL[CLASSES[i]] for i in np.argmax(arr, axis=1)]\n",
    "    df[\"argmax_p\"] = arr[np.arange(len(df)), np.argmax(arr, axis=1)]\n",
    "    return df\n",
    "\n",
    "frames = {sid: collect(sid) for sid in SUBJECTS}\n",
    "print({sid: (df.shape[0], int((~df[\"in_unmixed\"]).sum())) for sid, df in frames.items()})"
   ]
  },
