def render_subject(sid, results: dict, hcr_xy_um: float, sxy: float,
                   out_path: Path):
    fig, axes = plt.subplots(2, 5, figsize=(22, 10))

    for r, tk in enumerate(TARGET_KEYS):
        res = results[tk]
        hcr_bin = res["hcr_bin_crop"]
        H, W = hcr_bin.shape
        extent = [0, W * hcr_xy_um, H * hcr_xy_um, 0]

        ax = axes[r, 0]
        rgb = np.zeros((H, W, 3), dtype=np.float32)
        rgb[..., 0] = (hcr_bin > 0.5).astype(np.float32)
        ax.imshow(rgb, extent=extent, origin="upper")
        ax.set_title(f"{tk} target  (crop {H}×{W})")
        ax.set_ylabel(f"{tk}\n", fontsize=11)

        for c, mk in enumerate(METHOD_KEYS, start=1):
            warped = res[mk]["warp"]
            wb = (np.asarray(warped, dtype=np.float32) > WARP_BIN_THR).astype(np.float32)
            rgb = np.zeros((H, W, 3), dtype=np.float32)
            rgb[..., 0] = (hcr_bin > 0.5).astype(np.float32)
            rgb[..., 1] = wb
            ax = axes[r, c]
            ax.imshow(rgb, extent=extent, origin="upper")
            ncc = res[mk]["ncc"]
            ax.set_title(f"{METHOD_LABELS[mk]}\nNCC={ncc:.3f}")
            ax.set_xlabel("x (µm)")
            if r == 1:
                ax.set_xlabel("x (µm)")

    fig.suptitle(f"{sid} — 4 methods × 2 HCR targets  (sxy={sxy:.3f})",
                 fontsize=14)
    fig.tight_layout()
    fig.savefig(out_path, dpi=110, bbox_inches="tight")
    plt.close(fig)


def render_summary(all_results: dict, out_path: Path):
    sids = [sid for sid in SUBJECTS if sid in all_results
            and "error" not in all_results[sid]]
    fig, axes = plt.subplots(1, 2, figsize=(18, 5.5), sharey=True)
    width = 0.20
    x = np.arange(len(sids))
    colors = ["#4472C4", "#ED7D31", "#A5A5A5", "#FFC000"]

    for ti, tk in enumerate(TARGET_KEYS):
        ax = axes[ti]
        for i, mk in enumerate(METHOD_KEYS):
            ys = [all_results[sid][tk][mk]["ncc"] for sid in sids]
            ax.bar(x + i * width, ys, width, label=METHOD_LABELS[mk],
                   color=colors[i])
        # Annotate the per-subject best method
        for j, sid in enumerate(sids):
            scores = {mk: all_results[sid][tk][mk]["ncc"] for mk in METHOD_KEYS}
            best = max(scores, key=scores.get)
            yb = scores[best]
            i_best = METHOD_KEYS.index(best)
            ax.text(j + i_best * width, yb + 0.005, "★",
                    ha="center", fontsize=14, color="black")
        ax.set_xticks(x + 1.5 * width)
        ax.set_xticklabels(sids)
        ax.set_title(f"target = {tk}")
        ax.grid(True, alpha=0.3, axis="y")
        if ti == 0:
            ax.set_ylabel("binary NCC vs HCR target (M1-bbox crop)")
        ax.legend(loc="upper left", fontsize=9)

    fig.suptitle("4-method comparison × 2 HCR targets (★ = per-subject best)",
                 fontsize=13)
    fig.tight_layout()
    fig.savefig(out_path, dpi=120, bbox_inches="tight")
    plt.close(fig)


# --------------------------------------------------------------
# Driver
# --------------------------------------------------------------
def process_subject(sid: str) -> dict:
    print(f"\n=== {sid} ===", flush=True)
    s = load_subject(sid)
    sxy, sxy_src = get_sxy_with_fallback(sid, s)
    print(f"  sxy={sxy:.4f}  src={sxy_src}", flush=True)

    hcr_surf = get_hcr_top_surface_iter07(s, level=HCR_LEVEL)
    cz_surf = get_cz_surface_iter08(s)

    hcr_488_full, hcr_xy_um = hcr488_top_mip(s, hcr_surf, *HCR_SLAB)
    target_a = variant_watershed(hcr_488_full, hcr_xy_um)
    target_b = hcr_gfp_roi_mask(s, hcr_surf, hcr_xy_um, hcr_488_full.shape)
    n_gfp = int(s.hcr_gfp_df["hcr_id"].nunique()) if not s.hcr_gfp_df.empty else 0
    print(f"  HCR full {target_a.shape}; "
          f"ws488 fill={target_a.mean()*100:.1f}%, "
          f"gfp_roi fill={target_b.mean()*100:.1f}%, "
          f"GFP+ total ids={n_gfp}", flush=True)

    cz_bin = cz_binary_top_mip(s, cz_surf, *CZ_SLAB)
    cz_bin_warm = warm_start_cz_binary(
        cz_bin, cz_xy_um=float(s.cz_xy_um), hcr_xy_um=hcr_xy_um, sxy=sxy,
    )

    results = {}
    for tk, target in [("ws488", target_a), ("gfp_roi", target_b)]:
        print(f"  --- target = {tk} ---", flush=True)
        res = run_methods_for_target(cz_bin_warm, target)
        for mk in METHOD_KEYS:
            v = res[mk]
            extra = ""
            if "df_max_dy_px" in v:
                extra = f"  df_max=({v['df_max_dy_px']:.1f},{v['df_max_dx_px']:.1f})px"
            print(f"    {METHOD_LABELS[mk]:18s} bin-NCC={v['ncc']:.3f}{extra}",
                  flush=True)
        best = max(METHOD_KEYS, key=lambda k: res[k]["ncc"])
        print(f"    best = {METHOD_LABELS[best]} ({res[best]['ncc']:.3f})", flush=True)
        results[tk] = res

    out_png = FIG / f"compare_methods_final_{sid}.png"
    render_subject(sid, results, hcr_xy_um, sxy, out_png)

    summary = {"sid": sid, "sxy": sxy, "sxy_source": sxy_src,
               "hcr_xy_um": hcr_xy_um}
    for tk in TARGET_KEYS:
        r = results[tk]
        summary[tk] = {"crop_bbox": list(r["crop_bbox"])}
        for mk in METHOD_KEYS:
            summary[tk][mk] = {kk: vv for kk, vv in r[mk].items() if kk != "warp"}
        summary[tk]["best"] = max(METHOD_KEYS, key=lambda k: r[k]["ncc"])
        summary[tk]["best_ncc"] = float(r[summary[tk]["best"]]["ncc"])
    summary["wrote"] = str(out_png.relative_to(HERE))
    return summary


def main():
    all_results = {}
    for sid in SUBJECTS:
        try:
            all_results[sid] = process_subject(sid)
        except Exception as e:
            print(f"  ERROR {sid}: {type(e).__name__}: {e}", flush=True)
            import traceback; traceback.print_exc()
            all_results[sid] = {"sid": sid, "error": str(e)}

    out_json = HERE / "compare_methods_final_summary.json"
    out_json.write_text(json.dumps(all_results, indent=2, default=float))
    print(f"\nwrote {out_json.name}")
    out_png = FIG / "compare_methods_final_summary.png"
    render_summary(all_results, out_png)
    print(f"wrote {out_png.name}")

    # Text tables — one per target
    for tk in TARGET_KEYS:
        print(f"\nbinary NCC table — target = {tk}")
        print(f"{'sid':<8}" + "".join(f"{m:>14}" for m in METHOD_KEYS) +
              "    best")
        for sid in SUBJECTS:
            r = all_results.get(sid, {})
            if "error" in r:
                print(f"{sid:<8}  ERROR"); continue
            row = "".join(f"  {r[tk][m]['ncc']:12.3f}" for m in METHOD_KEYS)
            best = r[tk]["best"]
            print(f"{sid:<8}{row}    {METHOD_LABELS[best]} "
                  f"({r[tk]['best_ncc']:.3f})")


if __name__ == "__main__":
    main()
