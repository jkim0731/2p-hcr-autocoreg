# --------------------------------------------------------------
# HCR GFP+ ROI mask on level-4 MIP grid
# --------------------------------------------------------------
def hcr_gfp_roi_mask(s, hcr_surf, hcr_xy_um: float, mip_shape: tuple,
                    d_lo: float = HCR_SLAB[0], d_hi: float = HCR_SLAB[1],
                    radius_min_um: float = 4.0,
                    radius_max_um: float = 9.0) -> np.ndarray:
    """Binary mask of GFP+ HCR ROIs (one disk per cell) on the level-4
    MIP grid. The per-cell disk radius is derived from the segmentation
    `volume` field (level-0 voxels → µm³ → equivalent-sphere radius),
    clipped to ``[radius_min_um, radius_max_um]`` so the ROIs reflect
    cell-body size while clipping over-large ROIs that include
    processes."""
    H, W = mip_shape
    mask = np.zeros((H, W), dtype=np.uint8)
    if s.hcr_centroids.empty or s.hcr_gfp_df.empty:
        return mask

    cents = s.hcr_centroids.copy()
    cents["hcr_id"] = cents["hcr_id"].astype(int)
    gfp = s.hcr_gfp_df.copy()
    # Different builds use either 'volume' or 'count' for the
    # ROI voxel count (level-0). Pick whichever exists.
    if "volume" in gfp.columns:
        vol_col = "volume"
    elif "count" in gfp.columns:
        vol_col = "count"
    else:
        vol_col = None  # fall back to fixed-radius disks
    keep_cols = ["hcr_id"] + ([vol_col] if vol_col else [])
    gfp = gfp[keep_cols].copy()
    gfp["hcr_id"] = gfp["hcr_id"].astype(int)
    merged = cents.merge(gfp, on="hcr_id", how="inner")
    if merged.empty:
        return mask

    px = merged[["z_px", "y_px", "x_px"]].to_numpy(float)
    zyx_um = hcr_px_to_um(px, s)
    xyz_um = zyx_um[:, [2, 1, 0]]
    depth = depth_from_surface(xyz_um, hcr_surf)
    keep = (depth >= d_lo) & (depth <= d_hi)
    if not keep.any():
        return mask

    yy_um = zyx_um[keep, 1]
    xx_um = zyx_um[keep, 2]

    if vol_col is not None:
        vol_l0 = merged.loc[keep, vol_col].to_numpy(float)
        # level-0 voxel size: xy_um at level-0 = s.hcr_xy_um / 4
        xy_um_l0 = s.hcr_xy_um / 4.0
        z_um_l0 = float(s.hcr_z_um)
        vol_um3 = vol_l0 * (xy_um_l0 ** 2) * z_um_l0
        radii_um = np.cbrt(3.0 * vol_um3 / (4.0 * np.pi))
        radii_um = np.clip(radii_um, radius_min_um, radius_max_um)
    else:
        # Fallback to a fixed mid-range cell-body radius
        radii_um = np.full(int(keep.sum()),
                           0.5 * (radius_min_um + radius_max_um),
                           dtype=np.float32)

    yy_px = np.round(yy_um / hcr_xy_um).astype(int)
    xx_px = np.round(xx_um / hcr_xy_um).astype(int)
    radii_px = np.maximum(1, np.round(radii_um / hcr_xy_um).astype(int))

    for yc, xc, rp in zip(yy_px, xx_px, radii_px):
        if not (0 <= yc < H and 0 <= xc < W):
            continue
        y_lo = max(0, yc - rp); y_hi = min(H, yc + rp + 1)
        x_lo = max(0, xc - rp); x_hi = min(W, xc + rp + 1)
        yy, xx = np.ogrid[y_lo - yc:y_hi - yc, x_lo - xc:x_hi - xc]
        disk = (yy * yy + xx * xx) <= rp * rp
        mask[y_lo:y_hi, x_lo:x_hi] |= disk.astype(np.uint8)
    return mask


# --------------------------------------------------------------
# NCC + helpers
# --------------------------------------------------------------
def ncc_binary(warped: np.ndarray, hcr_bin: np.ndarray,
               mask: np.ndarray | None = None) -> float:
    a = (np.asarray(warped, dtype=np.float32) > WARP_BIN_THR).astype(np.float64)
    b = (np.asarray(hcr_bin) > 0.5).astype(np.float64)
    if mask is None:
        mask = np.ones(b.shape, dtype=bool)
    if mask.sum() < 50:
        return -1.0
    av = a[mask]; bv = b[mask]
    av = av - av.mean(); bv = bv - bv.mean()
    den = av.std() * bv.std()
    if den <= 1e-12:
        return -1.0
    return float((av * bv).mean() / den)


def _rigid_to_M_off(rigid: dict, template_shape, template_shape_rot) -> tuple:
    th = np.deg2rad(rigid["theta"])
    c, s = np.cos(th), np.sin(th)
    M0 = np.array([[c, s], [-s, c]], dtype=np.float64)
    H_t, W_t = template_shape
    rh, rw = template_shape_rot
    cy_out = rigid["oy"] + rh / 2.0
    cx_out = rigid["ox"] + rw / 2.0
    cy_in = H_t / 2.0; cx_in = W_t / 2.0
    off0 = np.array([cy_in, cx_in]) - M0 @ np.array([cy_out, cx_out])
    return M0, off0


def _bbox_with_margin(mask_bool: np.ndarray, margin_frac: float, shape):
    H, W = shape
    if not mask_bool.any():
        return 0, H, 0, W
    rows = np.any(mask_bool, axis=1)
    cols = np.any(mask_bool, axis=0)
    y0, y1 = int(np.where(rows)[0][0]), int(np.where(rows)[0][-1])
    x0, x1 = int(np.where(cols)[0][0]), int(np.where(cols)[0][-1])
    h = y1 - y0 + 1; w = x1 - x0 + 1
    my = int(round(h * margin_frac)); mx = int(round(w * margin_frac))
    return (max(0, y0 - my), min(H, y1 + 1 + my),
            max(0, x0 - mx), min(W, x1 + 1 + mx))


# --------------------------------------------------------------
# Run M1/M2/M4a/M4b for one (CZ, HCR_target) pair
# --------------------------------------------------------------
def run_methods_for_target(cz_bin_warm: np.ndarray, hcr_bin_full: np.ndarray) -> dict:
    rigid = stage1_rigid(cz_bin_warm, hcr_bin_full)
    M0, off0 = _rigid_to_M_off(
        rigid, template_shape=cz_bin_warm.shape,
        template_shape_rot=rigid["template_shape"],
    )
    rigid_warp_full = affine_transform(
        cz_bin_warm.astype(np.float32), M0, offset=off0,
        output_shape=hcr_bin_full.shape, order=1, mode="constant", cval=0.0,
    )

    fg = rigid_warp_full > WARP_BIN_THR
    y0, y1, x0, x1 = _bbox_with_margin(fg, CROP_MARGIN_FRAC, hcr_bin_full.shape)
    hcr_bin = hcr_bin_full[y0:y1, x0:x1].astype(np.uint8)
    rigid_warp = rigid_warp_full[y0:y1, x0:x1]
    off0_c = off0 + M0 @ np.array([y0, x0], dtype=np.float64)
    rigid_ncc = ncc_binary(rigid_warp, hcr_bin)

    affine = stage2_affine(
        cz_bin_warm, hcr_bin, M0, off0_c,
        scale_bounds=SCALE_BOUNDS, theta_bounds_deg=THETA_BOUND_DEG,
    )
    affine_warp = affine_transform(
        cz_bin_warm.astype(np.float32), affine["M"], offset=affine["offset"],
        output_shape=hcr_bin.shape, order=1, mode="constant", cval=0.0,
    )
    affine_ncc = ncc_binary(affine_warp, hcr_bin)

    # Per-grid overlap from sweep: 3×3 best at overlap=0.30; 4×4 at 0.0.
    pwr3 = nonrigid_piecewise_rigid(
        rigid_warp, hcr_bin, n_blocks=3,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
        overlap_frac=0.30,
    )
    pwr3_ncc = ncc_binary(pwr3["warped"], hcr_bin)

    pwr4 = nonrigid_piecewise_rigid(
        rigid_warp, hcr_bin, n_blocks=4,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
        overlap_frac=0.0,
    )
    pwr4_ncc = ncc_binary(pwr4["warped"], hcr_bin)

    return {
        "crop_bbox": (int(y0), int(y1), int(x0), int(x1)),
        "hcr_bin_crop": hcr_bin,
        "rigid":  {"warp": rigid_warp,    "ncc": rigid_ncc,
                   "theta_deg": float(rigid["theta"])},
        "affine": {"warp": affine_warp,   "ncc": affine_ncc,
                   "params": affine["params"]},
        "pwr3x3": {"warp": pwr3["warped"], "ncc": pwr3_ncc,
                   "df_max_dy_px": float(pwr3.get("df_max_dy_px", 0.0)),
                   "df_max_dx_px": float(pwr3.get("df_max_dx_px", 0.0))},
        "pwr4x4": {"warp": pwr4["warped"], "ncc": pwr4_ncc,
                   "df_max_dy_px": float(pwr4.get("df_max_dy_px", 0.0)),
                   "df_max_dx_px": float(pwr4.get("df_max_dx_px", 0.0))},
    }


