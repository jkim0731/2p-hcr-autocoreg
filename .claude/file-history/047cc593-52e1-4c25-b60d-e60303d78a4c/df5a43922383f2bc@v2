HCR_SLAB = (0.0, 100.0)

SCALE_BOUNDS = (0.85, 1.15)
THETA_BOUND_DEG = 15.0
PWR_GRID = 4
PWR_MAX_SHIFT_PX = 16
PWR_SMOOTH_SIGMA_PX = 8.0


# --------------------------------------------------------------
# Helpers
# --------------------------------------------------------------
def _rigid_to_M_off(rigid: dict, template_shape, template_shape_rot) -> tuple:
    th = np.deg2rad(rigid["theta"])
    c, s = np.cos(th), np.sin(th)
    M0 = np.array([[c, s], [-s, c]], dtype=np.float64)
    H_t, W_t = template_shape
    rh, rw = template_shape_rot
    cy_out = rigid["oy"] + rh / 2.0
    cx_out = rigid["ox"] + rw / 2.0
    cy_in = H_t / 2.0
    cx_in = W_t / 2.0
    off0 = np.array([cy_in, cx_in]) - M0 @ np.array([cy_out, cx_out])
    return M0, off0


def _normalise_intensity(img: np.ndarray) -> np.ndarray:
    a = np.asarray(img, dtype=np.float32)
    finite = np.isfinite(a)
    if not finite.any():
        return np.zeros_like(a)
    a = np.where(finite, a, np.nanmin(a[finite]))
    a = np.log1p(np.maximum(a - a.min(), 0.0))
    s = a.std()
    return (a - a.mean()) / (s + 1e-6)


# --------------------------------------------------------------
# Method runners
# --------------------------------------------------------------
def run_methods(cz_bin_warm: np.ndarray, hcr_bin: np.ndarray,
                hcr_intensity_mip: np.ndarray) -> dict:
    H_im, W_im = hcr_bin.shape

    rigid = stage1_rigid(cz_bin_warm, hcr_bin)
    M0, off0 = _rigid_to_M_off(
        rigid, template_shape=cz_bin_warm.shape,
        template_shape_rot=rigid["template_shape"],
    )
    rigid_warp = affine_transform(
        cz_bin_warm.astype(np.float32), M0, offset=off0,
        output_shape=hcr_bin.shape, order=1, mode="constant", cval=0.0,
    )
    rigid_ncc = ncc_overlap(rigid_warp, hcr_bin.astype(np.float32),
                            np.ones(hcr_bin.shape, dtype=bool))

    affine = stage2_affine(
        cz_bin_warm, hcr_bin, M0, off0,
        scale_bounds=SCALE_BOUNDS, theta_bounds_deg=THETA_BOUND_DEG,
    )
    affine_warp = affine_transform(
        cz_bin_warm.astype(np.float32), affine["M"], offset=affine["offset"],
        output_shape=hcr_bin.shape, order=1, mode="constant", cval=0.0,
    )

    coarse = nonrigid_coarse_bspline(affine_warp, hcr_bin, mesh=6,
                                     df_smooth_sigma_px=4.0)

    pwr_bin = nonrigid_piecewise_rigid(
        rigid_warp, hcr_bin, n_blocks=PWR_GRID,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
    )

    fixed_int = _normalise_intensity(hcr_intensity_mip)
    cz_bin_blur = gaussian_filter(rigid_warp.astype(np.float32),
                                  sigma=max(1.5, 2.0))
    moving_int = (cz_bin_blur - cz_bin_blur.mean()) / (cz_bin_blur.std() + 1e-6)
    pwr_int_raw = nonrigid_piecewise_rigid(
        moving_int, fixed_int, n_blocks=PWR_GRID,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
    )
    # NCC of the resulting CZ-binary warp against the watershed HCR target
    # (re-warp the original binary using the same per-pixel DF as pwr_int)
    int_warped_bin = _apply_pwr_df_to(
        rigid_warp, pwr_int_raw, hcr_bin.shape,
    )
    pwr_int_ncc = ncc_overlap(int_warped_bin, hcr_bin.astype(np.float32),
                              np.ones(hcr_bin.shape, dtype=bool))

    return {
        "rigid":      {"warp": rigid_warp,        "ncc": float(rigid_ncc),
                       "theta_deg": float(rigid["theta"])},
        "affine":     {"warp": affine_warp,       "ncc": float(affine["ncc"]),
                       "params": affine["params"]},
        "coarse_bsp": {"warp": coarse["warped"],  "ncc": float(coarse["ncc"]),
                       "ok": bool(coarse.get("ok"))},
        "pwr_binary": {"warp": pwr_bin["warped"], "ncc": float(pwr_bin["ncc"]),
                       "ok": bool(pwr_bin.get("ok")),
                       "df_max_dy_px": float(pwr_bin.get("df_max_dy_px", 0.0)),
                       "df_max_dx_px": float(pwr_bin.get("df_max_dx_px", 0.0))},
        "pwr_intens": {"warp": int_warped_bin,    "ncc": float(pwr_int_ncc),
                       "ok": bool(pwr_int_raw.get("ok")),
                       "df_max_dy_px": float(pwr_int_raw.get("df_max_dy_px", 0.0)),
                       "df_max_dx_px": float(pwr_int_raw.get("df_max_dx_px", 0.0))},
    }


def _apply_pwr_df_to(src: np.ndarray, pwr_result: dict, shape: tuple) -> np.ndarray:
    """Re-derive the same displacement field used inside ``nonrigid_piecewise_rigid``
    and apply it to a different source image (used to map the binary CZ
    through the intensity-derived block-shift field)."""
    from scipy.ndimage import map_coordinates
    from scipy.interpolate import RegularGridInterpolator

    H_im, W_im = shape
    n_blocks = pwr_result["n_blocks"]
    shifts = pwr_result["shifts"]  # (n_blocks, n_blocks, 2)
    bh = H_im // n_blocks
    bw = W_im // n_blocks
    yc = np.array([i * bh + bh / 2.0 for i in range(n_blocks)])
    xc = np.array([j * bw + bw / 2.0 for j in range(n_blocks)])
    fy_dy = RegularGridInterpolator((yc, xc), shifts[..., 0],
                                    bounds_error=False, fill_value=None)
    fy_dx = RegularGridInterpolator((yc, xc), shifts[..., 1],
                                    bounds_error=False, fill_value=None)
    yy, xx = np.mgrid[:H_im, :W_im]
    pts = np.stack([yy.ravel(), xx.ravel()], axis=-1).astype(np.float32)
    dy_px = fy_dy(pts).reshape(H_im, W_im).astype(np.float32)
    dx_px = fy_dx(pts).reshape(H_im, W_im).astype(np.float32)
    dy_px = gaussian_filter(dy_px, sigma=PWR_SMOOTH_SIGMA_PX)
    dx_px = gaussian_filter(dx_px, sigma=PWR_SMOOTH_SIGMA_PX)
    coords = np.array([yy - dy_px, xx - dx_px])
    return map_coordinates(src.astype(np.float32), coords, order=1,
                           mode="constant", cval=0.0)


# --------------------------------------------------------------
# Render
# --------------------------------------------------------------
def render_subject(sid, hcr_bin, hcr_488_mip, results, hcr_xy_um, sxy, out_path):
    H, W = hcr_bin.shape
    extent = [0, W * hcr_xy_um, H * hcr_xy_um, 0]

    fig, axes = plt.subplots(2, 3, figsize=(18, 12))

    def overlay(ax, warped, title, ncc):
        rgb = np.zeros((H, W, 3), dtype=np.float32)
        rgb[..., 0] = np.clip(hcr_bin.astype(np.float32), 0, 1)
        rgb[..., 1] = np.clip(np.asarray(warped, dtype=np.float32), 0, 1)
        ax.imshow(rgb, extent=extent, origin="upper")
        ax.set_title(f"{title}\nNCC = {ncc:.3f}")
        ax.set_xlabel("x (µm)"); ax.set_ylabel("y (µm)")

    # Top-left: HCR watershed binary + 488 raw context
    ax = axes[0, 0]
    bg = np.log1p(np.nan_to_num(hcr_488_mip)).astype(np.float32)
    bg /= max(1e-6, bg.max())
    rgb = np.zeros((H, W, 3), dtype=np.float32)
    rgb[..., 0] = np.clip(hcr_bin.astype(np.float32), 0, 1)
    rgb[..., 2] = bg * 0.6  # blue background = raw 488 (log)
    ax.imshow(rgb, extent=extent, origin="upper")
    ax.set_title(f"{sid} — HCR watershed binary (target)\nsxy={sxy:.3f}")
    ax.set_xlabel("x (µm)"); ax.set_ylabel("y (µm)")

    overlay(axes[0, 1], results["rigid"]["warp"],
            f"M1 rigid (θ={results['rigid']['theta_deg']:+.1f}°)",
            results["rigid"]["ncc"])
    overlay(axes[0, 2], results["affine"]["warp"],
            "M2 rigid + affine (s,θ ±15)", results["affine"]["ncc"])
    overlay(axes[1, 0], results["coarse_bsp"]["warp"],
            "M3 rigid + affine + coarse Bspl",
            results["coarse_bsp"]["ncc"])
    overlay(axes[1, 1], results["pwr_binary"]["warp"],
            f"M4 rigid + PWR ({PWR_GRID}×{PWR_GRID}, binary)",
            results["pwr_binary"]["ncc"])
    overlay(axes[1, 2], results["pwr_intens"]["warp"],
            f"M5 rigid + PWR ({PWR_GRID}×{PWR_GRID}, intensity)",
            results["pwr_intens"]["ncc"])

    fig.suptitle(f"{sid} — 5-method registration comparison "
                 "(watershed HCR binary)")
    fig.tight_layout()
    fig.savefig(out_path, dpi=110, bbox_inches="tight")
    plt.close(fig)


def render_summary(all_results: dict, out_path: Path):
    methods = ["rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"]
    labels = ["M1 rigid", "M2 rig+aff",
              "M3 rig+aff+\ncoarse Bspl",
              f"M4 rig+PWR\n{PWR_GRID}×{PWR_GRID} (bin)",
              f"M5 rig+PWR\n{PWR_GRID}×{PWR_GRID} (int)"]
    sids = [sid for sid in SUBJECTS if sid in all_results
            and "error" not in all_results[sid]]

    fig, ax = plt.subplots(figsize=(13, 5.2))
    width = 0.16
    x = np.arange(len(sids))
    for i, m in enumerate(methods):
        ys = [all_results[sid][m]["ncc"] for sid in sids]
        ax.bar(x + i * width, ys, width, label=labels[i])
    ax.set_xticks(x + 2 * width)
    ax.set_xticklabels(sids)
    ax.set_ylabel("NCC vs HCR watershed binary")
    ax.set_title("Watershed-binarised HCR — 5 registration methods")
    ax.grid(True, alpha=0.3, axis="y")
    ax.legend(loc="upper right", ncol=5, fontsize=9)
    fig.tight_layout()
    fig.savefig(out_path, dpi=120, bbox_inches="tight")
    plt.close(fig)


# --------------------------------------------------------------
# Driver
# --------------------------------------------------------------
def process_subject(sid: str) -> dict:
    print(f"\n=== {sid} ===", flush=True)
    s = load_subject(sid)
    sxy, sxy_src = get_sxy_with_fallback(sid, s)
    print(f"  sxy={sxy:.4f}  src={sxy_src}", flush=True)

    hcr_surf = get_hcr_top_surface_iter07(s, level=HCR_LEVEL)
    cz_surf = get_cz_surface_iter08(s)

    hcr_488_mip, hcr_xy_um = hcr488_top_mip(s, hcr_surf, *HCR_SLAB)
    hcr_bin = variant_watershed(hcr_488_mip, hcr_xy_um)
    print(f"  HCR watershed binary: shape={hcr_bin.shape}  "
          f"fill={hcr_bin.mean()*100:.1f}%", flush=True)

    cz_bin = cz_binary_top_mip(s, cz_surf, *CZ_SLAB)
    cz_bin_warm = warm_start_cz_binary(
        cz_bin, cz_xy_um=float(s.cz_xy_um), hcr_xy_um=hcr_xy_um, sxy=sxy,
    )

    res = run_methods(cz_bin_warm, hcr_bin, hcr_488_mip)
    for k in ("rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"):
        v = res[k]
        extra = ""
        if "ok" in v:
            extra = f"  ok={v['ok']}"
        if "df_max_dy_px" in v:
            extra += f"  df_max=({v['df_max_dy_px']:.1f},{v['df_max_dx_px']:.1f})px"
        print(f"  {k:11s}  NCC={v['ncc']:.3f}{extra}", flush=True)

    out_png = FIG / f"compare_methods_watershed_{sid}.png"
    render_subject(sid, hcr_bin, hcr_488_mip, res, hcr_xy_um, sxy, out_png)

    # Drop big arrays for JSON
    summary = {"sid": sid, "sxy": sxy, "sxy_source": sxy_src,
               "hcr_xy_um": hcr_xy_um}
    for k, v in res.items():
        summary[k] = {kk: vv for kk, vv in v.items() if kk != "warp"}
    summary["wrote"] = str(out_png.relative_to(HERE))
    return summary


def main():
    all_results = {}
    for sid in SUBJECTS:
        try:
            all_results[sid] = process_subject(sid)
        except Exception as e:
            print(f"  ERROR {sid}: {type(e).__name__}: {e}", flush=True)
            import traceback
            traceback.print_exc()
            all_results[sid] = {"sid": sid, "error": str(e)}

    out_json = HERE / "compare_methods_watershed_summary.json"
    out_json.write_text(json.dumps(all_results, indent=2, default=float))
    print(f"\nwrote {out_json.name}")

    out_png = FIG / "compare_methods_watershed_summary.png"
    render_summary(all_results, out_png)
    print(f"wrote {out_png.name}")

    # Quick text table
    methods = ["rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"]
    print("\nNCC table:")
    print(f"{'sid':<8}" + "".join(f"{m:>13}" for m in methods))
    for sid in SUBJECTS:
        r = all_results.get(sid, {})
        if "error" in r:
            print(f"{sid:<8}  ERROR")
            continue
        print(f"{sid:<8}" + "".join(f"  {r[m]['ncc']:11.3f}" for m in methods))


if __name__ == "__main__":
    main()
