# --------------------------------------------------------------
# Single canonical NCC: binary-vs-binary on a fixed mask
# --------------------------------------------------------------
def ncc_binary(warped: np.ndarray, hcr_bin: np.ndarray,
               mask: np.ndarray | None = None) -> float:
    """NCC between (warped > thr) and hcr_bin, on `mask` (full if None)."""
    a = (np.asarray(warped, dtype=np.float32) > WARP_BIN_THR).astype(np.float64)
    b = (np.asarray(hcr_bin) > 0.5).astype(np.float64)
    if mask is None:
        mask = np.ones(b.shape, dtype=bool)
    if mask.sum() < 50:
        return -1.0
    av = a[mask]; bv = b[mask]
    av = av - av.mean(); bv = bv - bv.mean()
    den = av.std() * bv.std()
    if den <= 1e-12:
        return -1.0
    return float((av * bv).mean() / den)


# --------------------------------------------------------------
# Helpers
# --------------------------------------------------------------
def _rigid_to_M_off(rigid: dict, template_shape, template_shape_rot) -> tuple:
    th = np.deg2rad(rigid["theta"])
    c, s = np.cos(th), np.sin(th)
    M0 = np.array([[c, s], [-s, c]], dtype=np.float64)
    H_t, W_t = template_shape
    rh, rw = template_shape_rot
    cy_out = rigid["oy"] + rh / 2.0
    cx_out = rigid["ox"] + rw / 2.0
    cy_in = H_t / 2.0
    cx_in = W_t / 2.0
    off0 = np.array([cy_in, cx_in]) - M0 @ np.array([cy_out, cx_out])
    return M0, off0


def _bbox_with_margin(mask_bool: np.ndarray, margin_frac: float, shape):
    """Return (y0, y1, x0, x1) of foreground bbox + margin_frac on each side."""
    H, W = shape
    if not mask_bool.any():
        return 0, H, 0, W
    rows = np.any(mask_bool, axis=1)
    cols = np.any(mask_bool, axis=0)
    y0, y1 = int(np.where(rows)[0][0]), int(np.where(rows)[0][-1])
    x0, x1 = int(np.where(cols)[0][0]), int(np.where(cols)[0][-1])
    h = y1 - y0 + 1; w = x1 - x0 + 1
    my = int(round(h * margin_frac)); mx = int(round(w * margin_frac))
    return (max(0, y0 - my), min(H, y1 + 1 + my),
            max(0, x0 - mx), min(W, x1 + 1 + mx))


def _normalise_intensity(img: np.ndarray) -> np.ndarray:
    a = np.asarray(img, dtype=np.float32)
    finite = np.isfinite(a)
    if not finite.any():
        return np.zeros_like(a)
    a = np.where(finite, a, np.nanmin(a[finite]))
    a = np.log1p(np.maximum(a - a.min(), 0.0))
    s = a.std()
    return (a - a.mean()) / (s + 1e-6)


def _apply_pwr_df(src: np.ndarray, pwr_result: dict, shape: tuple) -> np.ndarray:
    """Re-derive the per-pixel DF used inside `nonrigid_piecewise_rigid`
    and apply it to a different source (e.g. map a binary CZ through a
    DF computed on intensity)."""
    H_im, W_im = shape
    n_blocks = pwr_result["n_blocks"]
    shifts = pwr_result["shifts"]
    bh = H_im // n_blocks; bw = W_im // n_blocks
    yc = np.array([i * bh + bh / 2.0 for i in range(n_blocks)])
    xc = np.array([j * bw + bw / 2.0 for j in range(n_blocks)])
    fy_dy = RegularGridInterpolator((yc, xc), shifts[..., 0],
                                    bounds_error=False, fill_value=None)
    fy_dx = RegularGridInterpolator((yc, xc), shifts[..., 1],
                                    bounds_error=False, fill_value=None)
    yy, xx = np.mgrid[:H_im, :W_im]
    pts = np.stack([yy.ravel(), xx.ravel()], axis=-1).astype(np.float32)
    dy_px = fy_dy(pts).reshape(H_im, W_im).astype(np.float32)
    dx_px = fy_dx(pts).reshape(H_im, W_im).astype(np.float32)
    dy_px = gaussian_filter(dy_px, sigma=PWR_SMOOTH_SIGMA_PX)
    dx_px = gaussian_filter(dx_px, sigma=PWR_SMOOTH_SIGMA_PX)
    coords = np.array([yy - dy_px, xx - dx_px])
    return map_coordinates(src.astype(np.float32), coords, order=1,
                           mode="constant", cval=0.0)


# --------------------------------------------------------------
# Pipeline: M1 on full canvas → crop → M2..M5 on cropped frame
# --------------------------------------------------------------
def run_methods(cz_bin_warm: np.ndarray, hcr_bin_full: np.ndarray,
                hcr_488_mip_full: np.ndarray) -> dict:
    H_full, W_full = hcr_bin_full.shape

    # ---- M1: rigid on full canvas ----
    rigid = stage1_rigid(cz_bin_warm, hcr_bin_full)
    M0, off0 = _rigid_to_M_off(
        rigid, template_shape=cz_bin_warm.shape,
        template_shape_rot=rigid["template_shape"],
    )
    rigid_warp_full = affine_transform(
        cz_bin_warm.astype(np.float32), M0, offset=off0,
        output_shape=hcr_bin_full.shape, order=1, mode="constant", cval=0.0,
    )

    # ---- Crop HCR + rigid_warp to M1 bbox + 15% margin ----
    fg = rigid_warp_full > WARP_BIN_THR
    y0, y1, x0, x1 = _bbox_with_margin(fg, CROP_MARGIN_FRAC, hcr_bin_full.shape)
    hcr_bin = hcr_bin_full[y0:y1, x0:x1].astype(np.uint8)
    hcr_488 = hcr_488_mip_full[y0:y1, x0:x1]
    rigid_warp = rigid_warp_full[y0:y1, x0:x1]
    H_im, W_im = hcr_bin.shape

    # Translate the rigid affine init into the cropped frame. For
    # ``affine_transform``: output(y',x') = template[M @ (y',x') + off].
    # When we shift output by (y0, x0) to enter the cropped frame:
    #     M @ (y'+y0, x'+x0) + off = M @ (y',x') + (M @ (y0,x0) + off)
    # so the cropped offset is off0 + M0 @ (y0, x0).
    off0_c = off0 + M0 @ np.array([y0, x0], dtype=np.float64)

    rigid_ncc = ncc_binary(rigid_warp, hcr_bin)

    # ---- M2: rigid + affine (on cropped HCR) ----
    affine = stage2_affine(
        cz_bin_warm, hcr_bin, M0, off0_c,
        scale_bounds=SCALE_BOUNDS, theta_bounds_deg=THETA_BOUND_DEG,
    )
    affine_warp = affine_transform(
        cz_bin_warm.astype(np.float32), affine["M"], offset=affine["offset"],
        output_shape=hcr_bin.shape, order=1, mode="constant", cval=0.0,
    )
    affine_ncc = ncc_binary(affine_warp, hcr_bin)

    # ---- M3: rigid + affine + coarse BSpline ----
    coarse = nonrigid_coarse_bspline(affine_warp, hcr_bin, mesh=6,
                                     df_smooth_sigma_px=4.0)
    coarse_ncc = ncc_binary(coarse["warped"], hcr_bin)

    # ---- M4: rigid + PWR 4x4 on binary masks ----
    pwr_bin = nonrigid_piecewise_rigid(
        rigid_warp, hcr_bin, n_blocks=PWR_GRID,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
    )
    pwr_bin_ncc = ncc_binary(pwr_bin["warped"], hcr_bin)

    # ---- M5: rigid + PWR 4x4 on intensity ----
    fixed_int = _normalise_intensity(hcr_488)
    cz_blur = gaussian_filter(rigid_warp.astype(np.float32), sigma=2.0)
    moving_int = (cz_blur - cz_blur.mean()) / (cz_blur.std() + 1e-6)
    pwr_int_raw = nonrigid_piecewise_rigid(
        moving_int, fixed_int, n_blocks=PWR_GRID,
        max_shift_px=PWR_MAX_SHIFT_PX,
        interp_smooth_sigma_px=PWR_SMOOTH_SIGMA_PX,
    )
    pwr_int_warp_bin = _apply_pwr_df(rigid_warp, pwr_int_raw, hcr_bin.shape)
    pwr_int_ncc = ncc_binary(pwr_int_warp_bin, hcr_bin)

    return {
        "crop_bbox_full": (int(y0), int(y1), int(x0), int(x1)),
        "full_shape": (int(H_full), int(W_full)),
        "hcr_bin_crop": hcr_bin,
        "hcr_488_crop": hcr_488,
        "rigid":      {"warp": rigid_warp,           "ncc": rigid_ncc,
                       "theta_deg": float(rigid["theta"])},
        "affine":     {"warp": affine_warp,          "ncc": affine_ncc,
                       "params": affine["params"]},
        "coarse_bsp": {"warp": coarse["warped"],     "ncc": coarse_ncc,
                       "ok": bool(coarse.get("ok"))},
        "pwr_binary": {"warp": pwr_bin["warped"],    "ncc": pwr_bin_ncc,
                       "df_max_dy_px": float(pwr_bin.get("df_max_dy_px", 0.0)),
                       "df_max_dx_px": float(pwr_bin.get("df_max_dx_px", 0.0))},
        "pwr_intens": {"warp": pwr_int_warp_bin,     "ncc": pwr_int_ncc,
                       "df_max_dy_px": float(pwr_int_raw.get("df_max_dy_px", 0.0)),
                       "df_max_dx_px": float(pwr_int_raw.get("df_max_dx_px", 0.0))},
    }


# --------------------------------------------------------------
# Render
# --------------------------------------------------------------
def render_subject(sid, results, hcr_xy_um, sxy, out_path):
    hcr_bin = results["hcr_bin_crop"]
    hcr_488 = results["hcr_488_crop"]
    H, W = hcr_bin.shape
    extent = [0, W * hcr_xy_um, H * hcr_xy_um, 0]

    fig, axes = plt.subplots(2, 3, figsize=(18, 12))

    def overlay(ax, warped, title, ncc):
        wb = (np.asarray(warped, dtype=np.float32) > WARP_BIN_THR).astype(np.float32)
        rgb = np.zeros((H, W, 3), dtype=np.float32)
        rgb[..., 0] = (hcr_bin > 0.5).astype(np.float32)
        rgb[..., 1] = wb
        ax.imshow(rgb, extent=extent, origin="upper")
        ax.set_title(f"{title}\nbin-NCC = {ncc:.3f}")
        ax.set_xlabel("x (µm)"); ax.set_ylabel("y (µm)")

    # Top-left: HCR target with raw 488 in blue (cropped)
    ax = axes[0, 0]
    bg = np.log1p(np.nan_to_num(hcr_488)).astype(np.float32)
    bg /= max(1e-6, bg.max())
    rgb = np.zeros((H, W, 3), dtype=np.float32)
    rgb[..., 0] = (hcr_bin > 0.5).astype(np.float32)
    rgb[..., 2] = bg * 0.6
    ax.imshow(rgb, extent=extent, origin="upper")
    y0, y1, x0, x1 = results["crop_bbox_full"]
    H_full, W_full = results["full_shape"]
    ax.set_title(f"{sid} — HCR watershed (M1-bbox crop)\n"
                 f"sxy={sxy:.3f}  crop=({y1-y0}×{x1-x0}) of ({H_full}×{W_full})")
    ax.set_xlabel("x (µm)"); ax.set_ylabel("y (µm)")

    overlay(axes[0, 1], results["rigid"]["warp"],
            f"M1 rigid (θ={results['rigid']['theta_deg']:+.1f}°)",
            results["rigid"]["ncc"])
    overlay(axes[0, 2], results["affine"]["warp"],
            "M2 rigid + affine (s,θ ±15)", results["affine"]["ncc"])
    overlay(axes[1, 0], results["coarse_bsp"]["warp"],
            "M3 rigid + affine + coarse Bspl", results["coarse_bsp"]["ncc"])
    overlay(axes[1, 1], results["pwr_binary"]["warp"],
            f"M4 rigid + PWR ({PWR_GRID}×{PWR_GRID}, binary)",
            results["pwr_binary"]["ncc"])
    overlay(axes[1, 2], results["pwr_intens"]["warp"],
            f"M5 rigid + PWR ({PWR_GRID}×{PWR_GRID}, intensity)",
            results["pwr_intens"]["ncc"])

    fig.suptitle(f"{sid} — 5-method comparison "
                 "(watershed HCR; binary NCC; M1-bbox+15% crop)")
    fig.tight_layout()
    fig.savefig(out_path, dpi=110, bbox_inches="tight")
    plt.close(fig)


def render_summary(all_results: dict, out_path: Path):
    methods = ["rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"]
    labels = ["M1 rigid", "M2 rig+aff",
              "M3 rig+aff+\ncoarse Bspl",
              f"M4 rig+PWR\n{PWR_GRID}×{PWR_GRID} (bin)",
              f"M5 rig+PWR\n{PWR_GRID}×{PWR_GRID} (int)"]
    sids = [sid for sid in SUBJECTS if sid in all_results
            and "error" not in all_results[sid]]

    fig, ax = plt.subplots(figsize=(13, 5.2))
    width = 0.16
    x = np.arange(len(sids))
    for i, m in enumerate(methods):
        ys = [all_results[sid][m]["ncc"] for sid in sids]
        ax.bar(x + i * width, ys, width, label=labels[i])
    ax.set_xticks(x + 2 * width)
    ax.set_xticklabels(sids)
    ax.set_ylabel("binary NCC vs HCR watershed (M1-bbox crop)")
    ax.set_title("Watershed HCR — 5 registration methods (binary NCC)")
    ax.grid(True, alpha=0.3, axis="y")
    ax.legend(loc="upper right", ncol=5, fontsize=9)
    fig.tight_layout()
    fig.savefig(out_path, dpi=120, bbox_inches="tight")
    plt.close(fig)


# --------------------------------------------------------------
# Driver
# --------------------------------------------------------------
def process_subject(sid: str) -> dict:
    print(f"\n=== {sid} ===", flush=True)
    s = load_subject(sid)
    sxy, sxy_src = get_sxy_with_fallback(sid, s)
    print(f"  sxy={sxy:.4f}  src={sxy_src}", flush=True)

    hcr_surf = get_hcr_top_surface_iter07(s, level=HCR_LEVEL)
    cz_surf = get_cz_surface_iter08(s)

    hcr_488_full, hcr_xy_um = hcr488_top_mip(s, hcr_surf, *HCR_SLAB)
    hcr_bin_full = variant_watershed(hcr_488_full, hcr_xy_um)

    cz_bin = cz_binary_top_mip(s, cz_surf, *CZ_SLAB)
    cz_bin_warm = warm_start_cz_binary(
        cz_bin, cz_xy_um=float(s.cz_xy_um), hcr_xy_um=hcr_xy_um, sxy=sxy,
    )

    res = run_methods(cz_bin_warm, hcr_bin_full, hcr_488_full)
    y0, y1, x0, x1 = res["crop_bbox_full"]
    H_full, W_full = res["full_shape"]
    print(f"  HCR full {H_full}×{W_full}; M1 crop: "
          f"y[{y0}:{y1}] x[{x0}:{x1}] = {y1-y0}×{x1-x0}", flush=True)
    for k in ("rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"):
        v = res[k]
        extra = ""
        if "df_max_dy_px" in v:
            extra = f"  df_max=({v['df_max_dy_px']:.1f},{v['df_max_dx_px']:.1f})px"
        print(f"  {k:11s}  bin-NCC={v['ncc']:.3f}{extra}", flush=True)

    out_png = FIG / f"compare_methods_watershed_{sid}.png"
    render_subject(sid, res, hcr_xy_um, sxy, out_png)

    summary = {"sid": sid, "sxy": sxy, "sxy_source": sxy_src,
               "hcr_xy_um": hcr_xy_um,
               "crop_bbox_full": list(res["crop_bbox_full"]),
               "full_shape": list(res["full_shape"])}
    for k in ("rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"):
        summary[k] = {kk: vv for kk, vv in res[k].items() if kk != "warp"}
    summary["wrote"] = str(out_png.relative_to(HERE))
    return summary


def main():
    all_results = {}
    for sid in SUBJECTS:
        try:
            all_results[sid] = process_subject(sid)
        except Exception as e:
            print(f"  ERROR {sid}: {type(e).__name__}: {e}", flush=True)
            import traceback; traceback.print_exc()
            all_results[sid] = {"sid": sid, "error": str(e)}

    out_json = HERE / "compare_methods_watershed_summary.json"
    out_json.write_text(json.dumps(all_results, indent=2, default=float))
    print(f"\nwrote {out_json.name}")
    out_png = FIG / "compare_methods_watershed_summary.png"
    render_summary(all_results, out_png)
    print(f"wrote {out_png.name}")

    methods = ["rigid", "affine", "coarse_bsp", "pwr_binary", "pwr_intens"]
    print("\nbinary NCC table (cropped frame):")
    print(f"{'sid':<8}" + "".join(f"{m:>13}" for m in methods))
    for sid in SUBJECTS:
        r = all_results.get(sid, {})
        if "error" in r:
            print(f"{sid:<8}  ERROR"); continue
        print(f"{sid:<8}" + "".join(f"  {r[m]['ncc']:11.3f}" for m in methods))


if __name__ == "__main__":
    main()
