    return [
        Method("baseline_image_5pct", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_low_margin(vol, z_um, xy_um, 0.05, 0.1)),
        Method("N1_margin_1pct", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_low_margin(vol, z_um, xy_um, 0.01, 0.05)),
        Method("N1_margin_0p5pct", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_low_margin(vol, z_um, xy_um, 0.005, 0.05)),
        Method("N1_margin_0p1pct", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_low_margin(vol, z_um, xy_um, 0.001, 0.05)),
        Method("N2_per_channel_shallowest_1pct", "hcr_subject", True,
               lambda s: per_channel_shallowest(s, level=4, margin=0.01)),
        Method("N2_per_channel_shallowest_0p5pct", "hcr_subject", True,
               lambda s: per_channel_shallowest(s, level=4, margin=0.005)),
        Method("N3_roi_leading_edge_q0_off-15", "hcr", False,
               lambda xyz: roi_leading_edge_plane(
                   xyz, q_frac=0.0, z_offset_um=-15.0)),
        Method("N3_roi_leading_edge_q0_off-30", "hcr", False,
               lambda xyz: roi_leading_edge_plane(
                   xyz, q_frac=0.0, z_offset_um=-30.0)),
        Method("N3_roi_leading_edge_q2_off-5", "hcr", False,
