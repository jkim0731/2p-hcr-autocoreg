# ---------------------------------------------------------------
# Quality metrics — corrected criterion
# ---------------------------------------------------------------
def quality_metrics(pts_um: np.ndarray, surface: dict) -> dict:
    """Return quality metrics under the corrected criterion.

    - `above_frac` — share of cells with depth < 0. **Primary metric**:
      target close to 0 (the user accepts "close to 0 but not exactly 0").
    - `above_frac_5` — share with depth < -5 um (same as v1 frac_above_pia
      for backward comparison).
    - `cum_above_ratio` — mean density over [-200, 0] / mean density over
      [50, 200]. Expresses cumulative above-pia density relative to bulk.
      Target: << 1.
    - `onset_depth_um` — depth (>=0) where smoothed density first reaches
      50% of bulk. Larger onset_depth = surface sits further above tissue.
    - `above_peak_pos` — position (um) of the maximum density in the
      window [-200, 0]. If a spike still sits above the surface it will
      show here as a negative number.
    """
    if surface is None or len(pts_um) == 0:
        return {k: float("nan") for k in (
            "above_frac", "above_frac_5", "cum_above_ratio",
            "onset_depth_um", "above_peak_pos")}
    d = depth_from_surface(pts_um, surface)
    n_total = len(d)
    above_frac = float((d < 0).sum()) / n_total
    above_frac_5 = float((d < -5).sum()) / n_total
    bin_um = 5.0
    edges = np.arange(-200.0, 800.0 + bin_um, bin_um)
    centers = 0.5 * (edges[:-1] + edges[1:])
    h, _ = np.histogram(d, bins=edges)
    dens = h.astype(float) / bin_um
    bulk_mask = (centers >= 50) & (centers <= 200)
    above_mask = (centers >= -200) & (centers < 0)
    bulk = dens[bulk_mask].mean() if bulk_mask.any() else 0.0
    above_mean = dens[above_mask].mean() if above_mask.any() else 0.0
    cum_above_ratio = float(above_mean / bulk) if bulk > 0 else float("nan")
    # Onset depth: smoothed density crosses 0.5 * bulk going positive
    ksz = 6  # 30 um boxcar
    smooth = np.convolve(dens, np.ones(ksz) / ksz, mode="same")
    pos_mask = centers >= 0
    over = pos_mask & (smooth >= 0.5 * bulk)
    onset_depth = float(centers[over][0]) if (bulk > 0 and over.any()) else float("nan")
    # Peak position above surface (most "troublesome" above-pia depth)
    if above_mask.any():
        i = int(np.argmax(dens[above_mask]))
        above_peak_pos = float(centers[above_mask][i])
    else:
        above_peak_pos = float("nan")
    return {
        "above_frac": above_frac,
        "above_frac_5": above_frac_5,
        "cum_above_ratio": cum_above_ratio,
        "onset_depth_um": onset_depth,
        "above_peak_pos": above_peak_pos,
    }


# ---------------------------------------------------------------
# HCR methods (shallower direction)
# ---------------------------------------------------------------
def image_low_margin(vol, z_um, xy_um, margin: float, min_signal_abs: float):
    """Image-based fit with a very low `relative_margin` — catches the
    outermost signal edge. Smaller margin = surface placed shallower."""
    return estimate_pia_surface_from_image(
        vol, z_um, xy_um,
        min_signal_abs=min_signal_abs,
        relative_margin=margin,
    )


def per_channel_shallowest(s, level: int, margin: float, min_signal_abs: float = 100.0):
    """Fit a plane from each HCR channel independently, then return the plane
    whose intercept `c` is the shallowest (smallest z) at the volume centre.

    Rationale: different channels highlight different structures; the pia is
    whichever channel detects the topmost (smallest z) tissue boundary."""
    planes = []
    for ch in list_hcr_channels(s):
        try:
            vol, xy_um, z_um = load_hcr_volume(s, channel=ch, level=level)
        except FileNotFoundError:
            continue
        fit = estimate_pia_surface_from_image(
            vol, z_um, xy_um,
            min_signal_abs=min_signal_abs,
            relative_margin=margin,
        )
        if fit is not None:
            fit["channel"] = ch
            planes.append(fit)
    if not planes:
        return None
    # Pick the plane with the smallest z at the mean (x,y) footprint of cells
    # (smallest z = shallowest = most toward buffer).
    key = [(p["c"], p) for p in planes]
    key.sort(key=lambda t: t[0])
    winner = dict(key[0][1])
    winner["method"] = "per_channel_shallowest"
    winner["n_channels_considered"] = len(planes)
    return winner


def roi_leading_edge_plane(
    hcr_xyz_um: np.ndarray,
    *,
    xy_tile_um: float = 120.0,
    q_frac: float = 0.02,
    density_filter_radius: float = 30.0,
    density_min_neighbors: int = 3,
    z_offset_um: float = -15.0,
):
    """Fit a tilted plane to the per-tile **shallowest** ROI centroid, then
    translate by `z_offset_um` (negative = toward buffer) so the plane sits
    slightly above the topmost ROIs.

    Density filter (≥`density_min_neighbors` neighbours in `radius`) removes
    truly-isolated ROIs (often segmentation singletons) before taking the
    minimum per tile, otherwise one outlier in the buffer would pull the
    plane too high. The segmentation *clusters* in the buffer (session 01
    Stage A) are preserved by the filter — those are the ROIs the pia must
    sit above."""
    pts = np.asarray(hcr_xyz_um, dtype=float)
    if len(pts) < 50:
        return None
    keep = filter_in_tissue(
        pts, radius_um=density_filter_radius,
        min_neighbors=density_min_neighbors,
    )
    pts = pts[keep]
    if len(pts) < 50:
        return None
    xs, ys, zs = pts[:, 0], pts[:, 1], pts[:, 2]
    x_bin = (xs // xy_tile_um).astype(int)
    y_bin = (ys // xy_tile_um).astype(int)
    key = y_bin * 100000 + x_bin
    df = pd.DataFrame({"key": key, "x": xs, "y": ys, "z": zs})
    g = df.groupby("key")
    # Take the q_frac quantile of z per tile (q=0 → absolute min).
    agg = g.agg(x=("x", "median"), y=("y", "median"),
                z=("z", lambda v: float(np.quantile(v, q_frac))),
                n=("z", "size"))
    agg = agg[agg["n"] >= 5]
    if len(agg) < 10:
        return None
    fit = _robust_plane_fit(agg["x"].values, agg["y"].values, agg["z"].values)
    fit["c"] = float(fit["c"] + z_offset_um)
    fit["method"] = "roi_leading_edge"
    fit["n_tiles"] = int(len(agg))
    fit["z_offset_um"] = float(z_offset_um)
    return fit


def image_with_roi_ceiling(
    hcr_xyz_um: np.ndarray,
    vol: np.ndarray,
    z_um: float,
    xy_um: float,
    *,
    margin: float = 0.01,
    min_signal_abs: float = 0.05,
    safety_offset_um: float = 5.0,
    roi_xy_tile_um: float = 120.0,
    roi_q_frac: float = 0.02,
):
    """Low-margin image fit, then **clamp** the plane so no tile has ROIs
    above it. Tile by tile: if the tile's q_frac quantile of ROI z is
    above the image plane at that tile centre, lift the entire plane by
    the deficit (conservative global lift keeps it a plane — required).

    This approach adds robustness against tiles where the image threshold
    misses a cell-bearing region."""
    base = estimate_pia_surface_from_image(
        vol, z_um, xy_um,
        min_signal_abs=min_signal_abs,
        relative_margin=margin,
    )
    if base is None:
        return None
    pts = np.asarray(hcr_xyz_um, dtype=float)
    keep = filter_in_tissue(pts, radius_um=30.0, min_neighbors=3)
    pts = pts[keep]
    if len(pts) < 50:
        return base
    xs, ys, zs = pts[:, 0], pts[:, 1], pts[:, 2]
    x_bin = (xs // roi_xy_tile_um).astype(int)
    y_bin = (ys // roi_xy_tile_um).astype(int)
    key = y_bin * 100000 + x_bin
    df = pd.DataFrame({"key": key, "x": xs, "y": ys, "z": zs})
    g = df.groupby("key")
    agg = g.agg(x=("x", "median"), y=("y", "median"),
                z=("z", lambda v: float(np.quantile(v, roi_q_frac))),
                n=("z", "size"))
    agg = agg[agg["n"] >= 5]
    if len(agg) < 5:
        return base
    # Plane value at each tile centre
    plane_z = base["a"] * agg["x"].values + base["b"] * agg["y"].values + base["c"]
    deficit = plane_z - agg["z"].values  # if >0, plane sits below some ROI
    lift = float(max(0.0, deficit.max()))
    fit = dict(base)
    fit["c"] = float(fit["c"] - lift - safety_offset_um)
    fit["method"] = "image_with_roi_ceiling"
    fit["lift_um"] = lift
    fit["safety_offset_um"] = safety_offset_um
    fit["n_ceiling_tiles"] = int(len(agg))
    return fit


# ---------------------------------------------------------------
# CZ methods
# ---------------------------------------------------------------
def cz_image_surface(cz_img: np.ndarray, z_um: float, xy_um: float, margin: float):
    return estimate_pia_surface_from_image(
        cz_img, z_um, xy_um,
        min_signal_abs=50.0,
        relative_margin=margin,
    )


def cz_image_with_roi_ceiling(
    cz_xyz_um: np.ndarray,
    cz_img: np.ndarray,
    z_um: float,
    xy_um: float,
    *,
    margin: float = 0.02,
    safety_offset_um: float = 3.0,
    roi_xy_tile_um: float = 80.0,
    roi_q_frac: float = 0.0,
):
    base = cz_image_surface(cz_img, z_um, xy_um, margin=margin)
    if base is None:
        return None
    pts = np.asarray(cz_xyz_um, dtype=float)
    xs, ys, zs = pts[:, 0], pts[:, 1], pts[:, 2]
    x_bin = (xs // roi_xy_tile_um).astype(int)
    y_bin = (ys // roi_xy_tile_um).astype(int)
    key = y_bin * 100000 + x_bin
    df = pd.DataFrame({"key": key, "x": xs, "y": ys, "z": zs})
    g = df.groupby("key")
    agg = g.agg(x=("x", "median"), y=("y", "median"),
                z=("z", lambda v: float(np.quantile(v, roi_q_frac))),
                n=("z", "size"))
    agg = agg[agg["n"] >= 3]
    if len(agg) < 5:
        return base
    plane_z = base["a"] * agg["x"].values + base["b"] * agg["y"].values + base["c"]
    deficit = plane_z - agg["z"].values
    lift = float(max(0.0, deficit.max()))
    fit = dict(base)
    fit["c"] = float(fit["c"] - lift - safety_offset_um)
    fit["method"] = "cz_image_with_roi_ceiling"
    fit["lift_um"] = lift
    return fit


