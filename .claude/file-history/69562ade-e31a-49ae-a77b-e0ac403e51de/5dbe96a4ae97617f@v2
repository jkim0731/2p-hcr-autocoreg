        Method("N4_image_ceiling_1pct_off5", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_with_roi_ceiling(xyz, vol, z_um, xy_um,
                                          margin=0.01, safety_offset_um=5.0)),
        Method("N4_image_ceiling_0p5pct_off5", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_with_roi_ceiling(xyz, vol, z_um, xy_um,
