        Method("N4_image_ceiling_0p1pct_off10", "hcr", True,
               lambda xyz, vol, z_um, xy_um:
                   image_with_roi_ceiling(xyz, vol, z_um, xy_um,
                                          margin=0.001, safety_offset_um=10.0)),
    ]


def cz_methods() -> list[Method]:
    return [
        Method("cz_baseline_5pct", "cz", True,
               lambda xyz, vol, z_um, xy_um:
                   cz_image_surface(vol, z_um, xy_um, 0.05)),
        Method("cz_image_2pct", "cz", True,
               lambda xyz, vol, z_um, xy_um:
                   cz_image_surface(vol, z_um, xy_um, 0.02)),
        Method("cz_image_1pct", "cz", True,
               lambda xyz, vol, z_um, xy_um:
                   cz_image_surface(vol, z_um, xy_um, 0.01)),
        Method("cz_ceiling_2pct", "cz", True,
               lambda xyz, vol, z_um, xy_um:
                   cz_image_with_roi_ceiling(xyz, vol, z_um, xy_um,
                                             margin=0.02, safety_offset_um=3.0)),
        Method("cz_ceiling_1pct", "cz", True,
               lambda xyz, vol, z_um, xy_um:
                   cz_image_with_roi_ceiling(xyz, vol, z_um, xy_um,
                                             margin=0.01, safety_offset_um=3.0)),
    ]


# ---------------------------------------------------------------
# Evaluation
# ---------------------------------------------------------------
def run_hcr(methods: list[Method], subjects) -> tuple[pd.DataFrame, dict]:
    rows = []
    fits: dict[str, dict] = {}
    for sid in subjects:
        print(f"\n=== HCR {sid} ===")
        s = load_subject(sid)
        hcr_um = hcr_px_to_um(s.hcr_centroids[["z_px", "y_px", "x_px"]].values, s)
        hcr_xyz = hcr_um[:, [2, 1, 0]]
        vol = xy_um = z_um = None
        fits[sid] = {"_xyz": hcr_xyz}
        for m in methods:
            try:
                if m.scope == "hcr_subject":
                    surf = m.fn(s)
                elif m.needs_image:
                    if vol is None:
                        vol, xy_um, z_um, _ = load_hcr_combined(s, level=4)
                    surf = m.fn(hcr_xyz, vol, z_um, xy_um)
                else:
                    surf = m.fn(hcr_xyz)
            except Exception as e:
                print(f"  {m.name}: FAILED ({e})")
                rows.append({"subject": sid, "method": m.name,
                             "error": str(e)[:200]})
                continue
            if surf is None:
                print(f"  {m.name}: returned None")
                rows.append({"subject": sid, "method": m.name, "error": "None"})
                continue
            q = quality_metrics(hcr_xyz, surf)
            print(f"  {m.name}: c={surf.get('c'):.1f}  tilt={surf.get('tilt_deg',0):.2f}  "
                  f"above%={q['above_frac']*100:.2f}  cum_above={q['cum_above_ratio']:.3f}  "
                  f"onset={q['onset_depth_um']}  peak_above={q['above_peak_pos']}")
            rows.append({"subject": sid, "method": m.name,
                         "c_um": surf.get("c"),
                         "tilt_deg": surf.get("tilt_deg"),
                         "rough_um": surf.get("residual_std_um"),
                         **q})
            fits[sid][m.name] = surf
    df = pd.DataFrame(rows)
    df.to_csv(OUT / "hcr_results.csv", index=False)
    print(f"\nWrote {OUT / 'hcr_results.csv'}")
    return df, fits


def run_cz(methods: list[Method], subjects) -> tuple[pd.DataFrame, dict]:
    rows = []
    fits: dict[str, dict] = {}
    for sid in subjects:
        print(f"\n=== CZ {sid} ===")
        s = load_subject(sid)
        cz_um = cz_px_to_um(s.cz_centroids[["z_px", "y_px", "x_px"]].values, s)
        cz_xyz = cz_um[:, [2, 1, 0]]
        fits[sid] = {"_xyz": cz_xyz}
        img = load_cz_image(s)
        if img is None:
            print("  no CZ image")
            continue
        for m in methods:
            try:
                surf = m.fn(cz_xyz, img, s.cz_z_um, s.cz_xy_um)
            except Exception as e:
                print(f"  {m.name}: FAILED ({e})")
                rows.append({"subject": sid, "method": m.name,
                             "error": str(e)[:200]})
                continue
            if surf is None:
                print(f"  {m.name}: returned None")
                rows.append({"subject": sid, "method": m.name, "error": "None"})
                continue
            q = quality_metrics(cz_xyz, surf)
            print(f"  {m.name}: c={surf.get('c'):.1f}  tilt={surf.get('tilt_deg',0):.2f}  "
                  f"above%={q['above_frac']*100:.2f}  cum_above={q['cum_above_ratio']:.3f}  "
                  f"onset={q['onset_depth_um']}")
            rows.append({"subject": sid, "method": m.name,
                         "c_um": surf.get("c"),
                         "tilt_deg": surf.get("tilt_deg"),
                         "rough_um": surf.get("residual_std_um"),
                         **q})
            fits[sid][m.name] = surf
    df = pd.DataFrame(rows)
    df.to_csv(OUT / "cz_results.csv", index=False)
    print(f"\nWrote {OUT / 'cz_results.csv'}")
    return df, fits


# ---------------------------------------------------------------
# Plot helpers
# ---------------------------------------------------------------
def plot_profiles(fits: dict, methods: list[str], out_path: Path,
                  *, depth_range=(-200, 1500), title_prefix=""):
    n = len(fits)
    cols = 3
    rows = max(1, int(np.ceil(n / cols)))
    fig, axes = plt.subplots(rows, cols, figsize=(15, 4 * rows), sharex=True)
    axes = np.atleast_1d(axes).ravel()
    colors = plt.get_cmap("tab10").colors
    for ax, (sid, d) in zip(axes, fits.items()):
        xyz = d["_xyz"]
        for j, m in enumerate(methods):
            surf = d.get(m)
            if surf is None:
                continue
            c, dd = depth_profile(xyz, surf, bin_um=20, depth_range=depth_range)
            if dd.max() > 0:
                ax.plot(c, dd / dd.max(), color=colors[j % len(colors)],
                        lw=1.2, label=m)
        ax.axvline(0, color="k", lw=0.5)
        ax.set_title(f"{title_prefix}{sid}")
        ax.set_xlabel("depth from pia (um)")
        ax.set_ylabel("normalized density")
        ax.set_xlim(depth_range)
        ax.legend(fontsize=6, loc="upper right")
    for ax in axes[len(fits):]:
        ax.axis("off")
    fig.tight_layout()
    fig.savefig(out_path, dpi=120)
    plt.close(fig)
    print(f"Saved {out_path}")


