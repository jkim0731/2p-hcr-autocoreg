def load_cz_image(s):
    import tifffile
    candidates = list(s.coreg_dir.glob("*reg-dim-swapped.ome.tif"))
    if not candidates:
        candidates = list(s.coreg_dir.glob("*zstack.tif"))
    if not candidates:
        return None
    img = tifffile.imread(str(candidates[0]))
    while img.ndim > 3 and img.shape[0] == 1:
        img = img[0]
    return img


