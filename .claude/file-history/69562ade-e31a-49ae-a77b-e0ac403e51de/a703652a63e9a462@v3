# Core: per-column top-of-signal inside an arbitrary (low, high) band
# ------------------------------------------------------------------
def _per_column_top_in_band(
    vols_sub, xy_um_sub, z_um, xx, yy,
    z_low, z_high,
    relative_margin, min_signal_abs_frac, min_thick_um,
):
    """Return per-column top-of-signal (Y, X) µm map, NaN where no signal.

    `vols_sub` is a list of (Z, Ys, Xs) arrays (one per channel at the
    same spatial downsampling). `z_low`, `z_high` are (Ys, Xs) arrays:
    per-column search limits in µm.
    """
    Zs = vols_sub[0].shape[0]
    z_axis = np.arange(Zs, dtype=np.float32) * z_um
    band_mask = (z_axis[:, None, None] >= z_low[None]) & \
                (z_axis[:, None, None] <= z_high[None])
    evidence = vols_sub[0].copy()
    for v in vols_sub[1:]:
        np.maximum(evidence, v, out=evidence)
    in_band_ev = np.where(band_mask, evidence, np.nan).astype(np.float32)
    with np.errstate(all="ignore"):
        col_bg = np.nanpercentile(in_band_ev, 10, axis=0)
        col_max = np.nanpercentile(in_band_ev, 99, axis=0)
    dyn = col_max - col_bg
    global_dyn = float(np.nanpercentile(dyn, 95))
    abs_floor = float(min_signal_abs_frac * global_dyn)
    col_valid = np.isfinite(dyn) & (dyn >= abs_floor)
    thr = col_bg + relative_margin * dyn
    above = (evidence > thr[None, :, :]) & band_mask & col_valid[None, :, :]
    k = max(1, int(round(min_thick_um / z_um)))
    if Zs < k + 1:
        return None
    cum = np.cumsum(above.astype(np.int32), axis=0)
    win = cum[k - 1:].copy()
    win[1:] -= cum[:-k]
    is_start = win == k
    has_any = is_start.any(axis=0)
    if not has_any.any():
        return None
    first_z_idx = np.argmax(is_start, axis=0)
    top_z = np.full_like(col_bg, np.nan)
    top_z[has_any] = (first_z_idx[has_any] + (k - 1) // 2) * z_um
    return top_z


def _load_multichannel(s, level=4, xy_stride_um=10.0):
    """Return (vols_sub list, xx, yy, xy_um_sub, z_um)."""
    channels = list_hcr_channels(s)
    vols = []
    xy_um = z_um = None
    for ch in channels:
        try:
            v, xy_um, z_um = load_hcr_volume(s, channel=ch, level=level)
        except FileNotFoundError:
            continue
        vols.append(v.astype(np.float32, copy=False))
    sx = max(1, int(round(xy_stride_um / xy_um)))
    sy = max(1, int(round(xy_stride_um / xy_um)))
    vols_sub = [v[:, ::sy, ::sx] for v in vols]
    _, Ys, Xs = vols_sub[0].shape
    xs_um = np.arange(Xs) * sx * xy_um
    ys_um = np.arange(Ys) * sy * xy_um
    xx, yy = np.meshgrid(xs_um, ys_um)
    return vols_sub, xx, yy, sx * xy_um, z_um, channels


def _clamp_to_roi_envelope(fit, hcr_xyz, safety_offset_um=3.0):
    """Lift surface so no density-filtered 120 µm tile min-z sits above
    it; subtract a safety offset."""
    keep = filter_in_tissue(hcr_xyz, radius_um=30.0, min_neighbors=3)
    pts = hcr_xyz[keep]
    if len(pts) < 50:
        return fit, 0.0
    pxs, pys, pzs = pts[:, 0], pts[:, 1], pts[:, 2]
    xb = (pxs // 120.0).astype(int); yb = (pys // 120.0).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": pxs, "y": pys, "z": pzs})
    agg = df.groupby("k").agg(x=("x", "median"), y=("y", "median"),
                              z=("z", lambda v: float(np.quantile(v, 0.02))),
                              n=("z", "size"))
    agg = agg[agg["n"] >= 5]
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    plane_z = (fit["a"] * tx + fit["b"] * ty + fit["c"]
               + fit.get("p", 0) * tx * tx + fit.get("q", 0) * tx * ty
               + fit.get("r", 0) * ty * ty)
    deficit = plane_z - tz
    pos = deficit[deficit > 0]
    lift = float(pos.max()) if len(pos) else 0.0
    fit = dict(fit)
    fit["c"] = float(fit["c"] - lift - safety_offset_um)
    return fit, lift


def _surf_z(s, x, y):
    if s.get("type") == "grid":
        g = s["grid"]; xs = s["xs_um"]; ys = s["ys_um"]
        xf = np.asarray(x, dtype=np.float32)
        yf = np.asarray(y, dtype=np.float32)
        ix = np.clip(np.searchsorted(xs, xf) - 1, 0, len(xs) - 2)
        iy = np.clip(np.searchsorted(ys, yf) - 1, 0, len(ys) - 2)
        fx = np.clip((xf - xs[ix]) / (xs[ix + 1] - xs[ix]), 0.0, 1.0)
        fy = np.clip((yf - ys[iy]) / (ys[iy + 1] - ys[iy]), 0.0, 1.0)
        return ((1 - fx) * (1 - fy) * g[iy, ix]
                + fx * (1 - fy) * g[iy, ix + 1]
                + (1 - fx) * fy * g[iy + 1, ix]
                + fx * fy * g[iy + 1, ix + 1])
    return (s["a"] * x + s["b"] * y + s["c"]
            + s.get("p", 0) * x * x + s.get("q", 0) * x * y
            + s.get("r", 0) * y * y
            + s.get("cx3", 0) * x * x * x
            + s.get("cy3", 0) * y * y * y
            + s.get("cx2y", 0) * x * x * y
            + s.get("cxy2", 0) * x * y * y)


def _robust_cubic_fit(xs, ys, zs, max_iter: int = 8):
    """IRLS-Huber bicubic fit:
    z = a*x + b*y + c + p*x^2 + q*x*y + r*y^2
        + cx3*x^3 + cy3*y^3 + cx2y*x^2*y + cxy2*x*y^2
    Coordinate-centered for conditioning; coefficients returned in the
    original (x, y) frame — plus centered residual std for diagnostics.
    """
    import math
    xs = np.asarray(xs, dtype=float)
    ys = np.asarray(ys, dtype=float)
    zs = np.asarray(zs, dtype=float)
    x0 = float(xs.mean()); y0 = float(ys.mean())
    u = xs - x0; v = ys - y0
    X = np.column_stack([
        u, v, u * u, u * v, v * v,
        u**3, v**3, (u**2) * v, u * (v**2),
        np.ones_like(u),
    ])
    beta = np.linalg.lstsq(X, zs, rcond=None)[0]
    for _ in range(max_iter):
        resid = zs - X @ beta
        sigma = 1.4826 * np.median(np.abs(resid - np.median(resid)))
        if sigma < 1e-6:
            break
        w = np.where(np.abs(resid) <= 1.345 * sigma, 1.0,
                     1.345 * sigma / np.abs(resid))
        sw = np.sqrt(w)
        beta = np.linalg.lstsq(sw[:, None] * X, sw * zs, rcond=None)[0]
    au, bv, p, q, r, cx3, cy3, cx2y, cxy2, cuv = beta
    # Convert centered coeffs to absolute coordinates
    # z(x, y) = sum coeffs in (x-x0), (y-y0). Rather than derive
    # analytically, we store (x0, y0) and evaluate centered.
    return {
        # keep centered representation for evaluation
        "cent_x0": x0, "cent_y0": y0,
        "cent_a": float(au), "cent_b": float(bv),
        "cent_p": float(p), "cent_q": float(q), "cent_r": float(r),
        "cent_cx3": float(cx3), "cent_cy3": float(cy3),
        "cent_cx2y": float(cx2y), "cent_cxy2": float(cxy2),
        "cent_c": float(cuv),
        "tilt_deg": float(math.degrees(math.atan(math.hypot(au, bv)))),
        "residual_std_um": float(np.std(zs - X @ beta)),
        # the single linear "a, b, c" are the tilt+intercept at the centroid
        # under the centered representation, so _surf_z() cannot use them.
        # Callers should use _surf_z_cubic() instead.
    }


def _surf_z_cubic(s, x, y):
    """Evaluate a cubic fit produced by `_robust_cubic_fit`."""
    u = x - s["cent_x0"]; v = y - s["cent_y0"]
    return (s["cent_a"] * u + s["cent_b"] * v + s["cent_c"]
            + s["cent_p"] * u * u + s["cent_q"] * u * v
            + s["cent_r"] * v * v
            + s["cent_cx3"] * u ** 3 + s["cent_cy3"] * v ** 3
            + s["cent_cx2y"] * (u ** 2) * v
            + s["cent_cxy2"] * u * (v ** 2))


