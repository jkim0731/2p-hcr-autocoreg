def main():
    s = load_subject(SID)
    hcr_um = hcr_px_to_um(
        s.hcr_centroids[["z_px", "y_px", "x_px"]].values, s)
    hcr_xyz = hcr_um[:, [2, 1, 0]]

    # Load combined MIP/full-volume once for N13's N4-plane anchor
    vol, xy_um, z_um, _ = load_hcr_combined(s, level=4)

    results = {}
    stats = []
    for name, fn in VARIANTS:
        print(f"\n--- {name} ---")
        try:
            if name in ("N6_quad",):
                surf = v_n6(s, hcr_xyz)
            elif name == "N11_band150":
                surf = v_n11(s, hcr_xyz)
            else:
                surf = fn(s, hcr_xyz, vol, xy_um, z_um)
        except Exception as e:
            print(f"  FAILED: {e!r}")
            surf = None
        if surf is None:
            print("  None")
            continue
        q = quality_metrics(hcr_xyz, surf)
        print(f"  c={surf.get('c'):.1f}  tilt={surf.get('tilt_deg',0):.2f}  "
              f"above%={q['above_frac']*100:.3f}  "
              f"onset={q['onset_depth_um']}  "
              f"x_spread={q['onset_x_spread']}  y_spread={q['onset_y_spread']}")
        results[name] = surf
        stats.append({
            "method": name,
            "c_um": surf.get("c"),
            "tilt_deg": surf.get("tilt_deg"),
            "clamp_lift_um": surf.get("clamp_lift_um"),
            **q,
        })

    stats_df = pd.DataFrame(stats)
    stats_df.to_csv(
        OUT / f"explore_{SID}_stats.csv", index=False)
    print(f"\nWrote {OUT / f'explore_{SID}_stats.csv'}")
    print(stats_df[["method", "c_um", "tilt_deg", "above_frac",
                    "onset_depth_um", "onset_x_spread",
                    "onset_y_spread"]].to_string(index=False))

    # -----------------------------
    # Figure
    # -----------------------------
    y0 = float(np.median(hcr_xyz[:, 1]))
    # Build multi-channel combined MIP at y0 slab
    channels = list_hcr_channels(s)
    half = 40.0
    mips = []
    xy_mip = z_mip = None
    for ch in channels:
        try:
            mip, _, z_mip, xy_mip = load_hcr_y_slab(
                s, channel=ch, y_center_um=y0, half_width_um=half, level=4)
        except FileNotFoundError:
            continue
        m = mip.astype(np.float32)
        lo, hi = np.percentile(m, [1, 99.5])
        norm = np.clip((m - lo) / max(hi - lo, 1.0), 0.0, 1.0)
        mips.append(norm)
    max_mip = np.maximum.reduce(mips) if mips else None
    extent = (0, max_mip.shape[1] * xy_mip, max_mip.shape[0] * z_mip, 0)

    cmap = plt.get_cmap("tab10")
    fig = plt.figure(figsize=(16, 11))
    gs = fig.add_gridspec(3, 1, height_ratios=[3, 3, 2], hspace=0.3)

    # Panel 1: y-slab MIP with all surfaces overlaid
    ax1 = fig.add_subplot(gs[0])
    ax1.imshow(max_mip, extent=extent, cmap="gray",
               aspect="auto", interpolation="nearest")
    xs_line = np.linspace(0, max_mip.shape[1] * xy_mip, 500)
    ys_line = np.full_like(xs_line, y0)
    for j, (name, _) in enumerate(VARIANTS):
        surf = results.get(name)
        if surf is None:
            continue
        z_line = _surf_z(surf, xs_line, ys_line)
        ax1.plot(xs_line, z_line, lw=1.5, color=cmap(j % 10), label=name)
    in_slab = np.abs(hcr_xyz[:, 1] - y0) <= half
    ax1.scatter(hcr_xyz[in_slab, 0], hcr_xyz[in_slab, 2],
                s=1.5, c="cyan", alpha=0.35)
    ax1.set_title(f"{SID}  y={y0:.0f} µm slab  (multi-channel max MIP)")
    ax1.set_xlabel("x (µm)"); ax1.set_ylabel("z (µm)")
    ax1.legend(fontsize=7, ncol=3, loc="lower left")

    # Panel 2: same MIP, surfaces only (so lines are visible without clutter)
    ax2 = fig.add_subplot(gs[1])
    ax2.imshow(max_mip, extent=extent, cmap="gray",
               aspect="auto", interpolation="nearest", alpha=0.55)
    for j, (name, _) in enumerate(VARIANTS):
        surf = results.get(name)
        if surf is None:
            continue
        z_line = _surf_z(surf, xs_line, ys_line)
        ax2.plot(xs_line, z_line, lw=1.8, color=cmap(j % 10), label=name)
    ax2.set_title("Surfaces only (same slab)")
    ax2.set_xlabel("x (µm)"); ax2.set_ylabel("z (µm)")
    ax2.legend(fontsize=7, ncol=3, loc="lower left")

    # Panel 3: depth profiles
    ax3 = fig.add_subplot(gs[2])
    for j, (name, _) in enumerate(VARIANTS):
        surf = results.get(name)
        if surf is None:
            continue
        c, dens = depth_profile(
            hcr_xyz, surf, bin_um=20, depth_range=(-200, 1200))
        if dens.max() > 0:
            ax3.plot(c, dens / dens.max(), lw=1.3,
                     color=cmap(j % 10), label=name)
    ax3.axvline(0, color="k", lw=0.6)
    ax3.set_title("ROI density vs depth (normalized)")
    ax3.set_xlabel("depth from pia (µm)")
    ax3.set_ylabel("norm. density")
    ax3.legend(fontsize=7, ncol=3, loc="upper right")

    fig.suptitle(
        f"Subject {SID} — surface-estimation variants (target: close gap at x~2000 µm)",
        fontsize=12, y=0.995)
    fig.tight_layout(rect=(0, 0, 1, 0.98))
    out = FIG / f"explore_{SID}.png"
    fig.savefig(out, dpi=120)
    plt.close(fig)
    print(f"Saved {out}")


