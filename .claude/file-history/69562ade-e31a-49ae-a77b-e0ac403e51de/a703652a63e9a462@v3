def v_n14_iterative(s, hcr_xyz, band1=150.0, band2=80.0,
                    relative_margin=0.25, min_signal_abs_frac=0.20,
                    min_thick_um=10.0):
    """N14: iterate N11 — first pass with ±band1 around N6 anchor, then
    second pass with tighter ±band2 around the first fit. Final ROI
    clamp."""
    anchor = roi_quadratic_ceiling(
        hcr_xyz, safety_offset_um=3.0, max_residual_quantile=1.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    # First pass
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band1; z_high = anchor_zz + band1
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    fit1 = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    # Second pass: re-anchor to fit1, tighter band
    anchor_zz2 = _surf_z(fit1, xx, yy)
    z_low2 = anchor_zz2 - band2; z_high2 = anchor_zz2 + band2
    top_z2 = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low2, z_high2,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z2 is None:
        return fit1
    mask2 = np.isfinite(top_z2)
    fit2 = _robust_quadratic_fit(
        xx[mask2].ravel(), yy[mask2].ravel(), top_z2[mask2].ravel())
    fit2, lift = _clamp_to_roi_envelope(fit2, hcr_xyz)
    fit2["method"] = f"N14_iter_b{int(band1)}_{int(band2)}"
    fit2["clamp_lift_um"] = lift
    return fit2


