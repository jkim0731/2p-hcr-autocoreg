        s, band_um=150.0, relative_margin=0.25)


def v_n12_asym(s, hcr_xyz, below_um=300.0, above_um=50.0,
               relative_margin=0.25, min_signal_abs_frac=0.20,
               min_thick_um=10.0):
    """N12: asymmetric deep band around N6 anchor.

    Search from (anchor - below_um) to (anchor + above_um). Lets the
    image find the real boundary when the anchor is too shallow.
    """
    anchor = roi_quadratic_ceiling(
        hcr_xyz, safety_offset_um=3.0, max_residual_quantile=1.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - below_um
    z_high = anchor_zz + above_um
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None
    fit = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    fit, lift = _clamp_to_roi_envelope(fit, hcr_xyz)
    fit["method"] = f"N12_asym_b{int(below_um)}_a{int(above_um)}"
    fit["clamp_lift_um"] = lift
    return fit


