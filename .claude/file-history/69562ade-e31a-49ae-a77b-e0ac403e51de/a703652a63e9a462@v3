    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - max_z_above_anchor
    z_high = anchor_zz + max_z_below_anchor
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um2, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None
    fit = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    fit, lift = _clamp_to_roi_envelope(fit, hcr_xyz)
    fit["method"] = "N16_n4_imgfirst_clamp"
    fit["clamp_lift_um"] = lift
    return fit


def v_n18_quad_plus_grid_residual(
    s, hcr_xyz, vol, xy_um, z_um_vol,
    band_um=150.0,
    residual_sigma_um=120.0,
    relative_margin=0.25,
    min_signal_abs_frac=0.20,
    min_thick_um=10.0,
    safety_offset_um=3.0,
):
    """N18: robust quadratic base fit + Gaussian-smoothed residual
    correction, both computed from per-column image tops.

    Handles global tilt/curvature via the quadratic (stable across all
    subjects, including 782149's 12° tilt) AND localized deviations
    via the smoothed residual (790322's x~2000 µm dip).
    """
    from scipy.ndimage import gaussian_filter
    anchor = roi_quadratic_ceiling(
        hcr_xyz, safety_offset_um=3.0, max_residual_quantile=1.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band_um; z_high = anchor_zz + band_um
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None
    # Base quadratic fit through column tops
    fit = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    # Residual field
    quad_zz = _surf_z(fit, xx, yy)
    resid = top_z - quad_zz
    # Weighted Gaussian smoothing, treating NaNs as zero-weight
    w = mask.astype(np.float32)
    r = np.where(mask, resid, 0.0).astype(np.float32)
    sigma_pix = float(residual_sigma_um / xy_um_sub)
    num = gaussian_filter(r * w, sigma=sigma_pix)
    den = gaussian_filter(w, sigma=sigma_pix)
    resid_smooth = np.where(den > 1e-6, num / np.clip(den, 1e-6, None), 0.0)
    # Final surface grid
    surf_grid = quad_zz + resid_smooth
    # ROI-envelope clamp
    keep = filter_in_tissue(hcr_xyz, radius_um=30.0, min_neighbors=3)
    pts = hcr_xyz[keep]
    clamp_lift = 0.0
    if len(pts) >= 50:
        pxs, pys, pzs = pts[:, 0], pts[:, 1], pts[:, 2]
        xb = (pxs // 120.0).astype(int); yb = (pys // 120.0).astype(int)
        key = yb * 100000 + xb
        df = pd.DataFrame({"k": key, "x": pxs, "y": pys, "z": pzs})
        agg = df.groupby("k").agg(x=("x", "median"), y=("y", "median"),
                                  z=("z", lambda v: float(np.quantile(v, 0.02))),
                                  n=("z", "size"))
        agg = agg[agg["n"] >= 5]
        tx, ty, tz_roi = agg["x"].values, agg["y"].values, agg["z"].values
        xs_row = xx[0, :]; ys_col = yy[:, 0]
        ix = np.clip(np.searchsorted(xs_row, tx) - 1, 0, len(xs_row) - 2)
        iy = np.clip(np.searchsorted(ys_col, ty) - 1, 0, len(ys_col) - 2)
        fx = (tx - xs_row[ix]) / (xs_row[ix + 1] - xs_row[ix])
        fy = (ty - ys_col[iy]) / (ys_col[iy + 1] - ys_col[iy])
        g = surf_grid
        z_at_tile = (
            (1 - fx) * (1 - fy) * g[iy, ix]
            + fx * (1 - fy) * g[iy, ix + 1]
            + (1 - fx) * fy * g[iy + 1, ix]
            + fx * fy * g[iy + 1, ix + 1]
        )
        deficit = z_at_tile - tz_roi
        pos = deficit[deficit > 0]
        clamp_lift = float(pos.max()) if len(pos) else 0.0
    surf_grid = surf_grid - clamp_lift - safety_offset_um
    return {
        "type": "grid",
        "grid": surf_grid.astype(np.float32),
        "xs_um": xx[0, :].astype(np.float32),
        "ys_um": yy[:, 0].astype(np.float32),
        "c": float(surf_grid.mean()),
        "tilt_deg": float(fit["tilt_deg"]),
        "method": f"N18_quad_plus_resid_sig{int(residual_sigma_um)}",
        "clamp_lift_um": clamp_lift,
        "safety_offset_um": safety_offset_um,
        "quad_fit": fit,
        "residual_rms_um": float(np.sqrt(np.mean(resid_smooth ** 2))),
    }


def v_n21_n4_quantile(
    s, hcr_xyz, vol, xy_um, z_um_vol,
    band_um=150.0,
    relative_margin=0.25,
    min_signal_abs_frac=0.20,
    min_thick_um=10.0,
    target_quantile=0.70,
    n_iter=30,
    safety_offset_um=3.0,
):
    """N21: N13-style N4-anchor + ±band column tops, but fit with
    QUANTILE REGRESSION at target_quantile (e.g. 0.7) instead of IRLS
    Huber.

    Motivation (user's note on diagnose_790322):
      - N13 has the best shape (x_spread 15). Tops track the surface
        including the dip. But IRLS-Huber fits the *bulk* of tops, which
        is biased SHALLOW by above-surface noise. Symmetric outlier
        rejection (N20) doesn't help: the noise is too abundant to be an
        "outlier" under Huber's symmetric loss.
      - Quantile regression at q=0.7 says "fit the surface such that 70%
        of tops are above it, i.e. run below the top 30%". Since shallow
        noise has small z (shallow) and real tops have larger z (at the
        tissue boundary), q=0.7 pushes the fit DEEPER — onto the real
        surface, away from the shallow noise.

    IRLS for quantile regression:
      w_i = q       if r_i > 0     (top is deeper than fit, keep going)
      w_i = 1 - q   if r_i < 0     (top is shallower than fit, down-weight)
      and a small eps to avoid division by zero.
    """
    import math
    anchor = image_with_roi_ceiling(
        hcr_xyz, vol, z_um_vol, xy_um,
        margin=0.005, safety_offset_um=0.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band_um; z_high = anchor_zz + band_um

    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None

    xs_fit = xx[mask].ravel()
    ys_fit = yy[mask].ravel()
    zs_fit = top_z[mask].ravel()

    # Quadratic design matrix in centered coordinates
    x0 = xs_fit.mean(); y0 = ys_fit.mean()
    u = xs_fit - x0; v = ys_fit - y0
    X = np.column_stack([u, v, u * u, u * v, v * v, np.ones_like(u)])

    # Initial LS fit (median-ish)
    beta = np.linalg.lstsq(X, zs_fit, rcond=None)[0]
    q = float(target_quantile)

    # IRLS for quantile regression
    for _ in range(n_iter):
        r = zs_fit - X @ beta
        abs_r = np.abs(r)
        eps = max(0.01 * float(np.median(abs_r) + 1e-6), 0.5)
        # Quantile weights: positive residuals (deeper tops) weighted by q,
        # negative residuals (shallow tops) by (1-q). Divided by |r|.
        w = np.where(r >= 0, q, 1.0 - q) / np.clip(abs_r, eps, None)
        sw = np.sqrt(w)
        beta_new = np.linalg.lstsq(sw[:, None] * X, sw * zs_fit, rcond=None)[0]
        if np.linalg.norm(beta_new - beta) < 1e-6:
            beta = beta_new
            break
        beta = beta_new
    a, b_, p, q_c, r_c, c_c = beta

    # Convert centered coefficients to absolute
    A = a - 2 * p * x0 - q_c * y0
    B = b_ - 2 * r_c * y0 - q_c * x0
    C = (c_c - a * x0 - b_ * y0
         + p * x0 * x0 + q_c * x0 * y0 + r_c * y0 * y0)
    fit = {
        "a": float(A), "b": float(B), "c": float(C),
        "p": float(p), "q": float(q_c), "r": float(r_c),
        "tilt_deg": float(math.degrees(math.atan(math.hypot(A, B)))),
    }
    # ROI clamp
    fit, lift = _clamp_to_roi_envelope(fit, hcr_xyz, safety_offset_um=safety_offset_um)
    fit["method"] = f"N21_n4_b{int(band_um)}_q{int(target_quantile * 100)}"
    fit["clamp_lift_um"] = lift
    fit["n_tops"] = int(mask.sum())
    fit["residual_median"] = float(np.median(zs_fit - X @ beta))
    return fit


def v_n20_n4_asymmetric(
    s, hcr_xyz, vol, xy_um, z_um_vol,
    band_um=150.0,
    relative_margin=0.35,
    min_signal_abs_frac=0.25,
    min_thick_um=20.0,
    shallow_reject_um=30.0,
    n_reject_iters=3,
    safety_offset_um=3.0,
):
    """N20: N13-style (N4 anchor, ±band, per-column tops) BUT with
    asymmetric outlier rejection — iteratively drop tops that sit
    significantly ABOVE the current fit (shallow outliers = above-surface
    noise). Confidence-weighted fit.

    Motivation (from diagnose_790322 row 2, user guidance):
      - N4 anchor gives the best overall *shape* (x_spread 15 vs 50 for
        N11). Per-column tops track the true surface including the dip.
      - But the quadratic fit sits too shallow because some yellow tops
        are above the tissue boundary (autofluorescence debris, column
        noise). IRLS down-weights outliers symmetrically; what we want
        is a ONE-SIDED rejection of shallow outliers so the fit goes
        where the deep majority of tops sits.

    Pipeline:
      1. N4 image-plane anchor.
      2. Per-column top-of-signal in ±band_um (stricter thresholds:
         higher relative_margin, longer min_thick_um, higher
         min_signal_abs_frac to reject thin/weak false positives).
      3. Weighted robust quadratic fit with iterative shallow-outlier
         rejection: at each iteration, drop columns whose (top_z -
         fit_z) < -shallow_reject_um (i.e. top is >shallow_reject_um
         shallower than fit = likely above-surface noise). Refit.
      4. ROI-envelope clamp.
    """
    anchor = image_with_roi_ceiling(
        hcr_xyz, vol, z_um_vol, xy_um,
        margin=0.005, safety_offset_um=0.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band_um; z_high = anchor_zz + band_um

    Zs = vols_sub[0].shape[0]
    z_axis = np.arange(Zs, dtype=np.float32) * z_um
    band_mask = (z_axis[:, None, None] >= z_low[None]) & \
                (z_axis[:, None, None] <= z_high[None])
    evidence = vols_sub[0].copy()
    for v in vols_sub[1:]:
        np.maximum(evidence, v, out=evidence)
    in_band_ev = np.where(band_mask, evidence, np.nan).astype(np.float32)
    with np.errstate(all="ignore"):
        col_bg = np.nanpercentile(in_band_ev, 10, axis=0)
        col_max = np.nanpercentile(in_band_ev, 99, axis=0)
    dyn = col_max - col_bg
    global_dyn = float(np.nanpercentile(dyn, 95))
    abs_floor = float(min_signal_abs_frac * global_dyn)
    col_valid = np.isfinite(dyn) & (dyn >= abs_floor)
    thr = col_bg + relative_margin * dyn
    above = (evidence > thr[None, :, :]) & band_mask & col_valid[None, :, :]
    k = max(1, int(round(min_thick_um / z_um)))
    cum = np.cumsum(above.astype(np.int32), axis=0)
    win = cum[k - 1:].copy()
    win[1:] -= cum[:-k]
    is_start = win == k
    has_any = is_start.any(axis=0)
    first_z_idx = np.argmax(is_start, axis=0)
    top_z = np.full_like(col_bg, np.nan)
    top_z[has_any] = (first_z_idx[has_any] + (k - 1) // 2) * z_um

    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None

    xs_fit = xx[mask].ravel()
    ys_fit = yy[mask].ravel()
    zs_fit = top_z[mask].ravel()
    ws_fit = np.clip(
        (dyn[mask] / max(global_dyn, 1e-6)).ravel(), 0.05, 1.0)

    # Initial robust fit (Huber IRLS, symmetric)
    fit = _robust_quadratic_fit(xs_fit, ys_fit, zs_fit)
    kept = np.ones_like(zs_fit, dtype=bool)

    # Iterative ASYMMETRIC rejection: drop shallow outliers
    for it in range(n_reject_iters):
        fz = _surf_z(fit, xs_fit, ys_fit)
        resid = zs_fit - fz
        # Shallow outlier: top_z is >shallow_reject shallower than fit
        # (negative residual). Keep columns with resid >= -shallow_reject.
        new_kept = kept & (resid >= -float(shallow_reject_um))
        if new_kept.sum() < 50 or int(new_kept.sum()) == int(kept.sum()):
            kept = new_kept
            break
        kept = new_kept
        # Re-fit, confidence-weighted (so deep tops with high dyn dominate)
        xs_k = xs_fit[kept]; ys_k = ys_fit[kept]
        zs_k = zs_fit[kept]; ws_k = ws_fit[kept]
        # Huber IRLS with weights baked in: multiply X and y by sqrt(w)
        import math
        u = xs_k - xs_k.mean(); v = ys_k - ys_k.mean()
        X = np.column_stack([u, v, u * u, u * v, v * v, np.ones_like(u)])
        sw0 = np.sqrt(ws_k)
        beta = np.linalg.lstsq(sw0[:, None] * X, sw0 * zs_k, rcond=None)[0]
        for _ in range(6):
            r = zs_k - X @ beta
            sigma = 1.4826 * np.median(np.abs(r - np.median(r)))
            if sigma < 1e-6:
                break
            w_h = np.where(np.abs(r) <= 1.345 * sigma, 1.0,
                           1.345 * sigma / np.clip(np.abs(r), 1e-6, None))
            sw = np.sqrt(ws_k * w_h)
            beta = np.linalg.lstsq(sw[:, None] * X, sw * zs_k, rcond=None)[0]
        a, b_, p, q, r_c, c_c = beta
        # Convert centered coefficients to absolute (same form as
        # _robust_quadratic_fit output)
        x0 = xs_k.mean(); y0 = ys_k.mean()
        # z(x,y) = a*(x-x0) + b*(y-y0) + c + p*(x-x0)^2 + q*(x-x0)*(y-y0) + r*(y-y0)^2
        # Expand to z = A*x + B*y + C + P*x^2 + Q*x*y + R*y^2
        A = a - 2 * p * x0 - q * y0
        B = b_ - 2 * r_c * y0 - q * x0
        C = c_c - a * x0 - b_ * y0 + p * x0 * x0 + q * x0 * y0 + r_c * y0 * y0
        P = p; Q = q; R = r_c
        fit = {
            "a": float(A), "b": float(B), "c": float(C),
            "p": float(P), "q": float(Q), "r": float(R),
            "tilt_deg": float(math.degrees(math.atan(math.hypot(A, B)))),
        }

    fit, lift = _clamp_to_roi_envelope(fit, hcr_xyz, safety_offset_um=safety_offset_um)
    fit["method"] = (f"N20_n4_b{int(band_um)}_rm{relative_margin:g}"
                     f"_mt{int(min_thick_um)}_rej{int(shallow_reject_um)}")
    fit["clamp_lift_um"] = lift
    fit["n_tops_used"] = int(kept.sum())
    fit["n_tops_total"] = int(mask.sum())
    return fit


def v_n19_selective_residual(
    s, hcr_xyz, vol, xy_um, z_um_vol,
    band_below_um=250.0, band_above_um=100.0,
    residual_sigma_um=120.0,
    resid_mag_threshold_um=20.0,
    resid_positive_only=True,
    relative_margin=0.25,
    min_signal_abs_frac=0.20,
    min_thick_um=10.0,
    safety_offset_um=3.0,
    anchor_source="n6",
):
    """N19: quadratic base + SELECTIVE, confidence-weighted residual.

    Design motivation:
      - N11 (quadratic) misses 790322's x~2000 µm dip: the dip is a
        localized ~80 µm deviation that a global quadratic can't fit.
      - N17/N18 (always-on residual correction) fix 790322 but slightly
        shift the surface inside the tissue on 782149 (and 788406)
        because Gaussian smoothing averages in noisy-deep image tops.

    N19's compromise:
      1. Search a DEEP ASYMMETRIC band (-250, +100) around N6 anchor so
         the 790322 dip actually reaches the real boundary (300 µm below
         the global quad was the only setup that caught it in the
         diagnostic).
      2. Fit a robust quadratic to the column tops (base).
      3. Compute residuals = top_z - quad_z.
      4. Weight columns by dynamic range (confidence) before smoothing.
      5. Suppress residuals with |magnitude| below `resid_mag_threshold`
         so noise stays flat (→ falls back to the quadratic on
         well-behaved subjects).
      6. Optionally only accept POSITIVE residuals (i.e. surface
         deeper than quadratic) — this captures dips without allowing
         noise to lift the surface above the robust quadratic.
      7. Final ROI-envelope clamp.
    """
    from scipy.ndimage import gaussian_filter
    if anchor_source == "n4":
        anchor = image_with_roi_ceiling(
            hcr_xyz, vol, z_um_vol, xy_um,
            margin=0.005, safety_offset_um=0.0)
    else:
        anchor = roi_quadratic_ceiling(
            hcr_xyz, safety_offset_um=3.0, max_residual_quantile=1.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band_below_um
    z_high = anchor_zz + band_above_um

    # Recompute per-column tops AND dynamic-range confidence
    Zs = vols_sub[0].shape[0]
    z_axis = np.arange(Zs, dtype=np.float32) * z_um
    band_mask = (z_axis[:, None, None] >= z_low[None]) & \
                (z_axis[:, None, None] <= z_high[None])
    evidence = vols_sub[0].copy()
    for v in vols_sub[1:]:
        np.maximum(evidence, v, out=evidence)
    in_band_ev = np.where(band_mask, evidence, np.nan).astype(np.float32)
    with np.errstate(all="ignore"):
        col_bg = np.nanpercentile(in_band_ev, 10, axis=0)
        col_max = np.nanpercentile(in_band_ev, 99, axis=0)
    dyn = col_max - col_bg
    global_dyn = float(np.nanpercentile(dyn, 95))
    abs_floor = float(min_signal_abs_frac * global_dyn)
    col_valid = np.isfinite(dyn) & (dyn >= abs_floor)
    thr = col_bg + relative_margin * dyn
    above = (evidence > thr[None, :, :]) & band_mask & col_valid[None, :, :]
    k = max(1, int(round(min_thick_um / z_um)))
    cum = np.cumsum(above.astype(np.int32), axis=0)
    win = cum[k - 1:].copy()
    win[1:] -= cum[:-k]
    is_start = win == k
    has_any = is_start.any(axis=0)
    first_z_idx = np.argmax(is_start, axis=0)
    top_z = np.full_like(col_bg, np.nan)
    top_z[has_any] = (first_z_idx[has_any] + (k - 1) // 2) * z_um
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None

    # Robust quadratic base
    fit = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    quad_zz = _surf_z(fit, xx, yy)
    resid = top_z - quad_zz

    # Confidence weights: normalized dynamic range, clipped
    conf = np.where(mask, np.clip(dyn / max(global_dyn, 1e-6), 0.0, 1.0), 0.0)
    # Weighted smoothing of residuals (confidence-weighted)
    r = np.where(mask, resid, 0.0).astype(np.float32)
    w = conf.astype(np.float32)
    sigma_pix = float(residual_sigma_um / xy_um_sub)
    num = gaussian_filter(r * w, sigma=sigma_pix)
    den = gaussian_filter(w, sigma=sigma_pix)
    resid_smooth = np.where(den > 1e-3, num / np.clip(den, 1e-3, None), 0.0)

    # Suppress small residuals (below threshold) — HARD gate: keep full
    # residual where |r| > threshold, else zero. Soft thresholding shaved
    # the true correction at the 790322 dip (peak ~80 µm became 65).
    thr_um = float(resid_mag_threshold_um)
    gate = np.abs(resid_smooth) > thr_um
    resid_gated = np.where(gate, resid_smooth, 0.0)
    if resid_positive_only:
        resid_gated = np.maximum(resid_gated, 0.0)

    surf_grid = quad_zz + resid_gated

    # ROI-envelope clamp
    keep = filter_in_tissue(hcr_xyz, radius_um=30.0, min_neighbors=3)
    pts = hcr_xyz[keep]
    clamp_lift = 0.0
    if len(pts) >= 50:
        pxs, pys, pzs = pts[:, 0], pts[:, 1], pts[:, 2]
        xb = (pxs // 120.0).astype(int); yb = (pys // 120.0).astype(int)
        key = yb * 100000 + xb
        df = pd.DataFrame({"k": key, "x": pxs, "y": pys, "z": pzs})
        agg = df.groupby("k").agg(x=("x", "median"), y=("y", "median"),
                                  z=("z", lambda v: float(np.quantile(v, 0.02))),
                                  n=("z", "size"))
        agg = agg[agg["n"] >= 5]
        tx, ty, tz_roi = agg["x"].values, agg["y"].values, agg["z"].values
        xs_row = xx[0, :]; ys_col = yy[:, 0]
        ix = np.clip(np.searchsorted(xs_row, tx) - 1, 0, len(xs_row) - 2)
        iy = np.clip(np.searchsorted(ys_col, ty) - 1, 0, len(ys_col) - 2)
        fx = (tx - xs_row[ix]) / (xs_row[ix + 1] - xs_row[ix])
        fy = (ty - ys_col[iy]) / (ys_col[iy + 1] - ys_col[iy])
        g = surf_grid
        z_at_tile = (
            (1 - fx) * (1 - fy) * g[iy, ix]
            + fx * (1 - fy) * g[iy, ix + 1]
            + (1 - fx) * fy * g[iy + 1, ix]
            + fx * fy * g[iy + 1, ix + 1]
        )
        deficit = z_at_tile - tz_roi
        pos = deficit[deficit > 0]
        clamp_lift = float(pos.max()) if len(pos) else 0.0
    surf_grid = surf_grid - clamp_lift - safety_offset_um

    return {
        "type": "grid",
        "grid": surf_grid.astype(np.float32),
        "xs_um": xx[0, :].astype(np.float32),
        "ys_um": yy[:, 0].astype(np.float32),
        "c": float(surf_grid.mean()),
        "tilt_deg": float(fit["tilt_deg"]),
        "method": (f"N19_sel_b{int(band_below_um)}_{int(band_above_um)}"
                   f"_sig{int(residual_sigma_um)}"
                   f"_thr{int(resid_mag_threshold_um)}"
                   f"{'_pos' if resid_positive_only else ''}"),
        "clamp_lift_um": clamp_lift,
        "safety_offset_um": safety_offset_um,
        "quad_fit": fit,
        "resid_gated_max": float(np.nanmax(np.abs(resid_gated))),
    }


def v_n17_grid_smooth(s, hcr_xyz, vol, xy_um, z_um_vol,
                      band1_below=150.0, band1_above=150.0,
                      smooth_sigma_um=100.0,
                      relative_margin=0.25,
                      min_signal_abs_frac=0.20, min_thick_um=10.0,
                      anchor_source="n4",
                      safety_offset_um=3.0):
    """N17: non-parametric surface — Gaussian-smoothed per-column
    top-of-signal grid.

    Pipeline:
      1. Build anchor (N4 image plane or N6 quadratic — configurable).
      2. Per-column search in (anchor - below, anchor + above) for
         top-of-signal.
      3. Fill NaN columns by the median of valid columns (very coarse —
         only used where the image has truly no signal).
      4. Gaussian-smooth the resulting (Y, X) µm surface grid with
         `smooth_sigma_um`.
      5. ROI-envelope ceiling clamp against 120-µm-tile ROI min-z.
      6. Return a grid-based surface object: {type: "grid", grid, xs, ys}.
    """
    from scipy.ndimage import gaussian_filter
    if anchor_source == "n4":
        anchor = image_with_roi_ceiling(
            hcr_xyz, vol, z_um_vol, xy_um,
            margin=0.005, safety_offset_um=0.0)
    else:
        anchor = roi_quadratic_ceiling(
            hcr_xyz, safety_offset_um=3.0, max_residual_quantile=1.0)
    if anchor is None:
        return None
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    anchor_zz = _surf_z(anchor, xx, yy)
    z_low = anchor_zz - band1_below
    z_high = anchor_zz + band1_above
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    # Fill NaNs with the median of nearby valid columns via iterative
    # local mean (cheap inpainting).
    tz = top_z.copy()
    valid = np.isfinite(tz)
    if valid.sum() < 50:
        return None
    median_val = float(np.nanmedian(tz))
    tz[~valid] = median_val
    # Smooth
    sigma_pix = float(smooth_sigma_um / xy_um_sub)
    tz_smooth = gaussian_filter(tz.astype(np.float32), sigma=sigma_pix)
    # Where we inpainted, also apply weighted smoothing against the
    # valid mask to avoid introducing a constant-plateau bias.
    w = valid.astype(np.float32)
    num = gaussian_filter(tz * w, sigma=sigma_pix)
    den = gaussian_filter(w, sigma=sigma_pix)
    tz_smooth = np.where(den > 1e-6, num / np.clip(den, 1e-6, None),
                         tz_smooth)

    # ROI-envelope clamp on the grid
    keep = filter_in_tissue(hcr_xyz, radius_um=30.0, min_neighbors=3)
    pts = hcr_xyz[keep]
    clamp_lift = 0.0
    if len(pts) >= 50:
        pxs, pys, pzs = pts[:, 0], pts[:, 1], pts[:, 2]
        xb = (pxs // 120.0).astype(int); yb = (pys // 120.0).astype(int)
        key = yb * 100000 + xb
        df = pd.DataFrame({"k": key, "x": pxs, "y": pys, "z": pzs})
        agg = df.groupby("k").agg(x=("x", "median"), y=("y", "median"),
                                  z=("z", lambda v: float(np.quantile(v, 0.02))),
                                  n=("z", "size"))
        agg = agg[agg["n"] >= 5]
        tx, ty, tz_roi = agg["x"].values, agg["y"].values, agg["z"].values
        # Sample surface at tile centers (bilinear from grid)
        xs_row = xx[0, :]; ys_col = yy[:, 0]
        ix = np.clip(np.searchsorted(xs_row, tx) - 1, 0, len(xs_row) - 2)
        iy = np.clip(np.searchsorted(ys_col, ty) - 1, 0, len(ys_col) - 2)
        fx = (tx - xs_row[ix]) / (xs_row[ix + 1] - xs_row[ix])
        fy = (ty - ys_col[iy]) / (ys_col[iy + 1] - ys_col[iy])
        g = tz_smooth
        z_at_tile = (
            (1 - fx) * (1 - fy) * g[iy, ix]
            + fx * (1 - fy) * g[iy, ix + 1]
            + (1 - fx) * fy * g[iy + 1, ix]
            + fx * fy * g[iy + 1, ix + 1]
        )
        deficit = z_at_tile - tz_roi
        pos = deficit[deficit > 0]
        clamp_lift = float(pos.max()) if len(pos) else 0.0
    tz_smooth = tz_smooth - clamp_lift - safety_offset_um

    surf = {
        "type": "grid",
        "grid": tz_smooth.astype(np.float32),
        "xs_um": xx[0, :].astype(np.float32),
        "ys_um": yy[:, 0].astype(np.float32),
        "c": float(tz_smooth.mean()),
        "tilt_deg": 0.0,
        "method": f"N17_grid_sig{int(smooth_sigma_um)}_anc{anchor_source}",
        "clamp_lift_um": clamp_lift,
        "safety_offset_um": safety_offset_um,
    }
    return surf


def _grid_surface_z(surf, x, y):
    """Evaluate a grid surface at arbitrary (x, y) via bilinear interp."""
    g = surf["grid"]; xs = surf["xs_um"]; ys = surf["ys_um"]
    x = np.asarray(x, dtype=np.float32)
    y = np.asarray(y, dtype=np.float32)
    ix = np.clip(np.searchsorted(xs, x) - 1, 0, len(xs) - 2)
    iy = np.clip(np.searchsorted(ys, y) - 1, 0, len(ys) - 2)
    fx = np.clip((x - xs[ix]) / (xs[ix + 1] - xs[ix]), 0.0, 1.0)
    fy = np.clip((y - ys[iy]) / (ys[iy + 1] - ys[iy]), 0.0, 1.0)
    return ((1 - fx) * (1 - fy) * g[iy, ix]
            + fx * (1 - fy) * g[iy, ix + 1]
            + (1 - fx) * fy * g[iy + 1, ix]
            + fx * fy * g[iy + 1, ix + 1])


def v_n15_imgfirst(s, hcr_xyz, relative_margin=0.25,
                   min_signal_abs_frac=0.20, min_thick_um=10.0,
                   min_valid_z_um=0.0):
    """N15: purely image-first — no ROI anchor, no band. Per-column
    shallowest signal across the whole z range (clipped to column-wise
    [min_valid_z_um, zmax]). Then robust quadratic, then ROI clamp.

    Acts as a baseline: if multi-channel image evidence alone gives a
    clean top-of-signal, we should not need the band trick at all.
    """
    vols_sub, xx, yy, xy_um_sub, z_um, channels = _load_multichannel(s)
    Zs = vols_sub[0].shape[0]
    z_low = np.full_like(xx, min_valid_z_um, dtype=np.float32)
    z_high = np.full_like(xx, (Zs - 1) * z_um, dtype=np.float32)
    top_z = _per_column_top_in_band(
        vols_sub, xy_um_sub, z_um, xx, yy, z_low, z_high,
        relative_margin, min_signal_abs_frac, min_thick_um)
    if top_z is None:
        return None
    mask = np.isfinite(top_z)
    if mask.sum() < 50:
        return None
    fit = _robust_quadratic_fit(
        xx[mask].ravel(), yy[mask].ravel(), top_z[mask].ravel())
    fit, lift = _clamp_to_roi_envelope(fit, hcr_xyz)
    fit["method"] = "N15_imgfirst"
    fit["clamp_lift_um"] = lift
    return fit


