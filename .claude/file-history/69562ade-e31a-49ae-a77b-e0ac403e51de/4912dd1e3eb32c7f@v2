# ---------------------------------------------------------------
# HCR walkthrough — 782149
# ---------------------------------------------------------------
HCR_SID = "782149"
TILE_UM = 120.0
Q_FRAC = 0.02
SIGMA = 120.0
SAFETY = 5.0


def _hcr_envelope(xyz):
    keep = filter_in_tissue(xyz, radius_um=30.0, min_neighbors=3)
    pts = xyz[keep]
    xs, ys, zs = pts[:, 0], pts[:, 1], pts[:, 2]
    xb = (xs // TILE_UM).astype(int)
    yb = (ys // TILE_UM).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": xs, "y": ys, "z": zs})
    g = df.groupby("k")
    agg = g.agg(x=("x", "median"), y=("y", "median"),
                z=("z", lambda v: float(np.quantile(v, Q_FRAC))),
                n=("z", "size"))
    agg = agg[agg["n"] >= 5].reset_index(drop=True)
    return pts, agg


def walkthrough_hcr():
    s = load_subject(HCR_SID)
    hcr_um = hcr_px_to_um(
        s.hcr_centroids[["z_px", "y_px", "x_px"]].values, s)
    xyz = hcr_um[:, [2, 1, 0]]

    pts_filt, agg = _hcr_envelope(xyz)
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    quad = _robust_quadratic_fit(tx, ty, tz)
    quad_at_tile = (quad["a"] * tx + quad["b"] * ty + quad["c"]
                    + quad["p"] * tx * tx + quad["q"] * tx * ty
                    + quad["r"] * ty * ty)
    residuals = tz - quad_at_tile
    surf = roi_hybrid_quad_gauss_ceiling(
        xyz, sigma_um=SIGMA, safety_offset_um=SAFETY)

    # Show everything at one y-slab (median y).
    y0 = float(np.median(xyz[:, 1]))
    band = 40.0
    in_slab = np.abs(xyz[:, 1] - y0) <= band
    in_slab_filt = np.abs(pts_filt[:, 1] - y0) <= band
    tile_in_slab = np.abs(ty - y0) <= band

    mip, _, z_um, xy_um = load_hcr_y_slab(
        s, channel="488", y_center_um=y0, half_width_um=band, level=4)

    xs_line = np.linspace(float(xyz[:, 0].min()), float(xyz[:, 0].max()), 400)
    ys_line = np.full_like(xs_line, y0)
    quad_line = (quad["a"] * xs_line + quad["b"] * y0 + quad["c"]
                 + quad["p"] * xs_line * xs_line
                 + quad["q"] * xs_line * y0
                 + quad["r"] * y0 * y0)
    hybrid_line = _hybrid_surface_z(surf, xs_line, ys_line)

    fig, axes = plt.subplots(2, 3, figsize=(15, 8))

    # 1. All ROIs in slab
    ax = axes[0, 0]
    ax.scatter(xyz[in_slab, 0], xyz[in_slab, 2], s=1, c="steelblue", alpha=0.4)
    ax.set_title("1. All ROI centroids in slab\n(z vs x)")
    ax.invert_yaxis()
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")

    # 2. Density-filtered
    ax = axes[0, 1]
    ax.scatter(pts_filt[in_slab_filt, 0], pts_filt[in_slab_filt, 2],
               s=1, c="steelblue", alpha=0.4)
    ax.set_title(f"2. Density-filtered ROIs\n(kept {len(pts_filt)}/{len(xyz)})")
    ax.invert_yaxis()
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")

    # 3. Per-tile min-z envelope
    ax = axes[0, 2]
    ax.scatter(pts_filt[in_slab_filt, 0], pts_filt[in_slab_filt, 2],
               s=0.5, c="lightgray", alpha=0.4)
    ax.scatter(tx[tile_in_slab], tz[tile_in_slab],
               s=18, c="red", edgecolor="k", zorder=3)
    ax.set_title(f"3. Per-tile min-z envelope\n"
                 f"(120 um tiles, q={Q_FRAC}, {len(agg)} tiles)")
    ax.invert_yaxis()
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")

    # 4. Quadratic fit
    ax = axes[1, 0]
    ax.scatter(tx[tile_in_slab], tz[tile_in_slab],
               s=18, c="red", edgecolor="k", zorder=3, label="tile min-z")
    ax.plot(xs_line, quad_line, "b-", lw=1.6,
            label=f"quad fit (tilt={quad['tilt_deg']:.1f} deg)")
    ax.set_title("4. Robust quadratic base fit")
    ax.invert_yaxis()
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")
    ax.legend(fontsize=7)

    # 5. Residuals + Gaussian correction
    ax = axes[1, 1]
    ax.axhline(0, color="k", lw=0.5)
    ax.scatter(tx[tile_in_slab], residuals[tile_in_slab],
               s=14, c="red", edgecolor="k", label="tile residual")
    # Gaussian-smoothed residual trace along x at y=y0
    res_line = _hybrid_surface_z(
        {**surf, "c": 0.0, "a": 0.0, "b": 0.0, "p": 0.0, "q": 0.0, "r": 0.0},
        xs_line, ys_line,
    )
    ax.plot(xs_line, res_line, "g-", lw=1.5,
            label=f"Gaussian smooth (sigma={SIGMA:.0f} um)")
    ax.set_title("5. Residuals + Gaussian correction")
    ax.set_xlabel("x (um)"); ax.set_ylabel("tile_z - quad (um)")
    ax.legend(fontsize=7)

    # 6. Final surface on MIP
    ax = axes[1, 2]
    plot_pia_overlay(
        ax, mip, z_um=z_um, x_um=xy_um, surface=surf,
        y_slab_um=y0, title="6. Final hybrid surface on MIP",
    )
    ax.scatter(xyz[in_slab, 0], xyz[in_slab, 2],
               s=0.7, c="cyan", alpha=0.4)
    leg = ax.get_legend()
    if leg: leg.remove()

    fig.suptitle(f"HCR protocol walkthrough - subject {HCR_SID}"
                 f" (y = {y0:.0f} um slab)", fontsize=12)
    fig.tight_layout(rect=(0, 0, 1, 0.97))
    out = FIG / "hcr_walkthrough.png"
    fig.savefig(out, dpi=120)
    plt.close(fig)
    print(f"Saved {out}")


# ---------------------------------------------------------------
# CZ walkthrough - 767022
# ---------------------------------------------------------------
CZ_SID = "767022"
CZ_TILE_UM = 80.0


def walkthrough_cz():
    s = load_subject(CZ_SID)
    cz_um = cz_px_to_um(
        s.cz_centroids[["z_px", "y_px", "x_px"]].values, s)
    xyz = cz_um[:, [2, 1, 0]]
    img = load_cz_image(s)

    base = estimate_pia_surface_from_image(
        img, s.cz_z_um, s.cz_xy_um,
        min_signal_abs=50.0, relative_margin=0.02,
    )
    surf = cz_image_with_roi_ceiling(
        xyz, img, s.cz_z_um, s.cz_xy_um,
        margin=0.02, safety_offset_um=3.0,
    )

    # Tile ROIs for step 3 visualization
    xs, ys, zs = xyz[:, 0], xyz[:, 1], xyz[:, 2]
    xb = (xs // CZ_TILE_UM).astype(int)
    yb = (ys // CZ_TILE_UM).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": xs, "y": ys, "z": zs})
    agg = df.groupby("k").agg(
        x=("x", "median"), y=("y", "median"),
        z=("z", "min"), n=("z", "size"))
    agg = agg[agg["n"] >= 3].reset_index(drop=True)
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values

    # Load a y-slab for the MIP backgrounds
    y_center_px = int(xyz[:, 1].mean() / s.cz_xy_um)
    mip, y_px, z_um, xy_um = load_cz_y_slab(
        s, y_center_px=y_center_px, half_width_px=20)
    y0 = y_px * xy_um
    in_slab = np.abs(xyz[:, 1] - y0) <= 15 * s.cz_xy_um
    tile_in_slab = np.abs(ty - y0) <= 15 * s.cz_xy_um

    xs_line = np.linspace(0, mip.shape[1] * xy_um, 300)
    base_line = base["a"] * xs_line + base["b"] * y0 + base["c"]
    final_line = surf["a"] * xs_line + surf["b"] * y0 + surf["c"]

    fig, axes = plt.subplots(2, 2, figsize=(12, 8))

    ax = axes[0, 0]
    extent = (0, mip.shape[1] * xy_um, mip.shape[0] * z_um, 0)
    vmin, vmax = np.percentile(mip, [1, 99.5])
    ax.imshow(mip, extent=extent, cmap="gray", vmin=vmin, vmax=vmax,
              aspect="auto", interpolation="nearest")
    ax.set_title("1. CZ z-stack MIP")
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")

    ax = axes[0, 1]
    ax.imshow(mip, extent=extent, cmap="gray", vmin=vmin, vmax=vmax,
              aspect="auto", interpolation="nearest")
    ax.plot(xs_line, base_line, "orange", lw=1.5,
            label=f"image plane (2% margin, tilt={base['tilt_deg']:.1f} deg)")
    ax.set_title("2. Image-based plane fit")
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")
    ax.legend(fontsize=7)

    ax = axes[1, 0]
    ax.imshow(mip, extent=extent, cmap="gray", vmin=vmin, vmax=vmax,
              aspect="auto", interpolation="nearest")
    ax.scatter(xyz[in_slab, 0], xyz[in_slab, 2],
               s=1, c="cyan", alpha=0.4)
    ax.scatter(tx[tile_in_slab], tz[tile_in_slab],
               s=18, c="red", edgecolor="k", zorder=3, label="tile min-z")
    ax.plot(xs_line, base_line, "orange", lw=1.2, label="image plane")
    ax.set_title(f"3. Per-tile ROI min-z (80 um tiles)")
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")
    ax.legend(fontsize=7)

    ax = axes[1, 1]
    ax.imshow(mip, extent=extent, cmap="gray", vmin=vmin, vmax=vmax,
              aspect="auto", interpolation="nearest")
    ax.scatter(xyz[in_slab, 0], xyz[in_slab, 2],
               s=1, c="cyan", alpha=0.4)
    ax.plot(xs_line, base_line, "orange", lw=1.0, alpha=0.7,
            label="image plane (before clamp)")
    ax.plot(xs_line, final_line, "red", lw=1.8,
            label=f"final (lift={surf['lift_um']:.1f} um, off=3 um)")
    ax.set_title("4. Ceiling clamp + safety - final surface")
    ax.set_xlabel("x (um)"); ax.set_ylabel("z (um)")
    ax.legend(fontsize=7)

    fig.suptitle(f"CZ protocol walkthrough - subject {CZ_SID}"
                 f" (y = {y0:.0f} um slab)", fontsize=12)
    fig.tight_layout(rect=(0, 0, 1, 0.97))
    out = FIG / "cz_walkthrough.png"
    fig.savefig(out, dpi=120)
    plt.close(fig)
    print(f"Saved {out}")


