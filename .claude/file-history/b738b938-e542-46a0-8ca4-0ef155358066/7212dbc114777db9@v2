"""
S11 / Step 6 — Stage-3 iterative-prediction LOSO model.

Stacks soft neighbor features on top of stage-2 v5 OOF predictions.

Inputs:
- Stage-2 v5 LOSO OOF 4-class probas per cell:
      cached_roi_quality/{sid}_stage2_4class_proba_v5.parquet
  (each cell's probas are from a model that did NOT see its subject's labels —
   safe to use as a feature for LOSO stage-3.)
- Stage-2 v5 LOSO OOF binary scores per cell:
      cached_roi_quality/{sid}_stage2_binary_score_v5.parquet
- Neighbor lists (long format, one row per touching pair):
      cached_roi_quality/{sid}_neighbors_v1.parquet
- Original v5 feature matrix:
      cached_roi_quality/{sid}_features_v{2,3_extra,4,5}.parquet

For each cell, we compute soft neighbor aggregates (mean / max / min over
touching neighbors of stage-2 OOF probas; n_touching, top_overlap_voxels;
optionally weighted by overlap_voxels). These are concatenated with v5
features (and within-subject percentile features) to train a LOSO LightGBM.

Outputs (suffix `_v1` = stage-3 v1):
    cached_roi_quality/{sid}_stage3_binary_score_v1.parquet
    cached_roi_quality/{sid}_stage3_4class_proba_v1.parquet
    cached_roi_quality/roi_quality_stage3_binary_v1.txt   (production model)
    cached_roi_quality/roi_quality_stage3_4class_v1.txt
    cached_roi_quality/roi_quality_stage3_meta_v1.json
    sessions/v3_S11_roi_quality/outputs/stage3/...
"""
from __future__ import annotations

import json
from pathlib import Path

import lightgbm as lgb
import numpy as np
import pandas as pd
from sklearn.metrics import (
    accuracy_score,
    average_precision_score,
    brier_score_loss,
    confusion_matrix,
    f1_score,
    roc_auc_score,
)

ROOT = Path("/root/capsule")
CACHE = ROOT / "code/dev_code/cached_roi_quality"
SESS = ROOT / "code/sessions/v3_S11_roi_quality"
OUT = SESS / "outputs/stage3"
LABEL_LOG = SESS / "outputs/roi_qc_actions.jsonl"

SUBJECTS = ["755252", "767018", "767022", "782149", "788406", "790322"]

CLASS_NAMES = ["bad", "bad_ok", "good", "merged"]
CLASS_TO_IDX = {c: i for i, c in enumerate(CLASS_NAMES)}
PROBA_COLS = [f"p_{c}" for c in CLASS_NAMES]

BINARY_POS = {"good", "bad_ok"}
BINARY_NEG = {"bad", "merged"}

DROP_FEATURES = {"hcr_id", "y", "label", "human_label", "sid"}

PCT_RANK_COLS = [
    "volume_um3_opened", "volume_vox_raw",
    "axis3d_lambda1_um2", "surface_area_um2_opened",
]

LGB_BINARY = dict(
    objective="binary", learning_rate=0.05, num_leaves=31,
    min_data_in_leaf=20, feature_fraction=0.85, bagging_fraction=0.85,
    bagging_freq=5, lambda_l2=1.0, is_unbalance=True,
    metric=["binary_logloss", "auc"], verbosity=-1, seed=20260430,
)
LGB_MULTI = dict(
    objective="multiclass", num_class=len(CLASS_NAMES), learning_rate=0.05,
    num_leaves=31, min_data_in_leaf=15, feature_fraction=0.85,
    bagging_fraction=0.85, bagging_freq=5, lambda_l2=1.0,
    metric=["multi_logloss"], verbosity=-1, seed=20260430,
)
N_ESTIMATORS = 400
EARLY_STOP = 30


def _load_label_log() -> pd.DataFrame:
    return pd.read_json(LABEL_LOG, lines=True)


def _active_labels(log: pd.DataFrame, sid: str) -> pd.DataFrame:
    sub = log[log["sid"].astype(str) == sid].copy()
    if sub.empty:
        return pd.DataFrame(columns=["hcr_id", "label"])
    tomb_ids: set[int] = set()
    if (sub["label"] == "_undone_").any():
        for _, r in sub[sub["label"] == "_undone_"].iterrows():
            ub = r.get("undoes") or {}
            try:
                tomb_ids.add(int(ub.get("hcr_id", -1)))
            except (TypeError, ValueError):
                pass
    sub = sub[sub["label"].isin(["good", "bad", "bad_ok", "merged", "unsure"])]
    sub = sub[~sub["hcr_id"].astype(int).isin(tomb_ids)]
    if "ts" in sub.columns:
        sub = sub.sort_values("ts")
    sub = sub.drop_duplicates(subset=["hcr_id"], keep="last")
    return sub[["hcr_id", "label"]].reset_index(drop=True)


def _add_within_subject_pct(df: pd.DataFrame) -> pd.DataFrame:
    for c in PCT_RANK_COLS:
        if c not in df.columns:
            df[f"{c}_pct_subj"] = float("nan")
            continue
        df[f"{c}_pct_subj"] = df[c].rank(pct=True, method="average")
    return df


def _load_v5_features(sid: str) -> pd.DataFrame:
    f = pd.read_parquet(CACHE / f"{sid}_features_v2.parquet")
    g = pd.read_parquet(CACHE / f"{sid}_features_v3_extra.parquet")
    h = pd.read_parquet(CACHE / f"{sid}_features_v4.parquet")
    k = pd.read_parquet(CACHE / f"{sid}_features_v5.parquet")
    out = (f.merge(g, on="hcr_id", how="left", suffixes=("", "_v3"))
            .merge(h, on="hcr_id", how="left", suffixes=("", "_v4"))
            .merge(k, on="hcr_id", how="left", suffixes=("", "_v5")))
    out = _add_within_subject_pct(out)
    return out


def _load_stage2_oof(sid: str) -> pd.DataFrame:
    """4-class OOF proba + binary OOF score per cell, indexed by hcr_id."""
    p4 = pd.read_parquet(CACHE / f"{sid}_stage2_4class_proba_v5.parquet")
    p2 = pd.read_parquet(CACHE / f"{sid}_stage2_binary_score_v5.parquet")
    p4 = p4[["hcr_id"] + PROBA_COLS].copy()
    p2 = p2[["hcr_id", "score"]].rename(columns={"score": "p_binary_pos"}).copy()
    return p4.merge(p2, on="hcr_id", how="outer")


def _aggregate_neighbor_features(sid: str, oof: pd.DataFrame) -> pd.DataFrame:
    """Per host cell, aggregate stage-2 OOF probas of touching neighbors.

    Returns a frame with one row per host hcr_id and the neighbor-soft features.
    Cells with no touching neighbors get NaN aggregates and 0 for n/n_overlap.
    """
    nb = pd.read_parquet(CACHE / f"{sid}_neighbors_v1.parquet")
    if nb.empty:
        # Fabricate empty aggregator output.
        cols = ["hcr_id"] + (
            [f"nbr_mean_{c}" for c in PROBA_COLS]
            + [f"nbr_max_{c}" for c in PROBA_COLS]
            + [f"nbr_min_{c}" for c in PROBA_COLS]
            + [f"nbr_w_mean_{c}" for c in PROBA_COLS]
            + ["nbr_mean_p_binary_pos", "nbr_max_p_binary_pos",
               "nbr_min_p_binary_pos", "nbr_w_mean_p_binary_pos",
               "n_touching_neighbors", "max_overlap_voxels",
               "sum_overlap_voxels"]
        )
        return pd.DataFrame(columns=cols)

    # Merge neighbor probas in.
    rename = {c: f"nbr_{c}" for c in PROBA_COLS + ["p_binary_pos"]}
    nb_with_probs = nb.merge(
        oof.rename(columns={**{"hcr_id": "neighbor_id"}, **rename}),
        on="neighbor_id", how="left",
    )
    # Drop neighbors whose proba is unknown (e.g. neighbor missing from cache).
    val_cols = [f"nbr_{c}" for c in PROBA_COLS]
    nb_with_probs = nb_with_probs.dropna(subset=val_cols, how="all").copy()
    if nb_with_probs.empty:
        return pd.DataFrame(columns=["hcr_id"])

    # Weight by overlap_voxels for weighted-mean variants.
    w = nb_with_probs["overlap_voxels"].astype("float64").to_numpy()

    g = nb_with_probs.groupby("hcr_id", sort=False)
    parts = []

    # mean / max / min unweighted across touching neighbors.
    parts.append(g[val_cols].mean().add_prefix("__M__"))
    parts.append(g[val_cols].max().add_prefix("__X__"))
    parts.append(g[val_cols].min().add_prefix("__N__"))
    # binary score aggregates
    parts.append(
        g[["nbr_p_binary_pos"]].agg(["mean", "max", "min"])
    )

    # weighted means: sum(w * v) / sum(w) per group, per col.
    nb_with_probs["__w"] = w
    for c in val_cols + ["nbr_p_binary_pos"]:
        nb_with_probs[f"__wv_{c}"] = nb_with_probs[c] * nb_with_probs["__w"]
    sums_v = g[[f"__wv_{c}" for c in val_cols + ["nbr_p_binary_pos"]]].sum()
    sums_w = g[["__w"]].sum()
    wmean = sums_v.div(sums_w["__w"].replace(0, np.nan), axis=0)
    wmean.columns = [f"nbr_w_mean_{c.replace('__wv_nbr_', '').replace('__wv_', '')}"
                     for c in wmean.columns]
    parts.append(wmean)

    # adjacency size summaries
    extras = g.agg(
        n_touching_neighbors=("neighbor_id", "size"),
        max_overlap_voxels=("overlap_voxels", "max"),
        sum_overlap_voxels=("overlap_voxels", "sum"),
    )
    parts.append(extras)

    out = pd.concat(parts, axis=1)
    # rename the "__M__/__X__/__N__" prefixed columns to friendly names.
    rename_map = {}
    for c in out.columns:
        if isinstance(c, str):
            if c.startswith("__M__"):
                rename_map[c] = "nbr_mean_" + c[5 + len("__M__") - 5:]  # noop fallback
            elif c.startswith("__X__"):
                rename_map[c] = "nbr_max_" + c[5:]
            elif c.startswith("__N__"):
                rename_map[c] = "nbr_min_" + c[5:]
    # fix the noop above: rebuild rename_map cleanly
    rename_map = {}
    for c in out.columns:
        cs = c if isinstance(c, str) else "__".join(map(str, c))
        if cs.startswith("__M__"):
            rename_map[c] = "nbr_mean_" + cs[len("__M__"):].replace("nbr_", "")
        elif cs.startswith("__X__"):
            rename_map[c] = "nbr_max_" + cs[len("__X__"):].replace("nbr_", "")
        elif cs.startswith("__N__"):
            rename_map[c] = "nbr_min_" + cs[len("__N__"):].replace("nbr_", "")
    # the agg(['mean', 'max', 'min']) for binary produces multi-index columns
    # turn those into flat names too
    flat_cols = []
    for c in out.columns:
        if isinstance(c, tuple):
            base, agg = c
            if base == "nbr_p_binary_pos":
                flat_cols.append(f"nbr_{agg}_p_binary_pos")
            else:
                flat_cols.append("__".join(map(str, c)))
        else:
            flat_cols.append(rename_map.get(c, c))
    out.columns = flat_cols
    out = out.reset_index().rename(columns={"index": "hcr_id"})
    if "hcr_id" not in out.columns:
        out = out.rename(columns={out.columns[0]: "hcr_id"})
    return out


def _build_subject_frame(sid: str) -> pd.DataFrame:
    feats = _load_v5_features(sid)
    oof = _load_stage2_oof(sid)
    nb_aggr = _aggregate_neighbor_features(sid, oof)
    df = feats.merge(oof, on="hcr_id", how="left")
    df = df.merge(nb_aggr, on="hcr_id", how="left")
    # Fill structural counts with 0 (no neighbors found ⇒ true zero).
    for c in ["n_touching_neighbors", "max_overlap_voxels", "sum_overlap_voxels"]:
        if c in df.columns:
            df[c] = df[c].fillna(0)
    df["sid"] = sid
    return df


def _build_matrix(df: pd.DataFrame, feature_columns: list[str] | None
                  ) -> tuple[pd.DataFrame, list[str]]:
    if feature_columns is None:
        cols = [
            c for c in df.columns
            if c not in DROP_FEATURES
            and (pd.api.types.is_numeric_dtype(df[c]) or pd.api.types.is_bool_dtype(df[c]))
        ]
    else:
        cols = list(feature_columns)
    X = df[cols].copy()
    for c in X.columns:
        if pd.api.types.is_bool_dtype(X[c]):
            X[c] = X[c].astype("float32")
    return X, cols


def _early_stop_split(n: int, frac: float = 0.15, seed: int = 0):
    rng = np.random.default_rng(seed)
    idx = np.arange(n)
    rng.shuffle(idx)
    cut = max(1, int(round(n * (1 - frac))))
    return idx[:cut], idx[cut:]


def train_binary(X_tr, y_tr) -> lgb.Booster:
    tr, va = _early_stop_split(len(X_tr), frac=0.15, seed=42)
    return lgb.train(
        LGB_BINARY,
        lgb.Dataset(X_tr.iloc[tr], y_tr[tr]),
        num_boost_round=N_ESTIMATORS,
        valid_sets=[lgb.Dataset(X_tr.iloc[va], y_tr[va])],
        callbacks=[lgb.early_stopping(EARLY_STOP), lgb.log_evaluation(0)],
    )


def train_multi(X_tr, y_tr) -> lgb.Booster:
    tr, va = _early_stop_split(len(X_tr), frac=0.15, seed=42)
    return lgb.train(
        LGB_MULTI,
        lgb.Dataset(X_tr.iloc[tr], y_tr[tr]),
        num_boost_round=N_ESTIMATORS,
        valid_sets=[lgb.Dataset(X_tr.iloc[va], y_tr[va])],
        callbacks=[lgb.early_stopping(EARLY_STOP), lgb.log_evaluation(0)],
    )


def main() -> None:
    OUT.mkdir(parents=True, exist_ok=True)
    log = _load_label_log()
    print(f"label log: {len(log)} rows")

    feats = {sid: _build_subject_frame(sid) for sid in SUBJECTS}
    labs = {sid: _active_labels(log, sid) for sid in SUBJECTS}

    print("\nactive label counts per subject (post-undo):")
    for sid in SUBJECTS:
        c = labs[sid]["label"].value_counts().to_dict()
        print(f"  {sid}: total={len(labs[sid]):3d}  " + ", ".join(
            f"{k}={c.get(k, 0)}" for k in ["good", "bad", "bad_ok", "merged", "unsure"]
        ))
    print(f"\nstage-3 frame: {SUBJECTS[0]} has {feats[SUBJECTS[0]].shape[1]} columns")

    # ──────────────── BINARY ────────────────
    print("\n" + "=" * 62 + "\nBINARY (stage-3 v1)  {good, bad_ok} vs {bad, merged}, drop unsure\n" + "=" * 62)
    feature_columns = None
    bin_metrics, bin_imp = [], {}

    for held in SUBJECTS:
        tr_X, tr_y = [], []
        for sid in SUBJECTS:
            if sid == held:
                continue
            f = feats[sid]
            l = labs[sid]
            l = l[l["label"].isin(BINARY_POS | BINARY_NEG)].copy()
            l["y"] = l["label"].isin(BINARY_POS).astype("int8")
            merged = f.merge(l[["hcr_id", "y"]], on="hcr_id", how="inner")
            X, cols = _build_matrix(merged, feature_columns)
            feature_columns = cols
            tr_X.append(X)
            tr_y.append(merged["y"].to_numpy("int8"))
        X_tr = pd.concat(tr_X, axis=0).reset_index(drop=True)
        y_tr = np.concatenate(tr_y)

        f_held = feats[held]
        X_held, _ = _build_matrix(f_held, feature_columns)
        l_held = labs[held]
        l_held = l_held[l_held["label"].isin(BINARY_POS | BINARY_NEG)].copy()
        l_held["y"] = l_held["label"].isin(BINARY_POS).astype("int8")

        booster = train_binary(X_tr, y_tr)
        y_pred_full = booster.predict(X_held, num_iteration=booster.best_iteration)

        scored = pd.DataFrame({"hcr_id": f_held["hcr_id"].to_numpy(), "score": y_pred_full})
        eval_df = l_held.merge(scored, on="hcr_id", how="left")
        y_eval = eval_df["y"].to_numpy("int8")
        p_eval = eval_df["score"].to_numpy("float64")

        auc = roc_auc_score(y_eval, p_eval) if len(np.unique(y_eval)) > 1 else float("nan")
        ap = average_precision_score(y_eval, p_eval) if len(np.unique(y_eval)) > 1 else float("nan")
        brier = brier_score_loss(y_eval, p_eval)
        acc = accuracy_score(y_eval, (p_eval >= 0.5).astype("int8"))

        bin_metrics.append({
            "held_subject": held, "n_train": int(len(X_tr)),
            "n_eval": int(len(y_eval)),
            "auc": auc, "ap": ap, "brier": brier, "acc@0.5": acc,
            "best_iter": booster.best_iteration,
        })
        print(f"[hold {held}] n_tr={len(X_tr):3d}  n_ev={len(y_eval):3d}  "
              f"AUC={auc:.4f}  AP={ap:.4f}  Brier={brier:.4f}  acc@0.5={acc:.3f}  "
              f"iter={booster.best_iteration}")

        oof_df = pd.DataFrame({
            "hcr_id": f_held["hcr_id"].to_numpy("int64"),
            "score": y_pred_full.astype("float32"),
        }).merge(
            l_held.rename(columns={"label": "human_label"})[["hcr_id", "human_label"]],
            on="hcr_id", how="left",
        )
        oof_df.to_parquet(CACHE / f"{held}_stage3_binary_score_v1.parquet", index=False)

        gain = booster.feature_importance(importance_type="gain")
        for c, g in zip(feature_columns, gain):
            bin_imp.setdefault(c, []).append(float(g))

    bm = pd.DataFrame(bin_metrics).sort_values("held_subject")
    bm.to_csv(OUT / "binary_loso_metrics_v1.csv", index=False)
    print("\nstage-3 binary v1 LOSO summary:")
    print(bm.to_string(index=False))
    print(f"  mean AUC={bm['auc'].mean():.4f}  AP={bm['ap'].mean():.4f}  "
          f"Brier={bm['brier'].mean():.4f}  acc@0.5={bm['acc@0.5'].mean():.4f}")

    fi_b = (
        pd.DataFrame({c: pd.Series(v) for c, v in bin_imp.items()})
        .mean().sort_values(ascending=False)
        .rename("mean_gain").reset_index().rename(columns={"index": "feature"})
    )
    fi_b.to_csv(OUT / "binary_feature_importance_v1.csv", index=False)
    print("\nstage-3 binary v1 top-30 features:")
    print(fi_b.head(30).to_string(index=False))

    # ──────────────── 4-CLASS ────────────────
    print("\n" + "=" * 62 + f"\n4-CLASS (stage-3 v1)  {CLASS_NAMES}, drop unsure\n" + "=" * 62)
    multi_metrics, multi_imp = [], {}
    overall_cm = np.zeros((len(CLASS_NAMES), len(CLASS_NAMES)), dtype=int)

    for held in SUBJECTS:
        tr_X, tr_y = [], []
        for sid in SUBJECTS:
            if sid == held:
                continue
            f = feats[sid]
            l = labs[sid]
            l = l[l["label"].isin(CLASS_NAMES)].copy()
            l["y"] = l["label"].map(CLASS_TO_IDX).astype("int8")
            merged = f.merge(l[["hcr_id", "y"]], on="hcr_id", how="inner")
            X, _ = _build_matrix(merged, feature_columns)
            tr_X.append(X)
            tr_y.append(merged["y"].to_numpy("int8"))
        X_tr = pd.concat(tr_X, axis=0).reset_index(drop=True)
        y_tr = np.concatenate(tr_y)

        f_held = feats[held]
        X_held, _ = _build_matrix(f_held, feature_columns)
        l_held = labs[held]
        l_held = l_held[l_held["label"].isin(CLASS_NAMES)].copy()
        l_held["y"] = l_held["label"].map(CLASS_TO_IDX).astype("int8")

        booster = train_multi(X_tr, y_tr)
        proba_full = booster.predict(X_held, num_iteration=booster.best_iteration)
        scored = pd.DataFrame(proba_full, columns=PROBA_COLS)
        scored["hcr_id"] = f_held["hcr_id"].to_numpy("int64")
        eval_df = l_held.merge(scored, on="hcr_id", how="left")
        y_eval = eval_df["y"].to_numpy("int8")
        proba_eval = eval_df[PROBA_COLS].to_numpy("float64")
        y_pred = proba_eval.argmax(axis=1)
        acc = accuracy_score(y_eval, y_pred)
        f1m = f1_score(y_eval, y_pred, average="macro", zero_division=0)
        f1p = f1_score(y_eval, y_pred, average=None,
                        labels=list(range(len(CLASS_NAMES))), zero_division=0)
        cm = confusion_matrix(y_eval, y_pred, labels=list(range(len(CLASS_NAMES))))
        overall_cm += cm

        row = {
            "held_subject": held, "n_train": int(len(X_tr)),
            "n_eval": int(len(y_eval)), "acc": acc, "f1_macro": f1m,
            "best_iter": booster.best_iteration,
        }
        for c, fv in zip(CLASS_NAMES, f1p):
            row[f"f1_{c}"] = float(fv)
        multi_metrics.append(row)

        print(f"[hold {held}] n_tr={len(X_tr):3d}  n_ev={len(y_eval):3d}  "
              f"acc={acc:.3f}  f1_macro={f1m:.3f}  "
              + " ".join(f"f1_{c}={f:.2f}" for c, f in zip(CLASS_NAMES, f1p))
              + f"  iter={booster.best_iteration}")

        oof = scored[["hcr_id"] + PROBA_COLS].merge(
            l_held.rename(columns={"label": "human_label"})[["hcr_id", "human_label"]],
            on="hcr_id", how="left",
        )
        oof.to_parquet(CACHE / f"{held}_stage3_4class_proba_v1.parquet", index=False)

        gain = booster.feature_importance(importance_type="gain")
        for c, g in zip(feature_columns, gain):
            multi_imp.setdefault(c, []).append(float(g))

    mm = pd.DataFrame(multi_metrics).sort_values("held_subject")
    mm.to_csv(OUT / "4class_loso_metrics_v1.csv", index=False)
    print("\nstage-3 4-class v1 LOSO summary:")
    print(mm[["held_subject", "n_train", "n_eval", "acc", "f1_macro"]
             + [f"f1_{c}" for c in CLASS_NAMES]].to_string(index=False))
    print(f"  mean acc={mm['acc'].mean():.4f}  mean f1_macro={mm['f1_macro'].mean():.4f}")

    fi_m = (
        pd.DataFrame({c: pd.Series(v) for c, v in multi_imp.items()})
        .mean().sort_values(ascending=False)
        .rename("mean_gain").reset_index().rename(columns={"index": "feature"})
    )
    fi_m.to_csv(OUT / "4class_feature_importance_v1.csv", index=False)
    print("\nstage-3 4-class v1 top-30 features:")
    print(fi_m.head(30).to_string(index=False))

    cm_df = pd.DataFrame(overall_cm,
                          index=[f"true_{c}" for c in CLASS_NAMES],
                          columns=[f"pred_{c}" for c in CLASS_NAMES])
    cm_df.to_csv(OUT / "4class_confusion_overall_v1.csv")
    print("\nstage-3 4-class v1 confusion matrix (sum):")
    print(cm_df.to_string())

    # ──────────────── PRODUCTION (full-data) ────────────────
    print("\n" + "=" * 62 + "\nproduction stage-3 v1 models on all labelled rows\n" + "=" * 62)

    Xb_parts, yb_parts = [], []
    for sid in SUBJECTS:
        f = feats[sid]; l = labs[sid]
        l = l[l["label"].isin(BINARY_POS | BINARY_NEG)].copy()
        l["y"] = l["label"].isin(BINARY_POS).astype("int8")
        m = f.merge(l[["hcr_id", "y"]], on="hcr_id", how="inner")
        X, _ = _build_matrix(m, feature_columns)
        Xb_parts.append(X); yb_parts.append(m["y"].to_numpy("int8"))
    Xb = pd.concat(Xb_parts, axis=0).reset_index(drop=True)
    yb = np.concatenate(yb_parts)
    n_iter_b = max(int(np.median([m["best_iter"] for m in bin_metrics])), 80)
    bin_prod = lgb.train(LGB_BINARY, lgb.Dataset(Xb, yb),
                          num_boost_round=n_iter_b,
                          callbacks=[lgb.log_evaluation(0)])
    bin_prod.save_model(str(CACHE / "roi_quality_stage3_binary_v1.txt"))
    print(f"  binary stage-3 v1 production: {len(Xb)} rows, {n_iter_b} iters")

    Xm_parts, ym_parts = [], []
    for sid in SUBJECTS:
        f = feats[sid]; l = labs[sid]
        l = l[l["label"].isin(CLASS_NAMES)].copy()
        l["y"] = l["label"].map(CLASS_TO_IDX).astype("int8")
        m = f.merge(l[["hcr_id", "y"]], on="hcr_id", how="inner")
        X, _ = _build_matrix(m, feature_columns)
        Xm_parts.append(X); ym_parts.append(m["y"].to_numpy("int8"))
    Xm = pd.concat(Xm_parts, axis=0).reset_index(drop=True)
    ym = np.concatenate(ym_parts)
    n_iter_m = max(int(np.median([m["best_iter"] for m in multi_metrics])), 80)
    multi_prod = lgb.train(LGB_MULTI, lgb.Dataset(Xm, ym),
                             num_boost_round=n_iter_m,
                             callbacks=[lgb.log_evaluation(0)])
    multi_prod.save_model(str(CACHE / "roi_quality_stage3_4class_v1.txt"))
    print(f"  4-class stage-3 v1 production: {len(Xm)} rows, {n_iter_m} iters")

    meta = {
        "version": "stage3_v1",
        "feature_columns": feature_columns,
        "subjects": SUBJECTS,
        "class_names": CLASS_NAMES,
        "binary": {
            "n_train_total": int(len(Xb)),
            "n_iter_prod": int(n_iter_b),
            "loso_mean_auc": float(bm["auc"].mean()),
            "loso_mean_ap": float(bm["ap"].mean()),
            "loso_mean_brier": float(bm["brier"].mean()),
            "loso_mean_acc05": float(bm["acc@0.5"].mean()),
        },
        "four_class": {
            "n_train_total": int(len(Xm)),
            "n_iter_prod": int(n_iter_m),
            "loso_mean_acc": float(mm["acc"].mean()),
            "loso_mean_f1_macro": float(mm["f1_macro"].mean()),
        },
    }
    (CACHE / "roi_quality_stage3_meta_v1.json").write_text(json.dumps(meta, indent=2))
    print(f"\nmeta saved -> {CACHE / 'roi_quality_stage3_meta_v1.json'}")
    print(f"per-subject oof saved under {CACHE}/<sid>_stage3_*_v1.parquet")
    print(f"summaries under {OUT}")


