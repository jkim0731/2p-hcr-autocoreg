#!/usr/bin/env python3
"""Driver: extract per-cell v7 image-quality features.

Writes `cached_roi_quality/{sid}_features_v7.parquet`.

Usage:
    python 01h_extract_features_v7.py [--force] [--workers 6] [--subjects ...]
"""
from __future__ import annotations

import argparse
import sys
import time
from pathlib import Path

DEV_CODE = Path("/root/capsule/code/dev_code")
sys.path.insert(0, str(DEV_CODE))

from benchmark_data_loader import BENCHMARK_SUBJECTS  # noqa: E402
from roi_quality_v7 import extract_v7_all  # noqa: E402

DEFAULT_SUBJECTS = list(BENCHMARK_SUBJECTS)


def main() -> None:
    ap = argparse.ArgumentParser()
    ap.add_argument("--force", action="store_true")
    ap.add_argument("--workers", type=int, default=6)
    ap.add_argument("--subjects", nargs="+", default=None)
    args = ap.parse_args()

    subjects = args.subjects or DEFAULT_SUBJECTS
    print(f"v7 image-quality extraction → {len(subjects)} subjects, "
          f"workers={args.workers}, force={args.force}")
    t0 = time.time()
    results = extract_v7_all(subjects, workers=args.workers, force=args.force)
    print(f"\n=== ALL DONE in {time.time() - t0:.0f}s ===")
    for r in results:
        print(f"  {r}")


if __name__ == "__main__":
    main()
