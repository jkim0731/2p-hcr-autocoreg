def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


def spatial_outlier_clamp(surface, xs, ys, zs, *, tile_um=120.0, within_tile_q=0.10,
                           safety_offset_um=3.0, min_per_tile=5,
                           neighbor_radius_tiles=2, spatial_thr_um=80.0,
                           density_radius_um=30.0, density_min_neighbors=3):
    keep = _mod._filter_tops_by_density(
        xs, ys, zs, radius_um=density_radius_um,
        min_neighbors=density_min_neighbors)
    if keep.sum() < 50:
        return surface, 0.0, 0, 0, "no-tops"
    xs_f = xs[keep]; ys_f = ys[keep]; zs_f = zs[keep]
    xb = (xs_f // tile_um).astype(int)
    yb = (ys_f // tile_um).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": xs_f, "y": ys_f, "z": zs_f})
    agg = df.groupby("k").agg(
        x=("x", "median"), y=("y", "median"),
        z=("z", lambda v: float(np.quantile(v, within_tile_q))),
        n=("z", "size"))
    agg = agg[agg["n"] >= int(min_per_tile)].reset_index()
    if len(agg) == 0:
        return surface, 0.0, 0, 0, "no-tiles"
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    # Spatial outlier check: for each tile, look up z of neighbors within R tiles
    R = float(neighbor_radius_tiles) * tile_um
    tree = cKDTree(np.column_stack([tx, ty]))
    neigh_idx = tree.query_ball_point(np.column_stack([tx, ty]), r=R)
    keep_tile = np.ones(len(tz), dtype=bool)
    neigh_med = np.full(len(tz), np.nan)
    for i, idxs in enumerate(neigh_idx):
        idxs = [j for j in idxs if j != i]  # exclude self
        if len(idxs) < 3:
            continue  # too few neighbors, keep as-is
        m = float(np.median(tz[idxs]))
        neigh_med[i] = m
        if tz[i] < m - float(spatial_thr_um):
            keep_tile[i] = False
    n_total = len(tz)
    n_kept = int(keep_tile.sum())
    tx_k, ty_k, tz_k = tx[keep_tile], ty[keep_tile], tz[keep_tile]
    plane_z = sz(surface, tx_k, ty_k)
    deficit = plane_z - tz_k
    pos = deficit[deficit > 0]
    lift = float(pos.max()) if len(pos) else 0.0
    out = dict(surface)
    out["c"] = float(out["c"] - lift - safety_offset_um)
    rej = n_total - n_kept
    note = f"rejected={rej}/{n_total}"
    return out, lift, n_total, n_kept, note


