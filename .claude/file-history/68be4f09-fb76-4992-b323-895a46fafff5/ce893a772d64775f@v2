"""Test image-only pipeline with clamp DISABLED — does the surface
already sit close to pia without any clamp?

Hypothesis: column tops are already good positional estimates.  The
clamp over-lifts because per-tile 10%-pctile of tops is corrupted by
autofluorescence.  Without the clamp, at q=0.70 the surface should
land near the 30th percentile of tops per column — which should be
close to pia.
"""
from __future__ import annotations
import sys, importlib.util, os
from pathlib import Path
import numpy as np
os.environ["PYTHONUNBUFFERED"] = "1"

sys.path.insert(0, "/root/capsule/code/dev_code")

_spec = importlib.util.spec_from_file_location(
    "img_surface_l2",
    str(Path("/root/capsule/code/dev_code") / "03_image_based_surface.py"))
_mod = importlib.util.module_from_spec(_spec)
sys.modules["img_surface_l2"] = _mod
_spec.loader.exec_module(_mod)

from benchmark_analysis import load_hcr_combined
from benchmark_data_loader import hcr_px_to_um, load_subject


def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


for sid in ["755252", "767018", "767022", "782149", "788406", "790322"]:
    sys.stdout.write(f"loading {sid}...\n"); sys.stdout.flush()
    s = load_subject(sid)
    vol, xy_um, z_um, channels = load_hcr_combined(s, level=4)
    pts = hcr_px_to_um(s.hcr_centroids[["z_px","y_px","x_px"]].values, s)[:, [2,1,0]]

    # For each combination of q and (clamp or no clamp), get surface
    sys.stdout.write(f"fitting {sid}...\n"); sys.stdout.flush()
    for q_target in [0.50, 0.60, 0.70, 0.80]:
        res = _mod.estimate_surface_and_l2_image_based(
            vol, z_um, xy_um,
            target_quantile=q_target,
            column_margin=0.25,
            band_um=150.0,
            clamp_min_per_tile=100000,  # disable clamp
        )
        if res.surface is None:
            sys.stdout.write(f"  q={q_target}: NONE\n"); sys.stdout.flush()
            continue
        above, onset = eval_surf(res.surface, pts)
        sys.stdout.write(f"  {sid} q={q_target:.2f} noclamp: c={res.surface['c']:6.1f} "
                         f"tilt={res.surface['tilt_deg']:5.2f} above={above:.4f} onset={onset:.1f}\n")
        sys.stdout.flush()
