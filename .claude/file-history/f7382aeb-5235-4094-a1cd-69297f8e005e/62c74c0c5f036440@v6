def _save_histograms(per_subject: dict):
    import matplotlib

    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    FIG_DIR.mkdir(parents=True, exist_ok=True)

    # ---- counts panel: overlay counts-only thresholds
    fig, axes = plt.subplots(2, 2, figsize=(11, 8), sharex=True)
    for ax, sid in zip(axes.flatten(), SPOT_SUBJECTS):
        raw = load_raw_gfp_table(sid)
        x = np.log10(raw["counts"].values.astype(float))
        ax.hist(x, bins=80, color="0.7", edgecolor="k", linewidth=0.3)
        s = load_subject(sid, gfp_threshold_method="counts_min", gfp_min_spots=1)
        cg_ids = set(s.coreg_table["hcr_id"].astype(int).tolist())
        cg_counts = raw.loc[raw["hcr_id"].isin(cg_ids), "counts"].values
        if len(cg_counts):
            ax.hist(np.log10(cg_counts), bins=80, color="C0", alpha=0.5,
                    label=f"coreg cells ({len(cg_counts)})")
        strat = per_subject[sid]["strategies"]
        count_overlays = {
            "baseline_counts>=5":       ("C0", "--"),
            "A_gmm_log_counts":         ("C3", "-"),
            "A3_gmm_log_counts_3c_bg":  ("C5", "-"),
            "B_otsu_log_counts":        ("C2", "-"),
            "Triangle_log_counts":      ("C1", "-"),
            "Yen_log_counts":           ("C6", "-"),
            "Isodata_log_counts":       ("C7", "-"),
            "C_kneedle_counts":         ("C9", ":"),
            "GMM2_log_counts_gte10":    ("C4", "-."),
            "PeakGauss3_counts_p1":     ("C8", "-"),
            "PeakGauss3_counts_p2.5":   ("C8", "--"),
            "PeakGauss3_counts_p5":     ("C8", ":"),
        }
        for name, (col, ls) in count_overlays.items():
            if name not in strat:
                continue
            t = strat[name].get("threshold_counts", 0)
            if t and np.isfinite(t) and t > 0:
                tag = name.split("_")[0]
                ax.axvline(np.log10(t), color=col, ls=ls, lw=1.4,
                           label=f"{tag}={int(t)}")
        ax.set_title(f"{sid} (n={len(raw)})")
        ax.set_xlabel("log10(counts)")
        ax.set_ylabel("cells")
        ax.legend(fontsize=6, loc="upper right")
    fig.tight_layout()
    fig.savefig(FIG_DIR / "log_count_histograms.png", dpi=130)
    plt.close(fig)

    # ---- density panel: overlay density-only thresholds
    if "density" not in load_raw_gfp_table(SPOT_SUBJECTS[0]).columns:
        return
    fig, axes = plt.subplots(2, 2, figsize=(11, 8), sharex=True)
    for ax, sid in zip(axes.flatten(), SPOT_SUBJECTS):
        raw = load_raw_gfp_table(sid)
        if "density" not in raw.columns:
            continue
        d = raw["density"].values.astype(float)
        d_pos = d[d > 0]
        x = np.log10(d_pos)
        ax.hist(x, bins=80, color="0.7", edgecolor="k", linewidth=0.3)
        s = load_subject(sid, gfp_threshold_method="counts_min", gfp_min_spots=1)
        cg_ids = set(s.coreg_table["hcr_id"].astype(int).tolist())
        cg_d = raw.loc[raw["hcr_id"].isin(cg_ids), "density"].values.astype(float)
        cg_d = cg_d[cg_d > 0]
        if len(cg_d):
            ax.hist(np.log10(cg_d), bins=80, color="C0", alpha=0.5,
                    label=f"coreg cells ({len(cg_d)})")
        strat = per_subject[sid]["strategies"]
        density_overlays = {
            "Yen_log_density":       ("C6", "-"),
            "Otsu_log_density":      ("C2", "-"),
            "Isodata_log_density":   ("C7", "-"),
            "Triangle_log_density":  ("C1", "-"),
            "GMM_log_density":       ("C3", "-"),
            "GMM3bg_log_density":    ("C5", "-"),
            "GMM3_log_density":      ("C4", "-."),
            "PeakGauss3_density_p1":   ("C8", "-"),
            "PeakGauss3_density_p2.5": ("C8", "--"),
            "PeakGauss3_density_p5":   ("C8", ":"),
        }
        for name, (col, ls) in density_overlays.items():
            if name not in strat:
                continue
            t = strat[name].get("threshold_density")
            if t and np.isfinite(t) and t > 0:
                tag = name.split("_")[0]
                ax.axvline(np.log10(t), color=col, ls=ls, lw=1.4,
                           label=f"{tag}={t:.4f}")
        ax.set_title(f"{sid} (n={len(d_pos)})")
        ax.set_xlabel("log10(density)")
        ax.set_ylabel("cells")
        ax.legend(fontsize=6, loc="upper right")
    fig.tight_layout()
    fig.savefig(FIG_DIR / "log_density_histograms.png", dpi=130)
    plt.close(fig)


# =====================================================================
# CLI
# =====================================================================
def run() -> dict:
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    per_subject = {}
    for sid in SPOT_SUBJECTS:
        print(f"\n=== {sid} ===", flush=True)
        try:
            per_subject[sid] = analyze_one(sid)
        except Exception as exc:  # noqa: BLE001
            per_subject[sid] = {"subject": sid, "status": f"error: {exc!r}"}
            print(per_subject[sid])
            continue
        print(f"n_hcr_total={per_subject[sid]['n_hcr_total']}, "
              f"n_spot_bearing={per_subject[sid]['n_spot_bearing_cells']}, "
              f"n_coreg={per_subject[sid]['n_coreg_rows']}")
        for name, d in per_subject[sid]["strategies"].items():
            td = d.get("threshold_density")
            td_str = f"{td:.4f}" if td is not None else "    -"
            print(f"  {name:38s} tc={d.get('threshold_counts', 0):7.1f}  "
                  f"td={td_str}  "
                  f"gfp_frac={d.get('gfp_frac', float('nan')):.3f}  "
                  f"coreg_cov={d.get('coreg_coverage', float('nan')):.3f}  "
                  f"n_gfp={d.get('n_gfp', 0)}")

    # Cross-subject summary (ranking metric: max gfp_frac — lower is more stringent)
    strategy_names = list(next(iter(per_subject.values()))["strategies"].keys())
    summary = {}
    for name in strategy_names:
        fracs = [per_subject[sid]["strategies"][name]["gfp_frac"] for sid in SPOT_SUBJECTS]
        covs = [per_subject[sid]["strategies"][name].get("coreg_coverage") for sid in SPOT_SUBJECTS]
        tcs = [per_subject[sid]["strategies"][name].get("threshold_counts", 0.0) for sid in SPOT_SUBJECTS]
        tds = [per_subject[sid]["strategies"][name].get("threshold_density") for sid in SPOT_SUBJECTS]
        summary[name] = {
            "threshold_counts_per_subject": {sid: t for sid, t in zip(SPOT_SUBJECTS, tcs)},
            "threshold_density_per_subject": {sid: t for sid, t in zip(SPOT_SUBJECTS, tds)},
            "gfp_frac_per_subject": {sid: f for sid, f in zip(SPOT_SUBJECTS, fracs)},
            "coreg_cov_per_subject": {sid: c for sid, c in zip(SPOT_SUBJECTS, covs)},
            "gfp_frac_max": float(np.max(fracs)),
            "gfp_frac_mean": float(np.mean(fracs)),
            "gfp_frac_min": float(np.min(fracs)),
            "coreg_cov_min": (
                float(np.nanmin([c for c in covs if c is not None]))
                if any(c is not None for c in covs) else None
            ),
            "coreg_cov_mean": (
                float(np.nanmean([c for c in covs if c is not None]))
                if any(c is not None for c in covs) else None
            ),
        }

    # Winner logic (v2.1): most stringent strategy (lowest max gfp_frac across
    # subjects) whose coreg_coverage >= COVERAGE_TARGET on every subject.
    # gfp_frac is the common yardstick — it is well-defined for counts-only,
    # density-only, and joint strategies alike, so strategies of different
    # families can be compared directly.
    winners = []
    for name, row in summary.items():
        if name.startswith("baseline_"):
            continue
        covs_list = [c for c in row["coreg_cov_per_subject"].values() if c is not None]
        if not covs_list or min(covs_list) < COVERAGE_TARGET:
            continue
        winners.append((
            name,
            row["gfp_frac_max"],
            row["gfp_frac_mean"],
            min(covs_list),
        ))
    # lower max gfp_frac wins; tie-break by lower mean, then higher coverage
    winners.sort(key=lambda x: (x[1], x[2], -x[3]))

    out = {
        "coverage_target": COVERAGE_TARGET,
        "per_subject": per_subject,
        "cross_subject_summary": summary,
        "winners_ranked": [w[0] for w in winners],
        "winners_detail": [
            {"name": w[0], "gfp_frac_max": w[1], "gfp_frac_mean": w[2], "coreg_cov_min": w[3]}
            for w in winners
        ],
        "stopping_condition_note": (
            "A strategy 'passes' if coreg_coverage >= "
            f"{COVERAGE_TARGET:.2f} on every subject. Winners are ranked by "
            "`max gfp_frac across subjects` (lower is more stringent), which is "
            "well-defined for counts-only, density-only, and joint strategies. "
            "Ties broken by mean gfp_frac, then by coverage. No fixed-percentile "
            "strategy is considered — all methods must be distribution-driven so "
            "they generalise to subjects without a coreg table."
        ),
    }
    with open(RESULT_JSON, "w") as f:
        json.dump(out, f, indent=2, default=lambda v: v.tolist() if hasattr(v, "tolist") else str(v))
    print(f"\nWrote {RESULT_JSON}")

    # Plots
    try:
        _save_histograms(per_subject)
        print(f"Wrote figures to {FIG_DIR}")
    except Exception as exc:  # noqa: BLE001
        print(f"plot skipped: {exc!r}")

    return out


if __name__ == "__main__":
    run()
