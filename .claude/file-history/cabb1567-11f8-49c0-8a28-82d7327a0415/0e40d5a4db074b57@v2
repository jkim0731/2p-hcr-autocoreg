(OUT_SESSION / "figures").mkdir(parents=True, exist_ok=True)


def _find_cz_seg_mask(subject_id: str) -> Path | None:
    patterns = [
        f"data/multiplane-ophys_{subject_id}_*_cortical-zstack-segmentation_*",
        f"data/multiplane-ophys_{subject_id}_*_cortical-zstack-seg_*",
    ]
    for pat in patterns:
        dirs = sorted(glob.glob(str(ROOT / pat)))
        if not dirs:
            continue
        cand = Path(dirs[-1]) / "channel_0_ref_0" / "segmentation_masks.tif"
        if cand.exists():
            return cand
    return None


def _load_cz_image(s):
    cz_tifs = list(s.coreg_dir.glob("*reg-dim-swapped.ome.tif"))
    if not cz_tifs:
        cz_tifs = list(s.coreg_dir.glob("*zstack.tif"))
    if not cz_tifs:
        return None
    img = tifffile.imread(str(cz_tifs[0]))
    while img.ndim > 3 and img.shape[0] == 1:
        img = img[0]
    return img.astype(np.float32, copy=False)


def _plane_z(surface, x, y):
    return surface["a"] * x + surface["b"] * y + surface["c"]


def render_subject(subject_id: str, save_path: Path):
    s = load_subject(subject_id)

    # HCR
    vol_hcr, hcr_xy_um, hcr_z_um, ch = load_hcr_combined(s, level=4)
    r_hcr = estimate_surface_and_l2_image_based(
        vol_hcr, hcr_z_um, hcr_xy_um,
        xy_tile_um=150.0,
        top_blank_frac=0.05,
        top_blank_min_um=20.0,
        surface_search_frac=0.30,
        k_surface=3.0,
        relative_margin_min=0.01,
        k_l2_factor=1.5,
        l2_local_k=2.0,
        min_thick_surface_um=12.0,
        min_thick_l2_um=12.0,
        min_l1_um=40.0,
        max_l1_um=180.0,
        smooth_sigma_um=6.0,
    )

    # CZ
    cz_img = _load_cz_image(s)
    cz_mask_path = _find_cz_seg_mask(subject_id)
    bg_mask = None
    if cz_mask_path is not None:
        cz_seg = tifffile.imread(str(cz_mask_path))
        while cz_seg.ndim > 3 and cz_seg.shape[0] == 1:
            cz_seg = cz_seg[0]
        if cz_seg.shape == cz_img.shape:
            bg_mask = (cz_seg == 0)
    r_cz = estimate_surface_and_l2_image_based(
        cz_img, s.cz_z_um, s.cz_xy_um,
        mask_bg_for_l2=bg_mask,
        xy_tile_um=80.0,
        top_blank_frac=0.05,
        top_blank_min_um=20.0,
        surface_search_frac=0.30,
        k_surface=6.0,
        relative_margin_min=0.01,
        k_l2_factor=1.5,
        l2_local_k=2.0,
        min_thick_surface_um=12.0,
        min_thick_l2_um=15.0,
        min_l1_um=40.0,
        max_l1_um=180.0,
        smooth_sigma_um=6.0,
    )

    fig = plt.figure(figsize=(14, 10), constrained_layout=True)
    gs = fig.add_gridspec(3, 2)
    ax_h_xz = fig.add_subplot(gs[0, 0])
    ax_h_yz = fig.add_subplot(gs[0, 1])
    ax_c_xz = fig.add_subplot(gs[1, 0])
    ax_c_yz = fig.add_subplot(gs[1, 1])
    ax_h_prof = fig.add_subplot(gs[2, 0])
    ax_c_prof = fig.add_subplot(gs[2, 1])

    # HCR XZ MIP (collapse y at center)
    Y_h = vol_hcr.shape[1]
    half = min(20, Y_h // 4)
    y_mid = Y_h // 2
    mip_xz = vol_hcr[:, y_mid - half:y_mid + half, :].max(axis=1)
    mip_yz = vol_hcr[:, :, vol_hcr.shape[2] // 2 - half:vol_hcr.shape[2] // 2 + half].max(axis=2)

    Z_h = vol_hcr.shape[0]
    X_h_um = vol_hcr.shape[2] * hcr_xy_um
    Y_h_um = vol_hcr.shape[1] * hcr_xy_um

    ax_h_xz.imshow(
        mip_xz, extent=(0, X_h_um, Z_h * hcr_z_um, 0),
        aspect="auto", cmap="gray",
        vmin=np.percentile(mip_xz, 1), vmax=np.percentile(mip_xz, 99.5),
    )
    xs = np.linspace(0, X_h_um, 300)
    y0 = y_mid * hcr_xy_um
    if r_hcr.surface is not None:
        ax_h_xz.plot(xs, _plane_z(r_hcr.surface, xs, np.full_like(xs, y0)),
                     color="red", lw=1.4, label="surface")
    if r_hcr.l2 is not None:
        ax_h_xz.plot(xs, _plane_z(r_hcr.l2, xs, np.full_like(xs, y0)),
                     color="orange", lw=1.4, label="L2")
    ax_h_xz.set_title(f"HCR {subject_id} — XZ MIP @ y={y0:.0f} µm")
    ax_h_xz.set_xlabel("x (µm)"); ax_h_xz.set_ylabel("z (µm)")
    ax_h_xz.legend(loc="lower right", fontsize=8)

    ax_h_yz.imshow(
        mip_yz, extent=(0, Y_h_um, Z_h * hcr_z_um, 0),
        aspect="auto", cmap="gray",
        vmin=np.percentile(mip_yz, 1), vmax=np.percentile(mip_yz, 99.5),
    )
    ys = np.linspace(0, Y_h_um, 300)
    x0 = vol_hcr.shape[2] / 2 * hcr_xy_um
    if r_hcr.surface is not None:
        ax_h_yz.plot(ys, _plane_z(r_hcr.surface, np.full_like(ys, x0), ys),
                     color="red", lw=1.4, label="surface")
    if r_hcr.l2 is not None:
        ax_h_yz.plot(ys, _plane_z(r_hcr.l2, np.full_like(ys, x0), ys),
                     color="orange", lw=1.4, label="L2")
    ax_h_yz.set_title(f"HCR YZ MIP @ x={x0:.0f} µm")
    ax_h_yz.set_xlabel("y (µm)"); ax_h_yz.set_ylabel("z (µm)")
    ax_h_yz.legend(loc="lower right", fontsize=8)

    # CZ XZ / YZ MIPs
    Z_c, Y_c, X_c = cz_img.shape
    halfc = min(20, Y_c // 4)
    yc_mid = Y_c // 2; xc_mid = X_c // 2
    mip_c_xz = cz_img[:, yc_mid - halfc:yc_mid + halfc, :].max(axis=1)
    mip_c_yz = cz_img[:, :, xc_mid - halfc:xc_mid + halfc].max(axis=2)
    X_c_um = X_c * s.cz_xy_um
    Y_c_um = Y_c * s.cz_xy_um

    ax_c_xz.imshow(
        mip_c_xz, extent=(0, X_c_um, Z_c * s.cz_z_um, 0),
        aspect="auto", cmap="gray",
        vmin=np.percentile(mip_c_xz, 1), vmax=np.percentile(mip_c_xz, 99.5),
    )
    xs_c = np.linspace(0, X_c_um, 300)
    y0c = yc_mid * s.cz_xy_um
    if r_cz.surface is not None:
        ax_c_xz.plot(xs_c, _plane_z(r_cz.surface, xs_c, np.full_like(xs_c, y0c)),
                     color="red", lw=1.4, label="surface")
    if r_cz.l2 is not None:
        ax_c_xz.plot(xs_c, _plane_z(r_cz.l2, xs_c, np.full_like(xs_c, y0c)),
                     color="orange", lw=1.4, label="L2")
    ax_c_xz.set_title(f"CZ {subject_id} — XZ MIP @ y={y0c:.0f} µm")
    ax_c_xz.set_xlabel("x (µm)"); ax_c_xz.set_ylabel("z (µm)")
    ax_c_xz.legend(loc="lower right", fontsize=8)

    ax_c_yz.imshow(
        mip_c_yz, extent=(0, Y_c_um, Z_c * s.cz_z_um, 0),
        aspect="auto", cmap="gray",
        vmin=np.percentile(mip_c_yz, 1), vmax=np.percentile(mip_c_yz, 99.5),
    )
    ys_c = np.linspace(0, Y_c_um, 300)
    x0c = xc_mid * s.cz_xy_um
    if r_cz.surface is not None:
        ax_c_yz.plot(ys_c, _plane_z(r_cz.surface, np.full_like(ys_c, x0c), ys_c),
                     color="red", lw=1.4, label="surface")
    if r_cz.l2 is not None:
        ax_c_yz.plot(ys_c, _plane_z(r_cz.l2, np.full_like(ys_c, x0c), ys_c),
                     color="orange", lw=1.4, label="L2")
    ax_c_yz.set_title(f"CZ YZ MIP @ x={x0c:.0f} µm")
    ax_c_yz.set_xlabel("y (µm)"); ax_c_yz.set_ylabel("z (µm)")
    ax_c_yz.legend(loc="lower right", fontsize=8)

    # HCR intensity profile (global median) with thresholds
    prof_h = np.median(vol_hcr.reshape(Z_h, -1), axis=1)
    zs_h = np.arange(Z_h) * hcr_z_um
    ax_h_prof.plot(zs_h, prof_h, "k-", lw=1, label="global median")
    ax_h_prof.axhline(r_hcr.surf_thr, color="red", ls="--", lw=0.8,
                      label=f"surface thr={r_hcr.surf_thr:.3f}")
    ax_h_prof.axhline(r_hcr.l2_thr, color="orange", ls=":", lw=0.8,
                      label=f"L2 global thr={r_hcr.l2_thr:.3f}")
    if r_hcr.surface is not None:
        z_s_mid = _plane_z(
            r_hcr.surface, X_h_um / 2, Y_h_um / 2,
        )
        ax_h_prof.axvline(z_s_mid, color="red", lw=1,
                          label=f"surf @ mid={z_s_mid:.0f} µm")
    if r_hcr.l2 is not None:
        z_l_mid = _plane_z(
            r_hcr.l2, X_h_um / 2, Y_h_um / 2,
        )
        ax_h_prof.axvline(z_l_mid, color="orange", lw=1,
                          label=f"L2 @ mid={z_l_mid:.0f} µm")
    ax_h_prof.set_xlabel("z (µm)"); ax_h_prof.set_ylabel("median intensity")
    ax_h_prof.set_title("HCR global median profile (combined)")
    ax_h_prof.legend(fontsize=7)

    # CZ intensity profile (bg median if available)
    prof_all = np.median(cz_img.reshape(Z_c, -1), axis=1)
    if bg_mask is not None:
        prof_bg = []
        for z_i in range(Z_c):
            v = cz_img[z_i][bg_mask[z_i]]
            prof_bg.append(np.median(v) if v.size else np.nan)
        prof_bg = np.array(prof_bg)
    else:
        prof_bg = None
    zs_c = np.arange(Z_c) * s.cz_z_um
    ax_c_prof.plot(zs_c, prof_all, "k-", lw=1, label="all-voxel median")
    if prof_bg is not None:
        ax_c_prof.plot(zs_c, prof_bg, "b-", lw=1, label="bg-only median")
    ax_c_prof.axhline(r_cz.surf_thr, color="red", ls="--", lw=0.8,
                      label=f"surface thr={r_cz.surf_thr:.1f}")
    if r_cz.surface is not None:
        z_s_mid = _plane_z(r_cz.surface, X_c_um / 2, Y_c_um / 2)
        ax_c_prof.axvline(z_s_mid, color="red", lw=1,
                          label=f"surf @ mid={z_s_mid:.0f} µm")
    if r_cz.l2 is not None:
        z_l_mid = _plane_z(r_cz.l2, X_c_um / 2, Y_c_um / 2)
        ax_c_prof.axvline(z_l_mid, color="orange", lw=1,
                          label=f"L2 @ mid={z_l_mid:.0f} µm")
    ax_c_prof.set_xlabel("z (µm)"); ax_c_prof.set_ylabel("median intensity")
    ax_c_prof.set_title("CZ profiles (all voxels + background-only)")
    ax_c_prof.legend(fontsize=7)

    fig.suptitle(
        f"{subject_id}: image-based surface + L2 "
        f"(HCR tiles {r_hcr.n_surface_tiles}/{r_hcr.n_tiles_total}, L2 {r_hcr.n_l2_tiles}; "
        f"CZ tiles {r_cz.n_surface_tiles}/{r_cz.n_tiles_total}, L2 {r_cz.n_l2_tiles})",
        fontsize=11,
    )
    fig.savefig(save_path, dpi=110)
    plt.close(fig)
    print(f"saved {save_path}")


def main(subjects=None):
    subjects = subjects or BENCHMARK_SUBJECTS
    for sid in subjects:
        tgt_tmp = OUT_TMP / "figures" / f"walkthrough_{sid}.png"
        render_subject(sid, tgt_tmp)
        # best-effort mirror
        try:
            tgt_sess = OUT_SESSION / "figures" / f"walkthrough_{sid}.png"
            import shutil
            shutil.copy(tgt_tmp, tgt_sess)
        except Exception as exc:
            print("mirror failed:", exc)


if __name__ == "__main__":
    main()
