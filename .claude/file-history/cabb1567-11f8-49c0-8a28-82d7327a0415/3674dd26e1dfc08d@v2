def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    if s is None: return np.nan, np.nan
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


HCR_SUBJECTS = ["755252", "767018", "767022", "782149", "788406", "790322"]

for sid in HCR_SUBJECTS:
    print(f"=== {sid} ===", flush=True)
    s = load_subject(sid)
    vol, xy_um, z_um, channels = load_hcr_combined(s, level=4)
    pts = hcr_px_to_um(s.hcr_centroids[["z_px","y_px","x_px"]].values, s)[:, [2,1,0]]

    # first (current default)
    r1 = _mod.estimate_surface_and_l2_image_based(vol, z_um, xy_um, column_top_method="first")
    a1, o1 = eval_surf(r1.surface, pts)
    print(f"  first:   c={r1.surface['c']:6.1f} lift={r1.clamp_lift_um:5.1f} n_tops={r1.n_column_tops} above={a1:.4f} onset={o1}", flush=True)

    # longest
    r2 = _mod.estimate_surface_and_l2_image_based(vol, z_um, xy_um, column_top_method="longest")
    a2, o2 = eval_surf(r2.surface, pts)
    print(f"  longest: c={r2.surface['c']:6.1f} lift={r2.clamp_lift_um:5.1f} n_tops={r2.n_column_tops} above={a2:.4f} onset={o2}", flush=True)
