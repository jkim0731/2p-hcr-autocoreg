import tifffile


def _load_cz_image(s):
    cz_tifs = list(s.coreg_dir.glob("*reg-dim-swapped.ome.tif"))
    if not cz_tifs:
        cz_tifs = list(s.coreg_dir.glob("*zstack.tif"))
    if not cz_tifs:
        return None
    img = tifffile.imread(str(cz_tifs[0]))
    while img.ndim > 3 and img.shape[0] == 1:
        img = img[0]
    return img.astype(np.float32, copy=False)


def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


