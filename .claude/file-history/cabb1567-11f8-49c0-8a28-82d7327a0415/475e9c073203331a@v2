def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    if s is None: return np.nan, np.nan, np.nan
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return s["c"], above, onset


HCR_SUBJECTS = ["755252", "767018", "767022", "782149", "788406", "790322"]

# Directly compute anchor_top with both methods to measure contamination gap
def measure_contamination_gap(vol, z_um, xy_um, column_stride_um=10.0):
    sx = max(1, int(round(column_stride_um / xy_um)))
    vol_sub = vol[:, ::sx, ::sx].astype(np.float32, copy=False)
    top_first, _, _ = _mod._per_column_top_in_band(
        vol_sub, z_um, None, None,
        relative_margin=0.05, min_signal_abs_frac=0.20,
        min_thick_um=15.0, top_method="first")
    top_sub, _, _ = _mod._per_column_top_in_band(
        vol_sub, z_um, None, None,
        relative_margin=0.05, min_signal_abs_frac=0.20,
        min_thick_um=15.0, top_method="first_substantial",
        top_substantial_frac=0.5)
    first_valid = np.isfinite(top_first) if top_first is not None else np.zeros(0, dtype=bool)
    sub_valid = np.isfinite(top_sub) if top_sub is not None else np.zeros(0, dtype=bool)
    both = first_valid & sub_valid
    if both.sum() < 50:
        return 0.0, 0.0, 0, 0
    # Compute diff only on matched columns
    diff = top_sub[both] - top_first[both]
    gap_med = float(np.median(diff))
    gap_p90 = float(np.percentile(diff, 90))
    return gap_med, gap_p90, int(first_valid.sum()), int(sub_valid.sum())


