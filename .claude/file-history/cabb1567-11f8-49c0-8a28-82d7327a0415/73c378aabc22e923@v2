def sz(s, x, y):
    return (s["a"]*x + s["b"]*y + s["c"]
            + s.get("p",0)*x*x + s.get("q",0)*x*y + s.get("r",0)*y*y)


def eval_surf(s, pts):
    zs = sz(s, pts[:,0], pts[:,1])
    depth = pts[:,2] - zs
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        for c, d in zip(centers, density):
            if c >= 0 and d >= 0.5 * bulk:
                onset = float(c); break
    return above, onset


def adaptive_clamp(surface, xs, ys, zs, *, tile_um=120.0, within_tile_q=0.10,
                    safety_offset_um=3.0, min_per_tile=5, iqr_k=3.0,
                    density_radius_um=30.0, density_min_neighbors=3):
    # Filter tops by density first (same as main)
    keep = _mod._filter_tops_by_density(
        xs, ys, zs, radius_um=density_radius_um,
        min_neighbors=density_min_neighbors)
    if keep.sum() < 50:
        return surface, 0.0, 0, "no-tops"
    xs_f = xs[keep]; ys_f = ys[keep]; zs_f = zs[keep]
    xb = (xs_f // tile_um).astype(int)
    yb = (ys_f // tile_um).astype(int)
    key = yb * 100000 + xb
    df = pd.DataFrame({"k": key, "x": xs_f, "y": ys_f, "z": zs_f})
    agg = df.groupby("k").agg(
        x=("x", "median"), y=("y", "median"),
        z=("z", lambda v: float(np.quantile(v, within_tile_q))),
        n=("z", "size"))
    agg = agg[agg["n"] >= int(min_per_tile)]
    if agg.empty:
        return surface, 0.0, 0, "no-tiles"
    tx, ty, tz = agg["x"].values, agg["y"].values, agg["z"].values
    plane_z = sz(surface, tx, ty)
    deficit = plane_z - tz
    pos = deficit[deficit > 0]
    if len(pos) == 0:
        return surface, 0.0, int(len(agg)), "no-pos"
    # Adaptive: cap max lift at Q75 + k*IQR (Tukey-style outlier fence)
    q25, q75 = np.quantile(pos, [0.25, 0.75])
    iqr = q75 - q25
    fence = q75 + float(iqr_k) * iqr
    lift_max = float(pos.max())
    lift = min(lift_max, fence)
    out = dict(surface)
    out["c"] = float(out["c"] - lift - safety_offset_um)
    n_capped = int((pos > fence).sum())
    note = f"fence={fence:.1f} raw={lift_max:.1f} capped={n_capped}/{len(pos)}"
    return out, float(lift), int(len(agg)), note


