"""Sweep clamp params on HCR 755252."""
from __future__ import annotations
import sys
import importlib.util
from pathlib import Path
import numpy as np

ROOT = Path("/root/capsule")
DEV = ROOT / "code" / "dev_code"
sys.path.insert(0, str(DEV))

_spec = importlib.util.spec_from_file_location(
    "img_surface_l2", str(DEV / "03_image_based_surface.py"))
_mod = importlib.util.module_from_spec(_spec)
sys.modules["img_surface_l2"] = _mod
_spec.loader.exec_module(_mod)

from benchmark_analysis import load_hcr_combined
from benchmark_data_loader import hcr_px_to_um, load_subject

sid = sys.argv[1] if len(sys.argv) > 1 else "755252"
s = load_subject(sid)
vol, xy_um, z_um, channels = load_hcr_combined(s, level=4)
hcr_xyz = hcr_px_to_um(s.hcr_centroids[["z_px","y_px","x_px"]].values, s)[:, [2,1,0]]

def sz(surf, x, y):
    return (surf["a"]*x + surf["b"]*y + surf["c"] +
            surf.get("p",0)*x*x + surf.get("q",0)*x*y + surf.get("r",0)*y*y)

def eval_surf(surf):
    z_surf = sz(surf, hcr_xyz[:,0], hcr_xyz[:,1])
    depth = hcr_xyz[:,2] - z_surf
    n = len(depth)
    above = (depth < 0).sum() / n
    edges = np.arange(-200, 404, 5.0)
    h, _ = np.histogram(depth, bins=edges)
    density = h / (5.0 * max(n, 1))
    centers = 0.5 * (edges[:-1] + edges[1:])
    bulk = density[(centers >= 50) & (centers <= 200)].mean()
    onset = np.nan
    if bulk > 0:
        halfmax = 0.5 * bulk
        for c, d in zip(centers, density):
            if c >= 0 and d >= halfmax:
                onset = float(c); break
    return above, onset

print(f"--- {sid} ---")
for col_margin in [0.25, 0.40, 0.55]:
    for wtq in [0.10, 0.30, 0.50]:
        res = _mod.estimate_surface_and_l2_image_based(
            vol, z_um, xy_um,
            column_margin=col_margin,
            min_signal_abs_frac=0.20,
            clamp_within_tile_q=wtq,
            band_um=150.0,
            safety_offset_um=3.0,
        )
        if res.surface is None:
            print(f"col={col_margin} wtq={wtq}: NO SURFACE")
            continue
        above, onset = eval_surf(res.surface)
        print(f"col_m={col_margin:.2f} wtq={wtq:.2f}: tops={res.n_column_tops:5d} "
              f"lift={res.clamp_lift_um:6.1f}  c={res.surface['c']:6.1f}  "
              f"above={above:.4f}  onset={onset:.1f}")
