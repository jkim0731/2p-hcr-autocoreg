            if res.surface is None:
                continue
            above, onset = eval_surf(res.surface, pts)
            print(f" band={band:3.0f} den=(r{r_um:.0f},n{min_n:2d}): "
                  f"c={res.surface['c']:6.1f} lift={res.clamp_lift_um:6.1f} "
                  f"above={above:.4f} onset={onset:.1f}")
