    "import numpy as np\n",
    "subjects = ['755252', '767018', '767022', '782149', '788406', '790322']\n",
    "for sid in subjects:\n",
    "    sub = df[df.subject == sid].sort_values('Q', ascending=False).copy()\n",
    "    sub['mark'] = np.where(sub.selected, '★',\n",
    "                  np.where(sub['pass'], '✓', '✗'))\n",
    "    print(f'\\n=== {sid} ===')\n",
    "    print(sub[['mark', 'name', 'Q', 'Qabove', 'Qcon_n', 'above', 'onset']]\n",
    "          .to_string(index=False, float_format=lambda x: f'{x:7.4f}'))"
