"""v2-S04 Stage D iter 2 — validate step 1 candidates against `landmarks_qced`.

Question: do our top-slab candidate lists *contain* the manual landmark
HCR cells?  If the answer is no, the seed-constellation idea won't help
because the right answers were filtered out by the (R_xy, R_z, depth)
gate.  If yes, the next step is to score which subset of K landmarks
form a good constellation.

Per-subject metrics:
  - n_lm_top_slab      : active manual landmarks whose CZ cell is in our top-slab.
  - n_lm_recovered     : among those, how many had any candidate row.
  - n_lm_at_rank_1     : among those, how many had the manual HCR id as top-ranked.
  - n_lm_in_top_3      : how many in top-3.
  - rank_distribution  : list of ranks (NaN if not in candidate list).
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

sys.path.insert(0, "/root/capsule/code/full_automatic_execution_02/lib")
sys.path.insert(0, "/root/capsule/data/claude_data/full_automatic_execution_01")
sys.path.insert(0, "/root/capsule/code/dev_code")
sys.path.insert(0, "/root/capsule/data/claude_data/sessions/03c_onset_features/iterations")
sys.path.insert(0, "/root/capsule/data/claude_data/sessions/08_surface_vascular_match")

import numpy as np
import pandas as pd

from benchmark_data_loader import load_subject
from benchmark_analysis import depth_from_surface
from surfaces_iter08 import get_cz_surface_iter08

OUT = Path(__file__).resolve().parent
SUBJECTS_ALL = ["755252", "767018", "767022", "782149", "788406", "790322"]
DEPTH_BAND_UM = (0.0, 50.0)
TAG = __import__("os").environ.get("TAG", "")

ID_RE = re.compile(r"cz(\d+)-hcr(\d+)$")


def _parse_lm_ids(ids: pd.Series) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
    """Parse 'qced_cz47-hcr5908' or 'cz47-hcr5908'.  Returns (mask, cz_ids, hcr_ids)."""
    cz_ids, hcr_ids, ok = [], [], []
    for v in ids:
        s = str(v)
        if s.startswith("qced_"):
            s = s[5:]
        m = ID_RE.search(s)
        if m is None:
            cz_ids.append(-1); hcr_ids.append(-1); ok.append(False)
        else:
            cz_ids.append(int(m.group(1)))
            hcr_ids.append(int(m.group(2)))
            ok.append(True)
    return np.array(ok), np.array(cz_ids), np.array(hcr_ids)


def _validate_subject(sid: str) -> dict:
    cand_csv = OUT / f"step1_{sid}{TAG}_topslab_candidates.csv"
    if not cand_csv.exists():
        return {"subject_id": sid, "error": "no candidates csv"}
    cand = pd.read_csv(cand_csv)

    s = load_subject(sid)
    lm = s.landmarks_qced
    lm = lm[lm["active"]].copy()
    ok, cz_lm_ids, hcr_lm_ids = _parse_lm_ids(lm["ids"])
    lm = lm.loc[ok].assign(cz_id=cz_lm_ids[ok], hcr_id=hcr_lm_ids[ok])

    # Compute CZ depth for landmark CZ cells using the same iter08 surface.
    surf = get_cz_surface_iter08(s)
    if surf is None:
        return {"subject_id": sid, "error": "no CZ surface"}
    cz_xyz = lm[["cz_x", "cz_y", "cz_z"]].values.astype(float).copy()
    cz_xyz[:, 0] *= s.cz_xy_um
    cz_xyz[:, 1] *= s.cz_xy_um
    cz_xyz[:, 2] *= s.cz_z_um
    depth = depth_from_surface(cz_xyz, surf)
    lm["cz_depth_um"] = depth
    in_slab = (depth >= DEPTH_BAND_UM[0]) & (depth <= DEPTH_BAND_UM[1])
    lm_slab = lm.loc[in_slab].copy()

    # For each landmark, check if (cz_id, hcr_id) appears in candidate table.
    cand_lookup = cand.set_index(["cz_id", "hcr_id"])["rank"].to_dict()
    cand_per_cz = cand.groupby("cz_id").size().to_dict()

    ranks = []
    for _, row in lm_slab.iterrows():
        key = (int(row.cz_id), int(row.hcr_id))
        ranks.append(cand_lookup.get(key, np.nan))
    lm_slab["rank"] = ranks
    lm_slab["had_any_cand"] = lm_slab["cz_id"].map(
        lambda c: c in cand_per_cz)

    n_lm_total_active = int(in_slab.size)
    n_lm_top_slab = int(in_slab.sum())
    n_lm_cz_had_any = int(lm_slab["had_any_cand"].sum())
    n_lm_recovered = int(lm_slab["rank"].notna().sum())
    rec = {f"recall@{k}": float((lm_slab["rank"] <= k).sum() / n_lm_top_slab)
           if n_lm_top_slab else 0.0
           for k in (1, 3, 5, 10, 20)}
    return {
        "subject_id": sid,
        "n_lm_total_active": n_lm_total_active,
        "n_lm_top_slab": n_lm_top_slab,
        "n_cz_had_any_cand": n_lm_cz_had_any,
        "n_lm_recovered": n_lm_recovered,
        **rec,
        "recall_any": (n_lm_recovered / n_lm_top_slab) if n_lm_top_slab else 0.0,
    }


def main():
    rows = []
    for sid in SUBJECTS_ALL:
        out = _validate_subject(sid)
        rows.append(out)
        print(f"{sid}: {out}", flush=True)
    df = pd.DataFrame(rows)
    out_csv = OUT / f"step1_validation_against_landmarks{TAG}.csv"
    df.to_csv(out_csv, index=False)
    print(f"\n{df.to_string(index=False)}")
    print(f"\n→ {out_csv}")


if __name__ == "__main__":
    main()
