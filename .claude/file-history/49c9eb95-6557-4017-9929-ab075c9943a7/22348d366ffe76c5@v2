cells.append(nbf.v4.new_code_cell("""\
import sys
sys.path.insert(0, '/root/capsule/code/full_automatic_execution_02/lib')
sys.path.insert(0, '/root/capsule/code/dev_code')
sys.path.insert(0, '/root/capsule/data/claude_data/full_automatic_execution_01')
sys.path.insert(0, '/root/capsule/data/claude_data/sessions/03c_onset_features/iterations')
sys.path.insert(0, '/root/capsule/data/claude_data/sessions/08_surface_vascular_match')

from benchmark_data_loader import load_subject
import lib.centroid_helpers as ch
from bench_e_tps import _fit_aniso_with_means, _aniso_apply_explicit, _icp_loop

show = ['790322', '782149']
fig, axes = plt.subplots(1, len(show), figsize=(11.5, 5))
for ax, sid in zip(axes, show):
    s = load_subject(sid)
    cz_zyx, cz_ids = ch.centroids_um(s, 'cz')
    hcr_zyx, hcr_ids = ch.centroids_um(s, 'hcr_gfp')
    cz_id2i = {int(c): i for i,c in enumerate(cz_ids)}
    hcr_id2i = {int(h): i for i,h in enumerate(hcr_ids)}

    srow = tps[(tps.subject_id == sid) & (tps.method == 'E_TPS_aniso_icp')].iloc[0]
    cz_anchors = [int(x) for x in str(srow['anchor_cz_ids']).split(',')]
    hcr_anchors = [int(x) for x in str(srow['anchor_hcr_ids']).split(',')]
    seed_cz_zyx = np.array([cz_zyx[cz_id2i[c]] for c in cz_anchors])
    seed_hcr_zyx = np.array([hcr_zyx[hcr_id2i[h]] for h in hcr_anchors])
    fit = _fit_aniso_with_means(seed_cz_zyx, seed_hcr_zyx)
    cz_warp = _aniso_apply_explicit(cz_zyx, R=fit['R'], scales=fit['scales'],
                                     src_mean=fit['src_mean'], dst_mean=fit['dst_mean'])
    cz_warp_icp, _ = _icp_loop(cz_warp, hcr_zyx)
    anchor_pts = np.array([hcr_zyx[hcr_id2i[h]] for h in hcr_anchors])

    ax.scatter(hcr_zyx[:, 2], hcr_zyx[:, 1], s=4, color='lightgray', alpha=0.5,
               label='HCR GFP+')
    ax.scatter(cz_warp_icp[:, 2], cz_warp_icp[:, 1], s=4, color='steelblue',
               alpha=0.6, label='E_TPS_aniso_icp warped CZ')
    ax.scatter(anchor_pts[:, 2], anchor_pts[:, 1], s=180, marker='*',
               color='crimson', edgecolor='black', linewidth=1.5,
               label='K=4 anchors', zorder=5)
    r20 = float(srow['recall_at_20um'])
    ax.set_title(f"{sid}{' (rescue)' if sid in RESCUE else ''}\\n"
                 f"E_TPS_aniso_icp  r@20={r20:.3f}")
    ax.set_xlabel('x (µm)'); ax.set_ylabel('y (µm)')
    ax.set_aspect('equal')
    ax.legend(fontsize=8, loc='upper right')
plt.tight_layout()
plt.savefig(OUT / 'fig_s05_spatial_overlay.png', dpi=120)
plt.show()
"""))

