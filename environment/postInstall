#!/usr/bin/env bash
set -euxo pipefail

echo "Installing optional repos..."
cd / && git clone https://github.com/AllenNeuralDynamics/comb
cd /comb && git checkout for_gcamp_validation && pip install -e .

cd /
git clone https://github.com/AllenNeuralDynamics/lamf-analysis
cd /lamf-analysis && pip install -e .

cd / && git clone https://github.com/jkim0731/2p2fish
cd /2p2fish && pip install -e .
cd / &&git clone https://github.com/jkim0731/mfish-roi-classifier
cd /mfish-roi-classifier && pip install -e .
cd / && git clone https://github.com/AllenNeuralDynamics/capsule-3D-HCR-ROI-labeling
cd /capsule-3D-HCR-ROI-labeling && pip install -e .
cd / && git clone https://github.com/AllenNeuralDynamics/capsule-3D-HCR-ROI-classifier
cd /capsule-3D-HCR-ROI-classifier && pip install -e .
cd /&& git clone https://github.com/AllenNeuralDynamics/capsule-3D-HCR-ROI-classifier-training
cd /capsule-3D-HCR-ROI-classifier-training && pip install -e .

chmod -R a+rwX /lamf-analysis /comb 
chmod -R a+rwX /2p2fish /mfish-roi-classifier 
chmod -R a+rwX /capsule-3D-HCR-ROI-labeling /capsule-3D-HCR-ROI-classifier /capsule-3D-HCR-ROI-classifier-training



# # Updating FIJI
# # Can be commented out if not used
# echo "Updating Fiji (optional)..."
# FIJI_DIR=/Fiji.app
# FIJI="$FIJI_DIR/ImageJ-linux64"
# if [ -x "$FIJI" ]; then
#   "$FIJI" --update update
# fi

echo "Installing Claude CLI..."

# Keep Claude data under capsule storage, not main workstation disk.
# This directory will be owned by claude-user (see FIX #2 below).
mkdir -p /root/capsule/.claude

# Root shell convenience ? append to .bashrc only once
if ! grep -q 'CLAUDE_CONFIG_DIR=/root/capsule/.claude' /root/.bashrc 2>/dev/null; then
cat >> /root/.bashrc <<'EOF'

# Claude config + logs in capsule storage
export CLAUDE_CONFIG_DIR=/root/capsule/.claude
export PATH="/root/.local/bin:/usr/local/bin:/opt/conda/bin:$PATH"
EOF
fi

# Export for the remainder of this script (curl installer needs PATH)
export CLAUDE_CONFIG_DIR=/root/capsule/.claude
export PATH="/root/.local/bin:/usr/local/bin:/opt/conda/bin:$PATH"

curl -fsSL https://claude.ai/install.sh | bash

echo "Claude installation complete."
echo "Claude data dir: /root/capsule/.claude"

echo "Setting up claude-user..."

# FIX #3: catch useradd failures other than "user already exists" (exit 9).
# Exit code 9 = user already exists, which is fine; anything else is a real error.
useradd -m claude-user || { code=$?; [ $code -eq 9 ] || exit $code; }

# Make Claude binary globally accessible
ln -sf /root/.local/bin/claude /usr/local/bin/claude

# Let claude-user traverse required paths
chmod o+x /root
chmod o+rx /root/capsule
# The rest of the permissions are done by running start.sh ("startcapsule" alias)

# Ensure conda and correct env vars are available in claude-user login shells.
cat > /home/claude-user/.profile <<'EOF'
export PATH="/usr/local/bin:/opt/conda/bin:$PATH"
export CLAUDE_CONFIG_DIR=/root/capsule/.claude

# Make conda available in login shells
if [ -r /opt/conda/etc/profile.d/conda.sh ]; then
    . /opt/conda/etc/profile.d/conda.sh
fi

# Load .bashrc too if present
if [ -f ~/.bashrc ]; then
    . ~/.bashrc
fi
EOF
chown claude-user:claude-user /home/claude-user/.profile

echo "claude-user setup complete."
echo
echo "If Claude should edit /root/capsule/code, run:"
echo "  chown -R claude-user:claude-user /root/capsule/code"
echo
echo "Run Claude with:"
echo '  su -s /bin/bash - claude-user -c "cd /root/capsule && claude --dangerously-skip-permissions"'

# Helper aliases for root sessions.
# Use a shell function instead of deeply-escaped alias for claude-skip
# so DISPLAY/DBUS vars are forwarded cleanly without brittle quote nesting.
# Note: these only take effect in interactive root shells (sourced .bashrc).
if ! grep -q "alias startcapsule=" /root/.bashrc 2>/dev/null; then
cat >> /root/.bashrc <<'EOF'
alias startcapsule='bash /root/capsule/environment/start.sh'
alias vscode_setting='bash /root/capsule/environment/vscode_setting.sh'

# Forward display env vars to claude-user's session cleanly via a function.
# Must be run from an active desktop session (DISPLAY must be set).
claude-skip() {
    su -s /bin/bash - claude-user -c \
        "export DISPLAY='${DISPLAY}'; \
         export DBUS_SESSION_BUS_ADDRESS='${DBUS_SESSION_BUS_ADDRESS}'; \
         cd /root/capsule && claude --dangerously-skip-permissions"
}

claude-user-shell() {
    su -s /bin/bash - claude-user -c \
        "export DISPLAY='${DISPLAY}'; \
         export DBUS_SESSION_BUS_ADDRESS='${DBUS_SESSION_BUS_ADDRESS}'; \
         cd /root/capsule && exec bash -i"
}
EOF
fi