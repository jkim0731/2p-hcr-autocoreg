#!/usr/bin/env bash
set -euxo pipefail

echo "Installing optional repos..."
cd /
git clone https://github.com/AllenNeuralDynamics/comb
cd /comb && pip install -e .
cd /comb && git checkout for_gcamp_validation
cd /
git clone https://github.com/AllenNeuralDynamics/lamf-analysis
cd /lamf-analysis && pip install -e .

cd /
git clone https://github.com/AllenNeuralDynamics/2p2fish
cd /2p2fish && pip install -e .
cd /
git clone https://github.com/AllenNeuralDynamics/mfish-roi-classifier
cd /mfish-roi-classifier && pip install -e .

echo "Writing VS Code profile settings for stable kernel detection..."
mkdir -p /root/capsule/scratch/.vscode-root/User
cat > /root/capsule/scratch/.vscode-root/User/settings.json << 'EOF'
{
  "python.useEnvironmentsExtension": false,
  "python.defaultInterpreterPath": "/opt/conda/bin/python3",
  "python.condaPath": "/opt/conda/bin/conda",
  "jupyter.jupyterServerType": "local",
  "jupyter.kernels.excludePythonEnvironments": [],
  "python-envs.workspaceSearchPaths": [
    "./.venv"
  ],
  "python-envs.globalSearchPaths": [
    "/opt/conda",
    "/opt/conda/envs",
    "/root/.conda/envs",
    "/root/.virtualenvs"
  ],
  "python.terminal.activateEnvironment": true,
  "python.experiments.enabled": false,
  "python.testing.pytestEnabled": false,
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/data/**": true,
    "**/results/**": true,
    "**/scratch/**": true
  },
  "search.exclude": {
    "**/data/**": true,
    "**/results/**": true,
    "**/scratch/**": true
  }
}
EOF

echo "Updating Fiji (optional)..."
FIJI_DIR=/Fiji.app
FIJI="$FIJI_DIR/ImageJ-linux64"
if [ -x "$FIJI" ]; then
  "$FIJI" --update update
fi

echo "Installing Claude CLI..."

# Keep Claude data under capsule storage, not main workstation disk
mkdir -p /root/capsule/.claude

# Root shell convenience
if ! grep -q 'CLAUDE_CONFIG_DIR=/root/capsule/.claude' /root/.bashrc 2>/dev/null; then
cat >> /root/.bashrc <<'EOF'

# Claude config + logs in capsule storage
export CLAUDE_CONFIG_DIR=/root/capsule/.claude
export PATH="/root/.local/bin:/usr/local/bin:/opt/conda/bin:$PATH"
EOF
fi

export CLAUDE_CONFIG_DIR=/root/capsule/.claude
export PATH="/root/.local/bin:/usr/local/bin:/opt/conda/bin:$PATH"

curl -fsSL https://claude.ai/install.sh | bash

echo "Claude installation complete."
echo "Claude data dir: /root/capsule/.claude"

echo "Setting up claude-user..."

# Create non-root user for --dangerously-skip-permissions
useradd -m claude-user 2>/dev/null || true

# Make Claude binary globally accessible
ln -sf /root/.local/bin/claude /usr/local/bin/claude

# Let claude-user traverse required paths
chmod o+x /root
chmod o+rx /root/capsule

# Optional: writable workspace area Claude may edit
#chown -R claude-user:claude-user /root/capsule/scratch
#chown -R claude-user:claude-user /root/capsule/code
#chmod o+rx /root/capsule/data

# Critical fix:
# Claude runs as claude-user, so the Claude state directory must be owned by claude-user.
# Otherwise Claude may start but fail due to unreadable credentials/state.
#chown -R claude-user:claude-user /root/capsule/.claude

# These permissions are to be fixed using startcapsule ('bash /root/capsule/environment/start.sh')

# Ensure conda init is available to claude-user login shells by using .profile
cat > /home/claude-user/.profile <<'EOF'
export PATH="/usr/local/bin:/opt/conda/bin:$PATH"
export CLAUDE_CONFIG_DIR=/root/capsule/.claude

# Make conda available in login shells
if [ -r /opt/conda/etc/profile.d/conda.sh ]; then
    . /opt/conda/etc/profile.d/conda.sh
fi

# Optionally load .bashrc too
if [ -f ~/.bashrc ]; then
    . ~/.bashrc
fi
EOF
chown claude-user:claude-user /home/claude-user/.profile

echo "claude-user setup complete."
echo
echo "If Claude should edit /root/capsule/code, run:"
echo "  chown -R claude-user:claude-user /root/capsule/code"
echo
echo "Run Claude with:"
echo '  su -s /bin/bash - claude-user -c "cd /root/capsule && claude --dangerously-skip-permissions"'

# Optional helper alias for root sessions
if ! grep -q "alias claude-skip=" /root/.bashrc 2>/dev/null; then
cat >> /root/.bashrc <<'EOF'
alias startcapsule='bash /root/capsule/environment/start.sh'

alias claude-skip='su -s /bin/bash - claude-user -c "export DISPLAY='\''$DISPLAY'\''; export DBUS_SESSION_BUS_ADDRESS='\''$DBUS_SESSION_BUS_ADDRESS'\''; cd /root/capsule && claude --dangerously-skip-permissions"'
alias claude-user-shell='su -s /bin/bash - claude-user -c "export DISPLAY='\''$DISPLAY'\''; export DBUS_SESSION_BUS_ADDRESS='\''$DBUS_SESSION_BUS_ADDRESS'\''; cd /root/capsule && exec bash -i"'
EOF
fi